  "mcp": {
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    },
    "engram": {
      "type": "stdio",
      "command": "engram",
      "args": [
        "mcp",
        "--tools=agent"
      ],
      "enabled": true
    }
  },
  "tools": {
    "bash": true,
    "readFile": true,
    "writeFile": true,
    "editFile": true,
    "listFiles": true
  },
  "default_agent": "orchestrator",
  "share": "manual",
  "compaction": {
    "auto": true,
    "prune": true
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "build/**",
      ".git/**",
      ".engram-data/**",
      "tmp-session-debug/**",
      "logs/**",
      "session/**"
    ]
  },
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "skill": "allow",
    "question": "allow",
    "todowrite": "allow",
    "lsp": "ask",
    "webfetch": "deny",
    "websearch": "deny",
    "external_directory": "ask",
    "doom_loop": "deny",
    "edit": "allow",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git log*": "allow",
      "git diff*": "allow",
      "git show*": "allow",
      "rg *": "allow",
      "Get-ChildItem *": "allow",
      "Test-Path *": "allow"
    },
    "task": {
      "*": "allow"
    }
  },
  "systemPromptOptimization": {
    "enabled": true,
    "targetTokens": 2000,
    "maxTokens": 5000,
    "compression": "semantic",
    "abbreviations": {
      "implementation": "impl",
      "function": "fn",
      "configuration": "cfg",
      "required": "req",
      "optional": "opt",
      "reference": "ref",
      "standard": "std",
      "performance": "perf",
      "security": "sec",
      "development": "dev",
      "production": "prod",
      "environment": "env",
      "database": "db",
      "application": "app",
      "service": "svc",
      "repository": "repo"
    },
    "cache": {
      "enabled": true,
      "directory": ".session/prompt-cache",
      "ttl": 3600
    },
    "security": {
      "scanOnLoad": true,
      "blockSecrets": true,
      "blockXss": true
    },
    "versioning": {
      "enabled": true,
      "directory": ".session/prompt-versions"
    },
    "monitoring": {
      "trackTokens": true,
      "alertThreshold": 3000,
      "criticalThreshold": 5000
    }
  }
}
