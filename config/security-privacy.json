{
  "version": "1.0.0",
  "name": "foundation-security-privacy",
  "description": "Security and privacy configuration for Foundation orchestrator",

  "security": {
    "enabled": true,
    "autoInit": true,
    "autoSanitize": true,
    "autoBlock": true,
    "mode": "enforced",
    "audit": true
  },

  "privacy": {
    "prohibited": [
      {
        "category": "machineId",
        "patterns": ["COMPUTERNAME", "$env:COMPUTERNAME", "[System.Environment]::MachineName"],
        "replacement": "<MACHINE>",
        "severity": "HIGH"
      },
      {
        "category": "userId",
        "patterns": ["USERNAME", "$env:USERNAME", "[System.Environment]::UserName"],
        "replacement": "<USER>",
        "severity": "HIGH"
      },
      {
        "category": "homePath",
        "patterns": ["$env:USERPROFILE", "$env:HOME", "$env:APPDATA"],
        "replacement": "<HOME>",
        "severity": "HIGH"
      },
      {
        "category": "fullPaths",
        "patterns": ["C:\\\\Users\\\\[^\\\\]+", "/home/[^/]+", "\\\\\\\\[A-Za-z0-9_-]+\\\\\"],
        "replacement": "<PATH>",
        "severity": "HIGH"
      },
      {
        "category": "credentials",
        "patterns": ["API_KEY", "SECRET", "PASSWORD", "TOKEN"],
        "replacement": "<REDACTED>",
        "severity": "CRITICAL"
      }
    ],
    "criticalBlock": [
      {
        "id": "aws-key",
        "pattern": "AKIA[0-9A-Z]{16}",
        "action": "BLOCK"
      },
      {
        "id": "github-token",
        "pattern": "ghp_[A-Za-z0-9]{36}",
        "action": "BLOCK"
      },
      {
        "id": "stripe-key",
        "pattern": "sk_live_[0-9a-zA-Z]{24,}",
        "action": "BLOCK"
      },
      {
        "id": "private-key",
        "pattern": "-----BEGIN (RSA|EC|DSA|PRIVATE KEY-----",
        "action": "BLOCK"
      }
    ]
  },

  "mcpSecurity": {
    "enabled": true,
    "scopeToWorkspace": true,
    "allowedPaths": ["$PWD/**", "$WORKSPACE/**", "<PROJECT>/**"],
    "deniedPaths": [
      "**/.env",
      "**/.ssh/**",
      "**/node_modules/.package-lock.json",
      "**/.git/objects/**"
    ],
    "noNetworkExternal": false,
    "auditFileAccess": true
  },

  "targets": {
    "ai-api": {
      "sanitize": true,
      "blockCritical": true,
      "audit": true
    },
    "mcp": {
      "sanitize": true,
      "scopeValidation": true,
      "audit": true
    },
    "log": {
      "sanitize": true,
      "blockCritical": false,
      "audit": true
    },
    "error": {
      "sanitize": true,
      "blockCritical": false,
      "audit": false
    }
  },

  "audit": {
    "enabled": true,
    "path": ".runtime/security-audit.log",
    "format": "json",
    "rotateDaily": true,
    "retentionDays": 30
  },

  "hooks": {
    "prePrompt": "scripts/security/privacy-gateway.ps1",
    "preMcp": "scripts/security/mcp-security-validator.ps1",
    "preCommit": "hooks/pre-commit-privacy.ps1"
  },

  "reporting": {
    "enabled": true,
    "weekly": true,
    "metrics": [
      "sanitizedCount",
      "violationsBlocked",
      "patternsDetected",
      "auditEntries"
    ]
  }
}