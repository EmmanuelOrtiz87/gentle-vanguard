{
  "name": "Cursor - Gentle-Vanguard Workspace",
  "version": "2.0.0",
  "description": "Optimized for Cursor Agent Best Practices with modular rules, commands, and plans",
  "aiSettings": {
    "model": "claude-sonnet-4-5",
    "temperature": 0.3,
    "maxTokens": 4500,
    "localFirst": true
  },
  "toolPermissions": {
    "websearch": "deny",
    "codesearch": "deny",
    "webfetch": "deny"
  },
  "preProcessing": {
    "enabled": true,
    "mandatory": true,
    "script": "scripts/utilities/pre-process-input.ps1",
    "scriptArgs": { "UserInput": "USER_INPUT_HERE", "WorkspaceRoot": "." }
  },
  "rules": {
    "paths": [
      ".cursor/rules/core-workflow.md",
      ".cursor/rules/commands.md",
      ".cursor/rules/code-style.md"
    ]
  },
  "commands": {
    "paths": [".cursor/commands/"],
    "autoLoad": true
  },
  "plans": {
    "directory": ".cursor/plans/",
    "autoSave": true
  },
  "sessionManagement": {
    "autostart": "scripts/utilities/session-autostart.cmd",
    "project": "gentle-vanguard"
  },
  "language": { "default": "es", "technicalTerms": "en" },
  "governanceLayers": {
    "GOV": ["project-orchestrator-skill"],
    "DEV": ["sdd-lifecycle"],
    "QA": ["sdd-lifecycle"],
    "OPS": ["docker-devops-skill"],
    "DOC": ["documentation-governance"],
    "SESSION": ["session-workflow-skill"]
  }
}
