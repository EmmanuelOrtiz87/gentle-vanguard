{
  "name": "Windsurf - Local-First Configuration",
  "version": "1.1.0",
  "description": "Local-first policy for Windsurf IDE with advanced context, indexing, and adaptive controls",
  "workspace": {
    "projectRoot": ".",
    "configFiles": ["opencode.json", "AGENTS.md", "CLAUDE.md", ".cursorrules", "docs/AGENTS.md"],
    "skillPaths": ["skills/", "~/.config/opencode/skills/"],
    "skillRegistry": ".atl/skill-registry.md"
  },
  "aiSettings": {
    "temperature": 0.3,
    "maxTokens": 4500,
    "localFirst": true,
    "planFirstForComplex": true,
    "executionTemplate": {
      "goal": true,
      "context": true,
      "constraints": true,
      "doneWhen": true
    }
  },
  "toolPermissions": {
    "websearch": "deny",
    "webfetch": "deny",
    "externalTools": "ask",
    "note": "External tools only available via orchestrator and explicit approval"
  },
  "contextManagement": {
    "useEngramMemory": true,
    "engramPaths": [".engram-data/", "scripts/.session/", "logs/"],
    "useLocalSkills": true,
    "useProjectDocs": true,
    "fastContext": true,
    "indexIgnoreFile": ".codeiumignore",
    "memoryTiering": {
      "hot": "active session",
      "warm": "1 day",
      "cold": "7 days"
    }
  },
  "mcpServers": {
    "context7": {
      "enabled": false,
      "note": "Enable only when local skills insufficient"
    }
  },
  "governanceLayers": {
    "GOV": ["project-orchestrator-skill"],
    "SAD": ["sdd-design"],
    "DEV": ["sdd-apply"],
    "QA": ["sdd-verify"],
    "OPS": ["docker-devops-skill"],
    "DOC": ["documentation-governance"],
    "SCRIPT-GOV": ["sdd-apply"],
    "REPORT": ["management-reporting-skill"]
  },
  "gitflowCapabilities": {
    "branch": ["create-gitflow-branch.ps1"],
    "pr": ["create-pull-request.ps1"],
    "hooks": ["pre-commit-validation.ps1"],
    "merge": ["post-merge-sync.ps1"],
    "workflow": ["git-workflow-skill"],
    "commit": ["git-workflow-skill"],
    "conflict": ["git-workflow-skill"]
  },
  "preProcessing": {
    "enabled": true,
    "mandatory": true,
    "script": "scripts/utilities/pre-process-input.ps1",
    "scriptArgs": {
      "UserInput": "USER_INPUT_HERE",
      "WorkspaceRoot": "."
    },
    "fallbackBehavior": "continue"
  },
  "sessionManagement": {
    "autostart": {
      "enabled": true,
      "script": "scripts/utilities/session-autostart.cmd",
      "platform": "windows",
      "alternatives": {
        "linux": "bash ./scripts/utilities/session-autostart.sh",
        "macos": "bash ./scripts/utilities/session-autostart.sh"
      }
    },
    "tracking": {
      "project": "gentle-vanguard",
      "directory": ".",
      "sessionIdPattern": "session-YYYY-MM-DD-XX"
    }
  },
  "language": {
    "default": "es",
    "technicalTerms": "en",
    "responseStyle": "concise, direct"
  },
  "cascade": {
    "restrictToLocal": true,
    "allowExternalTools": false,
    "gitignoreAccess": false,
    "adaptiveModelRouter": true,
    "webDocsSearch": "disabled"
  },
  "advanced": {
    "ssh": {
      "enabled": true,
      "linuxHostsOnly": true
    },
    "devContainers": {
      "enabled": true
    },
    "wsl": {
      "enabled": true
    },
    "marketplace": {
      "configurable": true
    }
  },
  "skillEmulation": {
    "enabled": true,
    "note": "Windsurf no tiene skill tool nativo — los skills se cargan manualmente",
    "criticalSkills": {
      "documentation": "skills/documentation-governance/SKILL.md",
      "sddLifecycle": "skills/sdd-lifecycle/SKILL.md",
      "codeReview": "skills/code-review-orchestrator-skill/SKILL.md",
      "sessionWorkflow": "skills/session-workflow-skill/SKILL.md",
      "testing": ["skills/playwright-skill/SKILL.md", "skills/pytest-skill/SKILL.md"]
    }
  },
  "adaptiveOptimization": {
    "enabled": true,
    "controller": "scripts/utilities/adaptive-codex-windsurf-profile.ps1",
    "mode": "temporary",
    "autoRestore": true
  }
}
