{
  "name": "Cline VSCode Plugin - Dify.io Integration (Optimized)",
  "version": "2.1.0",
  "description": "Local-first optimized configuration for Cline VSCode plugin using Dify.io as LLM provider with full token efficiency and context management",
  "lastUpdated": "2026-04-28",
  "optimization": {
    "status": "OPTIMIZED",
    "targetReduction": "40-50%",
    "expectedTokenSavings": "significant",
    "notes": "Fully aligned with gentle-vanguard local-first policy"
  },
  "provider": {
    "type": "dify",
    "endpoint": "https://api.dify.io/v1",
    "authMethod": "api-key",
    "requiredEnv": ["DIFY_API_KEY"],
    "notes": "Set DIFY_API_KEY environment variable with your Dify.io API key",
    "requestTimeout": 30000,
    "retryPolicy": {
      "maxRetries": 3,
      "backoffMultiplier": 2,
      "initialDelayMs": 1000
    }
  },
  "tokenOptimization": {
    "enabled": true,
    "profile": "aggressive",
    "maxContextWindow": 128000,
    "safetyMargin": 15000,
    "effectiveWindow": 113000,
    "compressionRatio": 0.85,
    "aggressiveMode": {
      "enabled": true,
      "targetUtilization": "85%",
      "autoCompactThreshold": 12000,
      "preservePatterns": ["FIXME", "TODO", "BUG", "DECISION", "RESULT"]
    },
    "rules": {
      "promptChars": {
        "yellowThreshold": 1100,
        "redThreshold": 1600,
        "unit": "characters",
        "action": "AUTO_COMPACT"
      },
      "adoptionPercent": {
        "yellowThreshold": 75,
        "redThreshold": 50,
        "unit": "percentage",
        "action": "WARN_AND_COMPRESS"
      },
      "windowDays": 7,
      "enforceOnStartup": true
    },
    "monitoring": {
      "trackTokenUsage": true,
      "logFile": "logs/cline-token-usage.log",
      "reportingInterval": "session-end",
      "alertThresholds": {
        "yellowAt": 1100,
        "redAt": 1600
      }
    }
  },
  "contextManagement": {
    "strategy": "tiered-with-compression",
    "memoryTiering": {
      "hot": {
        "duration": "active session",
        "compression": "none",
        "retention": "100%",
        "maxAge": "current"
      },
      "warm": {
        "duration": "1 day",
        "compression": "light",
        "retention": "90%",
        "compressionMethod": "summarization"
      },
      "cold": {
        "duration": "7 days",
        "compression": "aggressive",
        "retention": "70%",
        "compressionMethod": "reference-only"
      },
      "archive": {
        "duration": "30+ days",
        "compression": "extreme",
        "retention": "40%",
        "compressionMethod": "index-only"
      }
    },
    "preCompactHook": {
      "enabled": true,
      "triggerAt": 12000,
      "script": "scripts/utilities/pre-compact-hook.ps1",
      "preservePatterns": ["FIXME", "TODO", "BUG", "DECISION", "RESULT"],
      "compressionRatio": 0.85,
      "autoRun": true,
      "reportResults": true
    },
    "handoffCompression": {
      "enabled": true,
      "script": "scripts/utilities/handoff-compress.ps1",
      "preserves": ["decisions", "results", "FIXMEs", "status flags", "critical context"],
      "truncates": ["verbose outputs", "repeated patterns", "debug logs", "intermediate steps"],
      "expectedReduction": "30-40%",
      "autoApply": true
    },
    "contextInjection": {
      "includeProjectStructure": true,
      "projectStructureDepth": 2,
      "includeActiveSkills": true,
      "includeCustomRules": true,
      "includeSessionContext": true,
      "excludePatterns": ["node_modules", ".git", "dist", "build", ".next"],
      "maxStructureSize": 2000
    },
    "redundancyDetection": {
      "enabled": true,
      "removeRepeatedContent": true,
      "useReferencesInstead": true,
      "minDuplicationThreshold": 100
    }
  },
  "sessionManagement": {
    "autostart": {
      "enabled": true,
      "script": "scripts/utilities/session-autostart.cmd",
      "configFile": "scripts/utilities/session-autostart.config.json",
      "runOnPluginLoad": true
    },
    "tracking": {
      "project": "workspace_gentle_vanguard",
      "directory": "c:\\Workspace_local",
      "sessionIdPattern": "session-YYYY-MM-DD-XX",
      "autoInitialize": true,
      "persistMetadata": true
    },
    "reliability": {
      "treatReadyAsPass": true,
      "treatPartialAsActionable": true,
      "useFullModeForCritical": true,
      "autoRecoveryOnError": true
    },
    "contextEfficiency": {
      "targetPercentage": 70,
      "autoCompactionThreshold": 12000,
      "reduceRedundancy": true,
      "referenceInsteadOfRepeat": true,
      "forceCompactOnStartup": true,
      "compactOnSessionEnd": true
    }
  },
  "skillLoading": {
    "adaptive": true,
    "autoLoad": true,
    "triggers": {
      "angular": ["angular-core", "angular-spa"],
      "react": ["react-19"],
      "go": ["golang-api"],
      "docker": ["docker-devops"],
      "powershell": ["script-governance-skill"],
      "session": ["session-workflow-skill"],
      "typescript": ["typescript-skill"],
      "nextjs": ["nextjs-15-skill"],
      "testing": ["testing-skill"],
      "security": ["security-expert-skill"]
    },
    "governanceLayers": {
      "GOV": ["project-orchestrator-skill"],
      "SAD": ["sdd-lifecycle"],
      "DEV": ["sdd-lifecycle"],
      "QA": ["sdd-lifecycle"],
      "OPS": ["docker-devops-skill"],
      "DOC": ["documentation-governance"],
      "SCRIPT-GOV": ["sdd-lifecycle"],
      "REPORT": ["management-reporting-skill"]
    },
    "gitflowCapabilities": {
      "branch": ["create-gitflow-branch.ps1"],
      "pr": ["create-pull-request.ps1"],
      "hooks": ["pre-commit-validation.ps1"],
      "merge": ["post-merge-sync.ps1"],
      "workflow": ["git-workflow-skill"],
      "commit": ["git-workflow-skill"],
      "conflict": ["git-workflow-skill"]
    },
    "rulesPath": "rules/adaptive/",
    "cacheSkills": true,
    "cacheDuration": 7200,
    "maxSkillsPerSession": 5,
    "prioritizeByFrequency": true
  },
  "customRules": {
    "enabled": true,
    "loadOrder": ["technical", "business", "review"],
    "paths": {
      "technical": "rules/custom/technical/",
      "business": "rules/custom/business/",
      "review": "rules/custom/review/"
    },
    "ruleIdPrefixes": {
      "technical": "TECH-",
      "business": "BIZ-",
      "review": "REV-"
    },
    "autoLoad": true,
    "validateOnLoad": true
  },
  "promptEngineering": {
    "systemPromptTemplate": "templates/cline-system-prompt.md",
    "contextInjection": {
      "includeProjectStructure": true,
      "includeActiveSkills": true,
      "includeCustomRules": true,
      "includeSessionContext": true,
      "maxContextSize": 8000
    },
    "responseFormat": {
      "enforceStructure": true,
      "maxResponseTokens": 2000,
      "requireSummary": true,
      "requireActionItems": false,
      "compressResponses": true
    },
    "languagePreference": "es",
    "toneGuidance": "technical, direct, concise, match OpenCode: <4 lines",
    "localFirst": {
      "enabled": true,
      "denyWebSearch": true,
      "denyCodeSearch": true,
      "denyWebFetch": true,
      "orchestratorOverride": true,
      "note": "External tools only available via orchestrator agent"
    }
  },
  "monitoring": {
    "tokenUsageTracking": true,
    "logFile": "logs/cline-token-usage.log",
    "detailedLogging": false,
    "alertThresholds": {
      "yellowAt": 1100,
      "redAt": 1600
    },
    "reportingInterval": "session-end",
    "metricsCollection": {
      "enabled": true,
      "trackCompressionRatio": true,
      "trackSkillUsage": true,
      "trackContextSize": true
    },
    "healthCheck": {
      "enabled": true,
      "interval": 300000,
      "reportFile": "logs/cline-health-check.log"
    }
  },
  "integrations": {
    "vscodeSettings": ".vscode/settings.json",
    "gitHooks": "hooks/",
    "workspaceConfig": "config/workspace.config.json",
    "contextEfficiencyConfig": "config/context-efficiency.json",
    "agentsConfig": "AGENTS.md",
    "structurePolicyConfig": "config/structure-policy.json"
  },
  "performanceTuning": {
    "cacheResponses": true,
    "cacheDuration": 7200,
    "batchRequests": true,
    "maxBatchSize": 5,
    "requestTimeout": 30000,
    "connectionPooling": true,
    "maxConnections": 10,
    "enableCompression": true,
    "compressionLevel": "high"
  },
  "difySpecificOptimizations": {
    "enabled": true,
    "apiVersion": "v1",
    "streamResponses": true,
    "useWebsocketWhenAvailable": false,
    "batchApiCalls": true,
    "rateLimitHandling": {
      "enabled": true,
      "maxRequestsPerMinute": 60,
      "backoffStrategy": "exponential"
    },
    "errorHandling": {
      "retryOnTimeout": true,
      "retryOnRateLimit": true,
      "maxRetries": 3
    }
  },
  "contextCompressionStrategies": {
    "enabled": true,
    "strategies": [
      {
        "name": "token-count-reduction",
        "enabled": true,
        "targetReduction": "25%",
        "method": "summarization"
      },
      {
        "name": "redundancy-elimination",
        "enabled": true,
        "targetReduction": "15%",
        "method": "deduplication"
      },
      {
        "name": "reference-consolidation",
        "enabled": true,
        "targetReduction": "10%",
        "method": "reference-only"
      }
    ],
    "totalTargetReduction": "40-50%"
  },
  "advancedFeatures": {
    "contextAwareness": {
      "enabled": true,
      "detectProjectType": true,
      "autoLoadRelevantSkills": true
    },
    "intelligentCaching": {
      "enabled": true,
      "cacheFrequentPatterns": true,
      "cacheProjectStructure": true,
      "cacheDuration": 7200
    },
    "adaptiveCompression": {
      "enabled": true,
      "adjustCompressionBasedOnTokenUsage": true,
      "minCompressionRatio": 0.75,
      "maxCompressionRatio": 0.95
    },
    "sessionContinuity": {
      "enabled": true,
      "preserveContextBetweenSessions": true,
      "autoRestoreOnReconnect": true
    }
  },
  "qualityAssurance": {
    "validateConfiguration": true,
    "checkDependencies": true,
    "verifyScriptPaths": true,
    "testConnectivity": true,
    "reportIssues": true
  },
  "localFirstPolicy": {
    "enabled": true,
    "toolRestrictions": {
      "websearch": "deny",
      "codesearch": "deny",
      "webfetch": "deny"
    },
    "preferredSources": ["local-skills", "engram-memory", "project-docs", "cached-responses"],
    "externalToolsOrchestratorOnly": true,
    "bypassConditions": ["user-explicit-request", "local-knowledge-insufficient"]
  }
}
