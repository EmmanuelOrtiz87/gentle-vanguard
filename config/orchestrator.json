{
  "orchestrator": {
    "version": "2.5.0",
    "preProcessing": {
      "enabled": true,
      "mandatory": true,
      "script": "tools/pre-process-input.ps1",
      "scriptArgs": {
        "UserInput": "USER_INPUT_HERE",
        "WorkspaceRoot": "."
      },
      "fallbackBehavior": "continue",
      "fallbackStrategy": "clarify-ba",
      "parseOutput": {
        "triggerFound": "TRIGGER_MATCH_FOUND",
        "planMode": "PLAN_MODE_REQUIRED",
        "noMatch": "NO_TRIGGER_MATCH"
      },
      "toolsSupported": [
        "opencode",
        "cline",
        "cursor",
        "windsurf",
        "continue_dev",
        "claude",
        "copilot",
        "antigravity"
      ]
    },
    "triggerDetection": {
      "enabled": true,
      "sources": [
        "config/auto-delegation.json",
        "skills/*/SKILL.md"
      ],
      "matchMode": "wordBoundary",
      "partialMatch": {
        "enabled": true,
        "threshold": 0.5
      }
    },
    "sessionStartup": {
      "enabled": true,
      "mandatory": true,
      "script": "tools/session-autostart.cmd",
      "platform": "windows",
      "alternatives": {
        "linux": "bash ./tools/session-autostart.sh",
        "macos": "bash ./tools/session-autostart.sh"
      }
    },
    "skillLoading": {
      "autoLoad": true,
      "tool": "skill",
      "fallbackToManual": false
    },
    "logging": {
      "enabled": true,
      "level": "info",
      "file": ".logs/orchestrator-preprocess.log"
    }
  }
}
