#!/bin/sh
# Standard Git hook for cross-platform pre-commit validation.

VALIDATE_SCRIPT="./scripts/validation/validate-project.ps1"

if [ -f "$VALIDATE_SCRIPT" ]; then
    echo ">> [Hook] Running pre-commit validation..."
    if command -v pwsh >/dev/null 2>&1; then
        pwsh -File "$VALIDATE_SCRIPT"
    else
        powershell -NoProfile -ExecutionPolicy Bypass -File "$VALIDATE_SCRIPT"
    fi
    exit $?
fi

exit 0