# Code Owners
# https://help.github.com/en/github/creating-cloning-and-archiving-repositories/about-code-owners
#
# Any file not covered by a specific rule falls to the default owner.
# Rules are evaluated from bottom to top — last matching rule wins.

# Default owner for everything
* @platform-team

# Core automation scripts — require platform-team review
/scripts/ @platform-team
/scripts/utilities/ @platform-team
/scripts/diagnostics/ @platform-team

# Governance validator — extra visibility (notify both teams)
/scripts/diagnostics/validate-script-governance.ps1 @platform-team @devops-team

# Script registry — single source of truth, changes need careful review
/docs/reference/script-registry.md @platform-team @devops-team

# CI/CD workflows — devops owns, platform-team co-reviews
/.github/workflows/ @devops-team @platform-team
/.github/CODEOWNERS @platform-team

# Skills / AI prompting layer
/skills/ @platform-team

# Templates
/templates/ @platform-team
/templates/project-types/ @platform-team

# Configuration
/config/ @platform-team

# Documentation
/docs/ @docs-team @platform-team
*.md @docs-team

