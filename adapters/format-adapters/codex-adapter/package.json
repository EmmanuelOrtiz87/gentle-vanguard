{
  "name": "codex-adapter",
  "version": "1.0.0",
  "description": "Converts Foundation skills to OpenAI Codex function calling format",
  "main": "adapter.js",
  "scripts": {
    "convert-skill": "node adapter.js convert-skill",
    "generate-tools": "node adapter.js generate-tools",
    "generate-proxy": "node adapter.js generate-proxy"
  },
  "keywords": [
    "foundation",
    "codex",
    "openai",
    "function-calling",
    "adapter"
  ],
  "dependencies": {
    "fs": "built-in",
    "path": "built-in"
  },
  "foundation": {
    "adapterType": "format-adapter",
    "targetTool": "codex",
    "targetFormat": "openai-function-calling",
    "compatibility": [
      "OpenAI Codex",
      "OpenAI API"
    ]
  }
}
