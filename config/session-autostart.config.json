{
  "version": "1.0.0",
  "name": "session-autostart-config",
  "description": "Configuration for session autostart pipeline - controls which steps run and their parameters",

  "pipeline": {
    "steps": [
      {
        "id": "tool-detection",
        "enabled": true,
        "script": "scripts/utilities/detect-tool.ps1",
        "args": "-AsJson",
        "required": false,
        "description": "Detect AI tool/agent and load tool-specific configuration"
      },
      {
        "id": "session-manager",
        "enabled": true,
        "script": "scripts/utilities/session-manager.ps1",
        "args": "-Mode AutoStart",
        "required": true,
        "description": "Initialize session ID and create session file"
      },
      {
        "id": "github-bypass",
        "enabled": true,
        "script": "scripts/utilities/SESSION-MANAGEMENT/ensure-github-bypass.ps1",
        "args": "",
        "required": false,
        "description": "Ensure GitHub bypass policy for current user"
      },
      {
        "id": "notifications",
        "enabled": true,
        "script": "scripts/utilities/session-notification.ps1",
        "args": "-TimeZone \"Argentina Standard Time\" -PeakStart 9 -PeakEnd 15 -Region \"Argentina\"",
        "required": false,
        "description": "Time-based peak hour notifications"
      },
      {
        "id": "auth-session",
        "enabled": false,
        "script": "scripts/utilities/auth-session.ps1",
        "args": "",
        "required": false,
        "description": "Authenticate owner for restricted operations (requires manual trigger with -ApiKey or -UseSecurityQuestions)",
        "note": "Disabled by default - auth is demand-driven, not at session start. Enable if session-level auth is required."
      },
      {
        "id": "engram-policy",
        "enabled": true,
        "script": "scripts/foundation/engram-policy.ps1",
        "args": "-Action enforce",
        "required": true,
        "description": "Verify Engram is installed and running"
      },
      {
        "id": "token-budget",
        "enabled": true,
        "script": "scripts/utilities/TELEMETRY-METRICS/token-budget-guard.ps1",
        "args": "-Task session-start -Risk low -Record -ActualPromptTokens 0 -ActualCompletionTokens 0",
        "required": false,
        "description": "Record session start for token budget tracking"
      },
      {
        "id": "engram-optimization",
        "enabled": true,
        "script": "scripts/utilities/optimize-engram-usage.ps1",
        "args": "-ProjectName workspace_local",
        "required": false,
        "description": "Optimize Engram memory usage"
      },
      {
        "id": "cross-workspace-validation",
        "enabled": true,
        "script": "scripts/monitoring/cross-workspace-validator.ps1",
        "args": "-Detailed",
        "required": false,
        "description": "Validate cross-workspace consistency"
      },
      {
        "id": "security-orchestrator",
        "enabled": true,
        "script": "scripts/utilities/security-orchestrator.ps1",
        "args": "-Action init -AsJson",
        "required": true,
        "description": "Initialize Security Orchestrator with policy and privacy configs"
      },
      {
        "id": "skill-router",
        "enabled": true,
        "script": "scripts/utilities/skill-router.ps1",
        "args": "-Query \"session-start\"",
        "required": false,
        "description": "Verify skill router is active"
      },
      {
        "id": "karpathy-guidelines",
        "enabled": true,
        "script": "scripts/utilities/karpathy-enforcer.ps1",
        "args": "-Trigger session-start -VerboseOutput",
        "required": false,
        "description": "Enforce Karpathy guidelines (Think, Simplicity, Surgical, Goal-Driven)"
      }
    ],

    "onStepFailure": "continue",
    "requiredStepFailureAction": "exit"
  },

  "notifications": {
    "timeZone": "Argentina Standard Time",
    "peakStart": 9,
    "peakEnd": 15,
    "region": "Argentina"
  },

  "sessionDirectory": ".session",
  "sessionFilePattern": "session-{date}-{number:D2}.json",
  "sessionExpiryHours": 8,

  "auth": {
    "integrateWithAutostart": false,
    "requireAuthForRestrictedOps": true,
    "sessionAuthFile": ".workspace/config/session-auth.json",
    "ownerAuthFile": "config/owner-auth.json",
    "lockoutFile": "config/owner-auth.json.lock",
    "encryptedAuthFile": "config/owner-auth.json.enc"
  },

  "orphanSessionCleanup": {
    "enabled": true,
    "maxAgeHours": 24,
    "statusesToClean": ["active"],
    "description": "Clean up sessions left in 'active' status after maxAgeHours (crash recovery)"
  }
}