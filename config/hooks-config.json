{
  "$schema": "hooks-config.schema.json",
  "description": "Hooks configuration for Foundation workflow - defines pre/post processing hooks",
  "version": "1.0.0",
  "hooks": {
    "pre_process": {
      "enabled": true,
      "mandatory": true,
      "description": "MANDATORY pre-processing hook - runs BEFORE any AI response to validate input and load skills",
      "script": "scripts/utilities/WORKFLOW-ORCHESTRATION/pre-process-input.ps1",
      "timeout": 30000,
      "args": {
        "UserInput": "${user_input}",
        "WorkspaceRoot": ".",
        "SkillRegistry": "config/skill-registry.json"
      },
      "parseOutput": {
        "triggerFound": "TRIGGER_MATCH_FOUND",
        "noMatch": "NO_TRIGGER_MATCH",
        "skillLoaded": "SKILL_LOADED"
      },
      "actions": {
        "onMatch": "Load skill using skill tool",
        "onNoMatch": "Continue with normal behavior",
        "onError": "Log error and continue"
      },
      "errorHandling": "continue"
    },
    "post_session": {
      "enabled": true,
      "description": "Runs after session ends - generates management report and captures Engram memory",
      "script": "scripts/utilities/TELEMETRY-METRICS/generate-management-report.ps1",
      "timeout": 60000,
      "args": {
        "SessionId": "${session_id}",
        "WorkspaceRoot": ".",
        "OutputDir": ".session/reports"
      },
      "parseOutput": {
        "reportGenerated": "REPORT_GENERATED",
        "success": "SUCCESS"
      },
      "actions": {
        "onSuccess": "Archive report to Engram",
        "onError": "Log error but don't fail session"
      },
      "errorHandling": "log_only"
    },
    "pre_commit": {
      "enabled": true,
      "description": "Runs before git commit - validates code quality and security",
      "script": "scripts/utilities/GIT-VERSION-CONTROL/pre-commit-validation.ps1",
      "timeout": 45000,
      "args": {
        "StagedFiles": "${staged_files}",
        "WorkspaceRoot": "."
      },
      "parseOutput": {
        "passed": "VALIDATION_PASSED",
        "failed": "VALIDATION_FAILED"
      },
      "actions": {
        "onPass": "Allow commit to proceed",
        "onFail": "Block commit and show errors"
      },
      "errorHandling": "fail"
    },
    "post_merge": {
      "enabled": true,
      "description": "Runs after merge completes - updates documentation and validates consistency",
      "script": "scripts/utilities/GIT-VERSION-CONTROL/post-merge-sync.ps1",
      "timeout": 60000,
      "args": {
        "MergeBranch": "${merge_branch}",
        "WorkspaceRoot": "."
      },
      "parseOutput": {
        "synced": "SYNC_COMPLETE",
        "issues": "ISSUES_FOUND"
      },
      "actions": {
        "onSync": "Update references and documentation",
        "onIssues": "Log issues for manual review"
      },
      "errorHandling": "log_only"
    }
  },
  "hookRegistry": {
    "description": "Central registry of all available hooks and their lifecycle",
    "location": "scripts/utilities/WORKFLOW-ORCHESTRATION/hook-registry.json",
    "autoDiscovery": true,
    "validateOnLoad": true
  },
  "execution": {
    "parallel": false,
    "timeout": 300000,
    "retryOnFailure": true,
    "maxRetries": 2,
    "logLevel": "info"
  }
}