{
  "orchestrator": {
    "version": "2.6.0",
    "preProcessing": {
      "enabled": true,
      "mandatory": true,
      "script": "scripts/utilities/pre-process-input.ps1",
      "scriptArgs": {
        "UserInput": "USER_INPUT_HERE",
        "WorkspaceRoot": "."
      },
      "fallbackBehavior": "continue",
      "fallbackStrategy": "clarify-ba",
      "parseOutput": {
        "triggerFound": "TRIGGER_MATCH_FOUND",
        "planMode": "PLAN_MODE_REQUIRED",
        "noMatch": "NO_TRIGGER_MATCH"
      },
      "toolsSupported": [
        "opencode",
        "cline",
        "cursor",
        "windsurf",
        "continue_dev",
        "claude",
        "copilot",
        "antigravity"
      ]
    },
    "triggerDetection": {
      "enabled": true,
      "sources": [
        "config/auto-delegation.json",
        "skills/*/SKILL.md"
      ],
      "matchMode": "wordBoundary",
      "partialMatch": {
        "enabled": true,
        "threshold": 0.5
      }
    },
    "sessionStartup": {
      "enabled": true,
      "mandatory": true,
      "script": "scripts/utilities/session-autostart.cmd",
      "platform": "windows",
      "alternatives": {
        "linux": "bash ./tools/session-autostart.sh",
        "macos": "bash ./tools/session-autostart.sh"
      }
    },
    "skillLoading": {
      "autoLoad": true,
      "tool": "skill",
      "fallbackToManual": false
    },
    "logging": {
      "enabled": true,
      "level": "info",
      "file": ".logs/orchestrator-preprocess.log"
    }
  },
  "communication_language": "es",
  "allowed_languages": [
    "es",
    "pt-BR",
    "en"
  ],
  "communication_response_mode": "simple",
  "allowed_response_modes": [
    "simple",
    "executive",
    "expanded"
  ],
  "chat_response": {
    "default_level": "chat-compact",
    "enforce_on_session_start": true,
    "allow": [
      "chat-compact",
      "chat-balanced",
      "chat-detailed"
    ],
    "decision": {
      "kind": "architecture",
      "title": "startup-chat-baseline",
      "rationale": "Initialize sessions with minimal chat verbosity for token efficiency and closure-first operation."
    }
  },
  "communication_presets": {
    "default": "bugfix",
    "allow": [
      "bugfix",
      "refactor",
      "docs",
      "audit-review",
      "executive-demo"
    ],
    "profiles": {
      "bugfix": {
        "language": "es",
        "detail": "simple",
        "compression": "ultra"
      },
      "refactor": {
        "language": "es",
        "detail": "simple",
        "compression": "ultra"
      },
      "docs": {
        "language": "es",
        "detail": "simple",
        "compression": "ultra"
      },
      "audit-review": {
        "language": "es",
        "detail": "simple",
        "compression": "ultra"
      },
      "executive-demo": {
        "language": "es",
        "detail": "simple",
        "compression": "ultra"
      }
    }
  },
  "response_profiles": {
    "active": "ultra",
    "allow": [
      "lite",
      "lleno",
      "ultra"
    ],
    "profiles": {
      "lite": {
        "description": "Professional concise language with complete sentences; no filler.",
        "guidelines": [
          "No digressions.",
          "Keep complete sentences.",
          "Focus on actionable output."
        ]
      },
      "lleno": {
        "description": "Compressed language with short fragments accepted.",
        "guidelines": [
          "Prefer short clauses.",
          "Drop non-essential connectors.",
          "Keep meaning explicit."
        ]
      },
      "ultra": {
        "description": "Aggressive compression with abbreviations and causal arrows.",
        "guidelines": [
          "Use compact abbreviations (db/auth/config/req/res/fn/impl).",
          "Prefer X -> Y causal notation.",
          "One-word answers when enough."
        ]
      }
    }
  },
  "response_policy": {
    "strict_mode": true,
    "enforce_baseline": true,
    "baseline_detail": "simple",
    "baseline_profile": "ultra",
    "baseline_chat_level": "chat-compact",
    "allow_overrides": false,
    "require_override_reason": true
  },
  "subagent_orchestration": {
    "token_budget_guard": {
      "enabled": true,
      "unit": "tokens",
      "estimation": {
        "method": "chars_div_4",
        "chars_per_token": 4,
        "note": "Canonical unit: tokens. chars/4 = estimated tokens. Use this formula across all scripts."
      },
      "daily_budget_tokens": 30000,
      "soft_threshold_pct": 70,
      "hard_threshold_pct": 90,
      "per_agent_budget_tokens": 750,
      "coordination_overhead_tokens": 125,
      "alert_levels": {
        "soft": "WARN — log and continue",
        "hard": "BLOCK — refuse dispatch until reset or override"
      },
      "legacy_script": "scripts/utilities/token-guard.ps1",
      "operational_script": "scripts/utilities/TELEMETRY-METRICS/token-budget-guard.ps1",
      "metrics_path": "docs/sessions/metrics/token-guard-usage.csv"
    }
  },
  "governed_override_profiles": {
    "_comment": "Controlled overrides for response_policy. Each profile requires a reason and is audit-logged.",
    "allow_governed_overrides": true,
    "require_reason": true,
    "audit_log": ".logs/override-audit.jsonl",
    "abuse_detection": {
      "enabled": true,
      "window_hours": 24,
      "warn_total_overrides": 4,
      "warn_per_agent": 3,
      "warn_per_profile": 3
    },
    "profiles": {
      "verbose-debug": {
        "baseline_detail": "expanded",
        "baseline_profile": "lleno",
        "baseline_chat_level": "chat-detailed",
        "allowed_for_agents": ["BA", "DOC"],
        "max_duration_turns": 5,
        "rationale": "Temporary verbose mode for complex exploratory or documentation tasks"
      },
      "executive-review": {
        "baseline_detail": "expanded",
        "baseline_profile": "lite",
        "baseline_chat_level": "chat-balanced",
        "allowed_for_agents": ["GOV", "DOC"],
        "max_duration_turns": 3,
        "rationale": "Used for executive-facing reports where full prose is required"
      }
    }
  }
}
