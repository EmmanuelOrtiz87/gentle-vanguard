  },
  "tools": [
    {
      "name": "engram",
      "checkCommand": "engram",
      "install": {
        "windows": "Write-Host 'Configure the engram release or clone source here for Windows.'",
        "linux": "Write-Host 'Configure the engram release or clone source here for Linux.'",
        "macos": "Write-Host 'Configure the engram release or clone source here for macOS.'"
      }
    },
  ]
