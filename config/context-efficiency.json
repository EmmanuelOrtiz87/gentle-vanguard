{
  "activeProfile": "optimized",
  "profiles": {
    "default": {
      "windowDays": 7,
      "promptChars": { "yellowMax": 1200, "redMax": 1800 },
      "adoptionPercent": { "yellowMin": 70, "redMin": 40 }
    },
    "recommended": {
      "windowDays": 7,
      "promptChars": { "yellowMax": 1100, "redMax": 1600 },
      "adoptionPercent": { "yellowMin": 75, "redMin": 50 }
    },
    "optimized": {
      "windowDays": 7,
      "promptChars": { "yellowMax": 800, "redMax": 1200 },
      "adoptionPercent": { "yellowMin": 85, "redMin": 65 },
      "note": "Tighter thresholds after CLAUDE.md/AGENTS.md compression — system prompt reduced ~50%"
    }
  },
  "liveAssist": {
    "enabled": true,
    "showOnCommands": [
      "status",
      "health",
      "start-session",
      "end-session",
      "day-end-closure",
      "review",
      "audit",
      "publish"
    ],
    "autoRunOnStartSessionWhenRed": true
  },
  "compactionPolicy": {
    "enabled": true,
    "slidingWindowTurns": 10,
    "pruneToolResults": true,
    "summarizeOlderTurns": false,
    "inputTokenBudgetPct": 80,
    "note": "Syncs with opencode.json compaction config. slidingWindowTurns must match maxTurns."
  },
  "tokenAutopilot": {
    "enabled": true,
    "profile": "hard",
    "triggerStatuses": ["WARN", "HARD_LIMIT"],
    "minConsecutiveAlerts": 1,
    "autoApplyOnCommands": [
      "context-pack",
      "compact-start",
      "audit",
      "publish",
      "end-session",
      "dispatch"
    ],
    "applyChatLevel": "chat-compact",
    "stateFile": ".session/token-autopilot-state.json",
    "inputGuard": {
      "enabled": true,
      "softThresholdPct": 70,
      "hardThresholdPct": 90,
      "note": "Input token guard — warns when conversation history exceeds % of model context window"
    },
    "manualAliases": {
      "economy": ["ahorro", "modo-ahorro", "ahorro-on", "economy", "token-save"],
      "balanced": ["normal", "balanceado", "modo-normal", "ahorro-off"],
      "detailed": ["detallado", "detalle", "full", "verbose"]
    }
  }
}
