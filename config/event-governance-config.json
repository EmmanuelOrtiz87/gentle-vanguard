{
  "version": "1.0",
  "description": "Event Governance Configuration - Security policies, rate limiting, and audit settings",
  "created": "2026-04-23",
  "governance": {
    "security": {
      "enabled": true,
      "policies": {
        "unauthorized_emit": {
          "description": "Prevent unauthorized event emission",
          "action": "block",
          "alert": true,
          "severity": "high"
        },
        "unauthorized_listen": {
          "description": "Prevent unauthorized event listening",
          "action": "block",
          "alert": true,
          "severity": "high"
        },
        "schema_validation": {
          "description": "Validate event payload against schema",
          "action": "block",
          "alert": false,
          "severity": "medium"
        },
        "size_limit": {
          "description": "Enforce maximum event size",
          "action": "block",
          "alert": true,
          "severity": "medium",
          "max_bytes": 10240
        }
      }
    },
    "rate_limiting": {
      "enabled": true,
      "strategy": "sliding_window",
      "window_size_seconds": 60,
      "enforcement": {
        "soft_limit": {
          "action": "warn",
          "threshold_percent": 80
        },
        "hard_limit": {
          "action": "block",
          "threshold_percent": 100
        }
      },
      "per_event_overrides": {
        "dispatch.started": {
          "max_per_minute": 10,
          "max_per_hour": 100
        },
        "dispatch.completed": {
          "max_per_minute": 10,
          "max_per_hour": 100
        },
        "agent.dispatched": {
          "max_per_minute": 50,
          "max_per_hour": 500
        },
        "agent.completed": {
          "max_per_minute": 50,
          "max_per_hour": 500
        },
        "session.started": {
          "max_per_minute": 5,
          "max_per_hour": 50
        },
        "session.ended": {
          "max_per_minute": 5,
          "max_per_hour": 50
        },
        "security.violation": {
          "max_per_minute": 100,
          "max_per_hour": 1000
        },
        "audit.event": {
          "max_per_minute": 1000,
          "max_per_hour": 10000
        }
      }
    },
    "audit": {
      "enabled": true,
      "log_level": "detailed",
      "capture": {
        "all_emissions": true,
        "all_subscriptions": true,
        "all_violations": true,
        "policy_decisions": true
      },
      "retention": {
        "days": 30,
        "max_entries": 300000
      },
      "storage": {
        "type": "json",
        "location": ".event-bus/audit",
        "rotation": "daily"
      }
    },
    "alerts": {
      "enabled": true,
      "channels": ["log", "event"],
      "severity_levels": {
        "critical": {
          "notify": true,
          "escalate": true
        },
        "high": {
          "notify": true,
          "escalate": false
        },
        "medium": {
          "notify": false,
          "escalate": false
        },
        "low": {
          "notify": false,
          "escalate": false
        }
      }
    },
    "monitoring": {
      "enabled": true,
      "metrics": {
        "event_count": true,
        "event_latency": true,
        "error_rate": true,
        "rate_limit_violations": true,
        "security_violations": true
      },
      "collection_interval_seconds": 60,
      "storage": {
        "type": "json",
        "location": ".event-bus/metrics"
      }
    }
  },
  "compliance": {
    "require_audit_trail": true,
    "require_schema_validation": true,
    "require_permission_check": true,
    "immutable_audit_logs": true,
    "audit_log_encryption": false,
    "data_retention_policy": "strict"
  },
  "orchestrator_integration": {
    "enabled": true,
    "supervision_mode": "passive",
    "auto_remediation": false,
    "escalation_threshold": "high",
    "notify_on_violations": true,
    "allow_orchestrator_override": false
  }
}