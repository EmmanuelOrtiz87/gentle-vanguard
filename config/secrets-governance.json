{
  "$schema": "config/secrets-governance.json",
  "version": "1.0.0",
  "lastUpdated": "2026-05-15T16:00:00Z",
  "title": "Secrets Governance & Management Policy",
  "description": "Enterprise-grade secrets management with compliance, rotation, audit, and enforcement",

  "classification": {
    "categories": [
      {
        "id": "api-keys",
        "name": "API Keys",
        "riskLevel": "CRITICAL",
        "rotationFrequency": "90 days",
        "encryptionRequired": true,
        "auditLevel": "full",
        "description": "Third-party API credentials, provider tokens"
      },
      {
        "id": "database-credentials",
        "name": "Database Credentials",
        "riskLevel": "CRITICAL",
        "rotationFrequency": "120 days",
        "encryptionRequired": true,
        "auditLevel": "full",
        "description": "DB passwords, connection strings, roles"
      },
      {
        "id": "signing-keys",
        "name": "Cryptographic Signing Keys",
        "riskLevel": "CRITICAL",
        "rotationFrequency": "1 year",
        "encryptionRequired": true,
        "auditLevel": "full",
        "description": "JWT keys, code signing certs, encryption master keys"
      },
      {
        "id": "oauth-tokens",
        "name": "OAuth/JWT Tokens",
        "riskLevel": "HIGH",
        "rotationFrequency": "30 days",
        "encryptionRequired": true,
        "auditLevel": "full",
        "description": "GitHub tokens, cloud provider tokens, SSO tokens"
      },
      {
        "id": "service-accounts",
        "name": "Service Account Credentials",
        "riskLevel": "HIGH",
        "rotationFrequency": "60 days",
        "encryptionRequired": true,
        "auditLevel": "full",
        "description": "Automation account passwords, CI/CD service account tokens"
      },
      {
        "id": "tls-certificates",
        "name": "TLS/SSL Certificates",
        "riskLevel": "HIGH",
        "rotationFrequency": "every 89 days",
        "encryptionRequired": true,
        "auditLevel": "full",
        "description": "SSL/TLS certs, client certs, mutual TLS credentials"
      },
      {
        "id": "mfa-seeds",
        "name": "MFA Seeds & Backup Codes",
        "riskLevel": "CRITICAL",
        "rotationFrequency": "on regeneration",
        "encryptionRequired": true,
        "auditLevel": "full",
        "description": "TOTP seeds, U2F backup keys, recovery codes"
      },
      {
        "id": "encryption-keys",
        "name": "Data Encryption Keys",
        "riskLevel": "CRITICAL",
        "rotationFrequency": "90 days",
        "encryptionRequired": true,
        "auditLevel": "full",
        "keyManagement": "HSM recommended",
        "description": "AES keys, DEKs (Data Encryption Keys), KEK (Key Encryption Keys)"
      }
    ]
  },

  "storage": {
    "policy": "Never commit secrets to Git or configuration files",
    "authorizedVaults": [
      {
        "name": "Local Vault",
        "type": "file-based",
        "path": "$HOME/.gentle-vanguard/vault/",
        "encryption": "AES-256-GCM",
        "accessControl": "RBAC",
        "backupFrequency": "daily",
        "redundancy": "local+encrypted"
      },
      {
        "name": "Environment Variables",
        "type": "process-memory",
        "scope": "current-session-only",
        "encryption": "inherited from parent process",
        "accessControl": "process-level isolation",
        "description": "Temporary secrets during execution, cleared on process exit"
      },
      {
        "name": "Key Management Service (KMS)",
        "type": "cloud-hsm",
        "providers": ["Azure Key Vault", "AWS KMS", "HashiCorp Vault"],
        "encryption": "HSM-backed",
        "accessControl": "IAM + MFA",
        "auditLogging": "all operations logged",
        "recommended": true
      },
      {
        "name": "CI/CD Secrets Manager",
        "type": "platform-specific",
        "examples": ["GitHub Secrets", "GitLab CI/CD variables", "Jenkins Credentials"],
        "encryption": "platform-managed AES-256",
        "accessControl": "role-based per repository",
        "rotationAutomated": true
      }
    ],
    "forbidden": [
      "Hardcoded in code or configs",
      "Environment variable exports in shell history",
      "Git repository (even deleted commits)",
      "Unencrypted log files",
      "Version control systems",
      "Shared document repositories"
    ]
  },

  "lifecycle": {
    "provisioning": {
      "process": "On-demand or automated",
      "approvalRequired": true,
      "approvers": ["security-owner", "service-owner"],
      "auditLog": "WHO requested, WHY, WHEN, approval timestamp"
    },
    "distribution": {
      "method": "Pull-based (agent retrieves via API), never push",
      "encryptionInTransit": "TLS 1.3 minimum",
      "timeout": "5 minutes max (secrets expire after retrieval window)",
      "logging": "Log WHO retrieved WHAT secret, WHEN, FROM WHERE"
    },
    "usage": {
      "principle": "Least privilege + Just-in-Time (JIT) access",
      "sessionTimeout": "60 minutes idle → automatic revocation",
      "auditTrail": "Every usage logged: WHO, WHAT, WHEN, RESULT",
      "anomalyDetection": "Alert if same secret retrieved >10 times in 1 hour"
    },
    "rotation": {
      "automated": true,
      "schedule": "Per category rotation frequency (see classification above)",
      "process": "(1) Generate new secret, (2) Test with new value, (3) Update in vault, (4) Update in app, (5) Verify app functioning, (6) Destroy old secret",
      "zeroDowntime": true,
      "failsafe": "If rotation fails, rollback to previous secret + alert security team"
    },
    "deprovisioning": {
      "trigger": "Employee departure, application retirement, breach response",
      "timeline": "Revoke immediately (within 5 minutes)",
      "verification": "Confirm revocation in audit log",
      "auditLog": "WHO revoked, WHY, WHEN, confirmation of removal"
    }
  },

  "rotation": {
    "automatedRotationEnabled": true,
    "rotationSchedule": [
      {
        "secretType": "api-keys",
        "frequency": "every 90 days",
        "executor": "gv secret rotate --category api-keys",
        "schedule": "cron: 0 2 * * 0 (Sunday 2 AM UTC)",
        "notification": "Security team + service owners 7 days before + 1 day before"
      },
      {
        "secretType": "database-credentials",
        "frequency": "every 120 days",
        "executor": "gv secret rotate --category database-credentials",
        "schedule": "cron: 0 2 1 * * (1st day of month, 2 AM UTC)",
        "notification": "DBAs + app owners 7 days advance notice"
      },
      {
        "secretType": "oauth-tokens",
        "frequency": "every 30 days",
        "executor": "gv secret rotate --category oauth-tokens",
        "schedule": "cron: 0 2 * * 0 (Weekly)",
        "notification": "Service owners"
      },
      {
        "secretType": "tls-certificates",
        "frequency": "every 89 days before expiration",
        "executor": "gv secret rotate --category tls-certificates",
        "automaticRenewal": "ACME (Let's Encrypt) with auto-renewal",
        "notification": "OPS team 30 days before expiration"
      },
      {
        "secretType": "signing-keys",
        "frequency": "every 1 year (or on compromise)",
        "executor": "gv secret rotate --category signing-keys --require-approval",
        "approvalRequired": ["CISO", "CTO"],
        "notification": "Executive + security + ops teams"
      }
    ],
    "rotationMonitoring": {
      "successRate": "Target 100%",
      "alert": "If any rotation fails, escalate to security team within 1 hour",
      "rollback": "Automatic rollback to previous secret if new one fails",
      "verification": "Post-rotation test: Verify new secret works in staging first"
    }
  },

  "access": {
    "principle": "Zero-Trust, Least Privilege",
    "authentication": {
      "required": true,
      "methods": ["MFA-enabled service account", "Human user with MFA", "Signed JWT from CI/CD"],
      "tokenExpiry": "15 minutes max"
    },
    "authorization": {
      "rbac": true,
      "roles": [
        {
          "name": "admin",
          "permissions": ["create", "read", "update", "delete", "rotate", "audit"],
          "members": ["security-team", "devops-lead"]
        },
        {
          "name": "operator",
          "permissions": ["read", "rotate"],
          "members": ["devops-team", "app-owners"]
        },
        {
          "name": "application",
          "permissions": ["read"],
          "members": ["service-accounts", "ci-cd-pipelines"]
        },
        {
          "name": "auditor",
          "permissions": ["audit", "report"],
          "members": ["compliance-team", "security-auditors"]
        }
      ],
      "restrictionBySecretType": {
        "mfa-seeds": "admin only",
        "encryption-keys": "admin + HSM operator",
        "signing-keys": "admin + cryptography-team",
        "api-keys": "operators + service-accounts",
        "database-credentials": "operators + dba-team",
        "oauth-tokens": "operators + app-owners"
      }
    },
    "requestApproval": {
      "required": true,
      "approvalGate": "If accessing CRITICAL secrets, require human approval",
      "timeoutForApproval": "15 minutes (access denied if not approved)",
      "notification": "Alert approvers in real-time (slack/email)"
    }
  },

  "audit": {
    "logging": {
      "enabled": true,
      "events": [
        "secret-created",
        "secret-accessed",
        "secret-rotated",
        "secret-deleted",
        "access-denied",
        "failed-authentication"
      ],
      "logFormat": "JSON with timestamp, actor, action, secret-id (hashed), resource, result, ip-address",
      "logRetention": "2 years (compliant with GDPR + SOC2)",
      "logEncryption": "AES-256 at rest, TLS in transit"
    },
    "alerting": {
      "highPriority": [
        "Unauthorized access attempt to CRITICAL secrets",
        "Mass secret access (>10 secrets in 5 min by same actor)",
        "Access outside business hours from unusual IP",
        "Failed rotation of critical secret",
        "Secret accessed from non-whitelisted IP"
      ],
      "escalation": "Immediate → Security team + CISO on-call"
    },
    "compliance": {
      "reports": [
        {
          "name": "Secret Access Report",
          "frequency": "weekly",
          "coverage": "All secrets accessed, by WHO, WHEN, result"
        },
        {
          "name": "Rotation Compliance",
          "frequency": "monthly",
          "coverage": "Rotation schedule adherence, failures, remediations"
        },
        {
          "name": "Violation Report",
          "frequency": "on-demand",
          "coverage": "Unauthorized access, policy violations, recommended actions"
        }
      ],
      "command": "gv secret audit-report --type [access|rotation|violations] --period [weekly|monthly|custom]"
    }
  },

  "breach": {
    "response": {
      "immediate": "Revoke compromised secret within 5 minutes",
      "notification": "Alert security team + service owners within 1 hour",
      "investigation": "Root cause analysis within 24 hours",
      "remediation": "Rotate all related secrets within 24 hours"
    },
    "command": "gv secret breach-response --compromised-secret <secret-id> --reason <reason>"
  },

  "enforcement": {
    "preCommitHook": {
      "enabled": true,
      "purpose": "Prevent secrets from being committed to Git",
      "tool": "secretlint",
      "failureAction": "block commit",
      "detectionPatterns": [
        "api_key=",
        "password=",
        "token:",
        "secret:",
        "private_key",
        "BEGIN RSA PRIVATE KEY"
      ]
    },
    "preDeploymentCheck": {
      "enabled": true,
      "purpose": "Scan code/configs for hardcoded secrets before deployment",
      "tool": "truffleHog + secretlint",
      "failureAction": "block deployment",
      "scanScope": "entire codebase + all config files"
    },
    "secretComplianceValidator": {
      "enabled": true,
      "command": "gv secret validate-compliance",
      "checks": [
        "All secrets encrypted at rest?",
        "Rotation on schedule?",
        "No hardcoded secrets in code?",
        "Access logs complete?",
        "MFA required for sensitive secrets?",
        "Vault backups current?"
      ],
      "exitCode": "0=compliant, 1=violations detected"
    }
  },

  "monitoring": {
    "dashboards": [
      {
        "name": "Secrets Health",
        "metrics": [
          "Secrets by rotation status (due, overdue, recent)",
          "Failed access attempts",
          "Unauthorized access alerts",
          "Secret lifecycle events"
        ]
      },
      {
        "name": "Compliance Status",
        "metrics": [
          "Rotation compliance %",
          "Encryption compliance %",
          "Access control violations",
          "Audit log completeness"
        ]
      }
    ],
    "command": "gv secret dashboard --type [health|compliance]"
  },

  "procedures": {
    "createSecret": {
      "steps": [
        "gv secret create --name <secret-name> --type <category>",
        "Provide value via stdin (not in command line)",
        "Review + approve in vault UI",
        "Secret stored encrypted, rotation scheduled",
        "Distribute to authorized services via API"
      ]
    },
    "rotateSecret": {
      "steps": [
        "gv secret rotate --name <secret-name>",
        "New secret generated + stored",
        "Test with new value in staging",
        "Approved + deployed to production",
        "Old secret revoked + logged",
        "Audit trail recorded"
      ]
    },
    "revokeSecret": {
      "steps": [
        "gv secret revoke --name <secret-name> --reason <reason>",
        "Immediate revocation (5 min SLA)",
        "All accesses logged",
        "Services notified to stop using secret",
        "Audit trail immutable"
      ]
    }
  },

  "policiesByRole": {
    "developers": {
      "canCreate": false,
      "canRead": ["application-secrets", "api-keys"],
      "canRotate": false,
      "mustUseVault": true,
      "noHardcoding": "enforced by pre-commit hook"
    },
    "devops": {
      "canCreate": true,
      "canRead": "all non-MFA",
      "canRotate": true,
      "requiresApproval": ["encryption-keys", "signing-keys"],
      "mustAuditAllActions": true
    },
    "security": {
      "canCreate": true,
      "canRead": "all",
      "canRotate": true,
      "canRevoke": true,
      "auditAccess": true
    },
    "applications": {
      "canCreate": false,
      "canRead": "assigned secrets only (via service account)",
      "canRotate": false,
      "sessionTimeout": "60 minutes"
    }
  },

  "integrations": {
    "cicd": {
      "github": {
        "secretsManager": "GitHub Secrets",
        "rotationAutomated": true,
        "auditTrail": true
      },
      "gitlab": {
        "secretsManager": "GitLab CI/CD Variables",
        "rotationAutomated": true,
        "auditTrail": true
      },
      "jenkins": {
        "secretsManager": "Jenkins Credentials Plugin",
        "rotationAutomated": true,
        "auditTrail": true
      }
    },
    "cloudProviders": {
      "azure": "Azure Key Vault integration",
      "aws": "AWS Secrets Manager integration",
      "gcp": "Google Cloud Secret Manager integration"
    },
    "hsm": {
      "providers": ["Thales Luna HSM", "YubiHSM", "Azure Dedicated HSM"],
      "recommendation": "For encryption-keys, signing-keys (CRITICAL)",
      "keyBackup": "Enabled with secure recovery procedures"
    }
  },

  "compliance": {
    "standards": ["SOC2", "GDPR", "ISO27001", "PCI-DSS"],
    "mandatoryFeatures": [
      "Encryption at rest (AES-256)",
      "Encryption in transit (TLS 1.3)",
      "Access control (RBAC + MFA)",
      "Audit logging (immutable, 2-year retention)",
      "Automated rotation per schedule",
      "Breach response procedures",
      "Zero-trust access model"
    ]
  },

  "status": "MANDATORY — All agents MUST comply by 2026-06-01",
  "violationAction": "Non-compliance blocks production deployment",
  "reviewCycle": "Annual + quarterly updates per threat landscape"
}
