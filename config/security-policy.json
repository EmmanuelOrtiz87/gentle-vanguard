{
  "version": "1.0.0",
  "name": "security-policy",
  "description": "Security authorization policy for Foundation - defines which operations require authentication",

  "authentication": {
    "requiredFor": [
      {
        "operation": "security.disable",
        "description": "Disable security orchestrator",
        "severity": "CRITICAL",
        "requireAuth": true
      },
      {
        "operation": "security.modify",
        "description": "Modify security-privacy.json configuration",
        "severity": "CRITICAL",
        "requireAuth": true
      },
      {
        "operation": "security.disable.Block",
        "description": "Disable critical pattern blocking",
        "severity": "CRITICAL",
        "requireAuth": true
      },
      {
        "operation": "orchestrator.disable",
        "description": "Disable main orchestrator",
        "severity": "HIGH",
        "requireAuth": true
      },
      {
        "operation": "config.strategic.modify",
        "description": "Modify strategic stack configuration",
        "severity": "HIGH",
        "requireAuth": true
      },
      {
        "operation": "api-keys.modify",
        "description": "Add or modify API keys in configurations",
        "severity": "CRITICAL",
        "requireAuth": true
      },
      {
        "operation": "session.requireAuth",
        "description": "Enable session authentication requirement",
        "severity": "HIGH",
        "requireAuth": true
      }
    ],
    "autoAuthOperations": [
      "security.status",
      "security.init",
      "security.scan",
      "privacy-gateway.sanitize"
    ],
    "apiKeyHeader": "fnd_local_2026_",
    "sessionDuration": 8
  },

  "accessControl": {
    "mode": "enforced",
    "fallbackToQuestions": true,
    "maxAttempts": 3,
    "lockoutMinutes": 15
  },

  "audit": {
    "logAuthAttempts": true,
    "logPath": ".runtime/security-auth-audit.log",
    "alertOnFailedAttempts": true,
    "alertThreshold": 3
  }
}