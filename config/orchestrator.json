{
  "orchestrator": {
    "version": "2.5.0",
    "preProcessing": {
      "enabled": true,
      "mandatory": true,
      "description": "MANDATORY pre-processing hook - runs BEFORE any AI response",
      "script": "scripts/utilities/pre-process-input.ps1",
      "scriptArgs": {
        "UserInput": "USER_INPUT_HERE",
        "WorkspaceRoot": "."
      },
      "fallbackBehavior": "continue",
      "toolsSupported": [
        "opencode",
        "cline",
        "cursor",
        "windsurf",
        "continue_dev",
        "claude",
        "copilot",
        "antigravity"
      ]
    },
    "triggerDetection": {
      "enabled": true,
      "sources": [
        "skills/*/SKILL.md",
        "config/auto-delegation.json"
      ],
      "matchMode": "wordBoundary",
      "partialMatch": {
        "enabled": true,
        "threshold": 0.5
      }
    },
    "sessionStartup": {
      "enabled": true,
      "mandatory": true,
      "script": "scripts/utilities/session-autostart.cmd",
      "platform": "windows",
      "alternatives": {
        "linux": "bash ./scripts/utilities/session-autostart.sh",
        "macos": "bash ./scripts/utilities/session-autostart.sh"
      }
    },
    "skillLoading": {
      "autoLoad": true,
      "tool": "skill",
      "fallbackToManual": false
    },
    "logging": {
      "enabled": true,
      "level": "info",
      "file": ".logs/orchestrator-preprocess.log"
    }
  }
}
