{
  "tool": "windsurf",
  "displayName": "Windsurf",
  "version": "latest",
  "preProcess": {
    "loadSkills": false,
    "skillTool": "none",
    "autoLoad": false,
    "mcpBridge": false
  },
  "capabilities": ["ai_chat", "code_generation"],
  "configFiles": [".windsurf/config.json", ".codeiumignore", "AGENTS.md"],
  "adapter": {
    "type": "format-adapter",
    "path": "adapters/format-adapters/windsurf-adapter",
    "status": "ready"
  },
  "hooks": {
    "preToolCall": "scripts/utilities/pre-process-input.ps1",
    "sessionStart": "scripts/utilities/session-autostart.cmd",
    "adaptiveProfile": "scripts/utilities/adaptive-codex-windsurf-profile.ps1",
    "sessionStartPlatform": {
      "windows": "scripts/utilities/session-autostart.cmd",
      "linux": "bash ./scripts/utilities/session-autostart.sh",
      "macos": "bash ./scripts/utilities/session-autostart.sh"
    }
  }
}
