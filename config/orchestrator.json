{
  "orchestrator": {
    "version": "2.6.0",
    "active": true,
    "activation_mode": "auto",
    "activeToolDetection": {
      "enabled": true,
      "mandatory": true,
      "script": "scripts/utilities/detect-tool.ps1",
      "scriptArgs": "-ConfigPath config/orchestrator.json -AsJson",
      "fallbackTool": "opencode",
      "fallbackPromptFile": "CLAUDE.md",
      "canonicalEntryPoint": "docs/AGENTS.md",
      "note": "Detects tool at runtime and loads correct profile. OpenCode is the baseline default when no explicit runtime marker is present. Always use AGENTS.md over tool-specific files."
    },
    "preProcessing": {
      "enabled": true,
      "mandatory": true,
      "script": "scripts/utilities/pre-process-input.ps1",
      "scriptArgs": {
        "UserInput": "USER_INPUT_HERE",
        "WorkspaceRoot": "."
      },
      "fallbackBehavior": "continue",
      "fallbackStrategy": "clarify-ba",
      "parseOutput": {
        "triggerFound": "TRIGGER_MATCH_FOUND",
        "planMode": "PLAN_MODE_REQUIRED",
        "noMatch": "NO_TRIGGER_MATCH"
      },
      "toolsSupported": [
        "opencode",
        "orchestrator",
        "cline",
        "cursor",
        "windsurf",
        "continue_dev",
        "claude",
        "copilot",
        "antigravity"
      ]
    },
    "triggerDetection": {
      "enabled": true,
      "sources": ["config/auto-delegation.json", "skills/*/SKILL.md"],
      "matchMode": "wordBoundary",
      "partialMatch": {
        "enabled": true,
        "threshold": 0.5
      }
    },
    "sessionStartup": {
      "enabled": true,
      "mandatory": true,
      "script": "scripts/utilities/session-autostart.cmd",
      "platform": "windows",
      "alternatives": {
        "linux": "bash ./scripts/utilities/session-autostart.sh",
        "macos": "bash ./scripts/utilities/session-autostart.sh"
      }
    },
    "skillLoading": {
      "autoLoad": true,
      "tool": "skill",
      "fallbackToManual": false
    },
    "logging": {
      "enabled": true,
      "level": "info",
      "file": ".logs/orchestrator-preprocess.log"
    }
  },
  "communication_language": "es",
  "allowed_languages": ["es", "pt-BR", "en"],
  "communication_response_mode": "simple",
  "allowed_response_modes": ["simple", "executive", "expanded"],
  "chat_response": {
    "default_level": "chat-compact",
    "enforce_on_session_start": false,
    "auto_escalate_on_complex_tasks": true,
    "auto_escalate_triggers": [
      "multi-step",
      "implement",
      "refactor",
      "bug fix",
      "crear",
      "build",
      "desarrollar",
      "arreglar",
      "implementar"
    ],
    "allow": ["chat-compact", "chat-balanced", "chat-detailed"],
    "decision": {
      "kind": "architecture",
      "title": "startup-chat-baseline",
      "rationale": "Initialize sessions with minimal chat verbosity for token efficiency and closure-first operation."
    }
  },
  "communication_presets": {
    "default": "bugfix",
    "allow": ["bugfix", "refactor", "docs", "audit-review", "executive-demo"],
    "profiles": {
      "bugfix": {
        "language": "es",
        "detail": "simple",
        "compression": "ultra"
      },
      "refactor": {
        "language": "es",
        "detail": "simple",
        "compression": "ultra"
      },
      "docs": {
        "language": "es",
        "detail": "simple",
        "compression": "ultra"
      },
      "audit-review": {
        "language": "es",
        "detail": "simple",
        "compression": "ultra"
      },
      "executive-demo": {
        "language": "es",
        "detail": "simple",
        "compression": "ultra"
      }
    }
  },
  "response_profiles": {
    "active": "ultra",
    "allow": ["lite", "lleno", "ultra"],
    "profiles": {
      "lite": {
        "description": "Professional concise language with complete sentences; no filler.",
        "guidelines": ["No digressions.", "Keep complete sentences.", "Focus on actionable output."]
      },
      "lleno": {
        "description": "Compressed language with short fragments accepted. Adequate detail for task completion.",
        "guidelines": [
          "Complete sentences preferred.",
          "Explain reasoning before actions.",
          "Provide sufficient detail to finish tasks in one pass."
        ]
      },
      "simple": {
        "description": "Minimum viable detail — no preamble, no postamble, no digressions.",
        "guidelines": [
          "No preamble or postamble.",
          "No echoing user's question.",
          "One line answer then tools."
        ]
      },
      "ultra": {
        "description": "Aggressive compression with abbreviations and causal arrows.",
        "guidelines": [
          "Use compact abbreviations (db/auth/config/req/res/fn/impl).",
          "Prefer X -> Y causal notation.",
          "One-word answers when enough."
        ]
      }
    }
  },
  "response_policy": {
    "strict_mode": true,
    "enforce_baseline": true,
    "baseline_detail": "simple",
    "baseline_profile": "ultra",
    "baseline_chat_level": "chat-compact",
    "allow_overrides": true,
    "require_override_reason": true,
    "break_glass": {
      "enabled": true,
      "description": "Auto-override when current response profile prevents completing multi-step tasks. Agent detects pattern (user reports incompleteness, task spans 3+ turns, loop detection) and overrides autonomously.",
      "override_to_profile": "lleno",
      "override_to_chat_level": "chat-balanced",
      "override_to_detail": "simple",
      "requires_notification": true,
      "notification_template": "[BREAK GLASS] La configuración {old_profile}/{old_chat_level} impedía completar la tarea. Override automático a {new_profile}/{new_chat_level}. Motivo: {reason}",
      "audit_log": ".logs/break-glass-audit.jsonl",
      "detection_triggers": [
        "usuario reporta tarea incompleta (no terminaste, a la mitad, incompleto, no finalizaste)",
        "misma tarea se extiende 3+ turnos sin completarse",
        "usuario repite el mismo reclamo",
        "agente detecta que su output fue truncado o insuficiente",
        "bucle detectado (misma conversación girando sin progreso)"
      ],
      "allowed_profiles": ["lleno", "lite"],
      "allowed_chat_levels": ["chat-balanced", "chat-detailed"],
      "cooldown_turns": 5,
      "abuse_prevention": {
        "max_overrides_per_session": 3,
        "max_overrides_per_hour": 2,
        "reset_on_session_start": true
      }
    }
  },
    "editing": {
      "hashline": {
        "enabled": true,
        "script": "scripts/editing/hashline.ps1",
        "storage": ".runtime/hashline-db.json",
        "hash_algorithm": "SHA-256",
        "integration": {
          "lefthook": ".lefthook.yml#post-commit.hashing-snapshot",
          "pre_compact": "scripts/utilities/pre-compact-hook.ps1"
        }
      }
    },
    "team_mode": {
      "enabled": true,
      "script": "scripts/utilities/WORKFLOW-ORCHESTRATION/team-mode.ps1",
      "dispatch_integration": "scripts/utilities/WORKFLOW-ORCHESTRATION/dispatch-agent.ps1#-Mode team",
      "message_bus": "scripts/adaptive/agent-message-bus.ps1",
      "max_members": 8,
      "runtime_dir": ".runtime/teams"
    },
    "skill_mcp": {
      "enabled": true,
      "script": "scripts/utilities/UTILITIES/skill-mcp-manager.ps1",
      "mcp_config": "config/mcp-servers.json",
      "skill_format_key": "mcp_servers",
      "active_mcps_file": ".runtime/skill-mcps/active-skill-mcps.json"
    },
    "subagent_orchestration": {
    "token_budget_guard": {
      "enabled": true,
      "unit": "tokens",
      "estimation": {
        "method": "chars_div_4",
        "chars_per_token": 4,
        "note": "Canonical unit: tokens. chars/4 = estimated tokens. Use this formula across all scripts."
      },
      "daily_budget_tokens": 30000,
      "soft_threshold_pct": 70,
      "hard_threshold_pct": 90,
      "per_agent_budget_tokens": 3000,
      "coordination_overhead_tokens": 125,
      "skill_body_overage_warning_pct": 70,
      "alert_levels": {
        "soft": "WARN — log and continue",
        "hard": "BLOCK — refuse dispatch until reset or override"
      },
      "legacy_script": "scripts/utilities/token-guard.ps1",
      "operational_script": "scripts/utilities/TELEMETRY-METRICS/token-budget-guard.ps1",
      "metrics_path": "docs/sessions/metrics/token-guard-usage.csv"
    },
    "constraint_optimization": {
      "enabled": true,
      "description": "Reduce repetition of constraints in prompts after agents earn trust through consistent compliance.",
      "state_file": ".session/constraint-retention-state.json",
      "passes_threshold": 3,
      "reset_on_failure": true,
      "notify_on_drop": false,
      "track_from": ["agentProfiles.constraint_retention", "behavior-prompts.earned_trust"],
      "injection_point": "before_task_execution",
      "drop_strategy": "soft_drop",
      "integration": {
        "auto_delegation": "$ref:auto-delegation.json#/adaptive_mode/constraint_optimization",
        "behavior_prompts": "$ref:behavior-prompts.json#/prompts/*/earned_trust"
      }
    },
    "artifact_naming": {
      "enabled": true,
      "description": "Multi-user artifact persistence — username prefix prevents collisions in parallel sessions.",
      "mode": "username_prefix",
      "modes_available": ["username_prefix", "user_subdirectory", "session_scoped"],
      "username_sources": ["$env:GV_USERNAME", "$env:USERNAME", "git config user.name"],
      "sanitize": true,
      "separator": "-",
      "timestamp_format": "YYYY-MM-DD-HHmmss",
      "file_locking": {
        "enabled": true,
        "method": "lock_file",
        "lock_directory": ".session/locks",
        "retry_attempts": 3,
        "retry_delay_ms": 200,
        "scope": [
          "telemetry-master.csv",
          "agent-usage.csv",
          "context-usage.csv",
          "token-guard-usage.csv",
          "cloud-agent-telemetry.csv"
        ]
      },
      "integration": {
        "auto_delegation": "$ref:auto-delegation.json#/adaptive_mode/artifact_naming",
        "utility_script": "scripts/utilities/artifact-naming.ps1"
      }
    }
  },
  "workspace": {
    "workspaceRoot": ".",
    "projectRoot": "projects",
    "dataRoot": ".engram-data",
    "toolsRoot": "tools",
    "templatesRoot": "templates",
    "projectTemplate": "templates/project-root",
    "configFile": "config/workspace.config.json",
    "note": "All paths relative to workspace root (the directory containing this config). Agent MUST read workspace.config.json for detailed per-project settings. New projects are created under projectRoot/.",
    "newProjectFlow": "sdd-lifecycle",
    "projectDefaults": {
      "kind": "service",
      "preset": "default",
      "architecture": "layered",
      "profile": "general",
      "testCommand": "go test ./..."
    }
  },
  "norms": {
    "orchestrator": "docs/NORMATIVAS-ORQUESTADOR.md",
    "hashline": "scripts/editing/hashline.ps1",
    "team_mode": "scripts/utilities/WORKFLOW-ORCHESTRATION/team-mode.ps1",
    "skill_mcp": "scripts/utilities/UTILITIES/skill-mcp-manager.ps1",
    "code_review": "rules/CODE-REVIEW-STANDARDS.md",
    "pr_workflow": "rules/PR-WORKFLOW.md",
    "secrets_management": "rules/SECRETS-MANAGEMENT.md",
    "incident_response": "rules/INCIDENT-RESPONSE.md",
    "context_engineering": "rules/CONTEXT-ENGINEERING.md",
    "continuous_improvement": "rules/CONTINUOUS-IMPROVEMENT.md",
    "prompt_engineering": "rules/PROMPT-ENGINEERING.md",
    "ai_model_selection": "rules/AI-MODEL-SELECTION.md",
    "model_routing": "config/model-routing.json",
    "delegation_rules": "rules/DELEGATION-RULES.md",
    "sdd_config": "openspec/config.yaml",
    "inter_agent_communication": "rules/INTER-AGENT-COMMUNICATION.md",
    "security": "docs/NORMATIVAS-SEGURIDAD.md",
    "testing": "docs/NORMATIVAS-TESTING.md",
    "accessibility": "docs/NORMATIVAS-ACCESIBILIDAD.md",
    "i18n_l10n": "docs/NORMATIVAS-I18N-L10N.md",
    "api_design": "docs/NORMATIVAS-API-DESIGN.md",
    "sre": "docs/NORMATIVAS-SRE.md",
    "chaos_engineering": "docs/NORMATIVAS-CHAOS-ENGINEERING.md",
    "sbom": "docs/NORMATIVAS-SBOM.md",
    "iso_25010": "docs/NORMATIVAS-ISO25010.md",
    "iso_27001": "docs/NORMATIVAS-ISO27001.md",
    "compliance": {
      "security_config": "config/security-hardening.json",
      "testing_config": "config/testing-policy.json",
      "sre_error_budgets": "config/sre-error-budgets.json",
      "ps_analyzer": "config/PSScriptAnalyzerSettings.psd1",
      "eslint": ".eslintrc.json",
      "typescript": "tsconfig.json"
    }
  },
  "toolProfiles": {
    "opencode": {
      "promptFile": "CLAUDE.md",
      "configFile": "opencode.json",
      "primaryEntryPoint": "docs/AGENTS.md",
      "responseProfile": "ultra",
      "communicationLang": "es",
      "supportsSkillTool": true,
      "supportsMemTools": true,
      "detectFirst": true,
      "mandatoryStartup": "scripts/utilities/session-autostart.cmd",
      "adaptiveProfile": "scripts/utilities/adaptive-opencode-profile.ps1",
      "note": "CLAUDE.md is auto-loaded by OpenCode — contains immediate detect-tool.ps1 directive atop"
    },
    "claude-code": {
      "promptFile": "CLAUDE.md",
      "configFile": ".claude/settings.json",
      "primaryEntryPoint": "docs/AGENTS.md",
      "responseProfile": "ultra",
      "communicationLang": "es",
      "supportsSkillTool": true,
      "supportsMemTools": true,
      "adaptiveProfile": "scripts/utilities/adaptive-claude-cline-profile.ps1",
      "note": "Claude Code native — CLAUDE.md is auto-loaded"
    },
    "cline": {
      "promptFile": ".clinerules",
      "configFile": ".clinerules",
      "primaryEntryPoint": "docs/AGENTS.md",
      "responseProfile": "ultra",
      "communicationLang": "es",
      "supportsSkillTool": false,
      "supportsMemTools": false,
      "adaptiveProfile": "scripts/utilities/adaptive-claude-cline-profile.ps1",
      "note": "Cline uses .clinerules — must reference AGENTS.md for canonical bootstrap"
    },
    "cursor": {
      "promptFile": ".cursorrules",
      "configFile": ".cursorrules",
      "primaryEntryPoint": "docs/AGENTS.md",
      "responseProfile": "ultra",
      "communicationLang": "es",
      "supportsSkillTool": false,
      "supportsMemTools": false,
      "adaptiveProfile": "scripts/utilities/adaptive-cursor-profile.ps1",
      "note": "Cursor uses .cursorrules — must reference AGENTS.md for canonical bootstrap"
    },
    "windsurf": {
      "promptFile": "CLAUDE.md",
      "configFile": ".windsurf/config.json",
      "primaryEntryPoint": "docs/AGENTS.md",
      "responseProfile": "ultra",
      "communicationLang": "es",
      "supportsSkillTool": false,
      "supportsMemTools": false,
      "adaptiveProfile": "scripts/utilities/adaptive-codex-windsurf-profile.ps1",
      "note": "Windsurf uses CLAUDE.md by convention — canonical entry is AGENTS.md"
    },
    "codex": {
      "promptFile": "CLAUDE.md",
      "configFile": ".codex/config.toml",
      "primaryEntryPoint": "docs/AGENTS.md",
      "responseProfile": "ultra",
      "communicationLang": "es",
      "supportsSkillTool": false,
      "supportsMemTools": false,
      "adaptiveProfile": "scripts/utilities/adaptive-codex-windsurf-profile.ps1",
      "note": "Codex — shares adaptive profile with Windsurf"
    },
    "continue-dev": {
      "promptFile": "CLAUDE.md",
      "configFile": ".continue/config.json",
      "primaryEntryPoint": "docs/AGENTS.md",
      "responseProfile": "ultra",
      "communicationLang": "es",
      "supportsSkillTool": true,
      "supportsMemTools": true,
      "adaptiveProfile": "scripts/utilities/adaptive-continue-copilot-profile.ps1",
      "note": "Continue.dev — adaptive profile manages token/permission optimization"
    },
    "copilot": {
      "promptFile": "CLAUDE.md",
      "configFile": ".continue/config.json",
      "primaryEntryPoint": "docs/AGENTS.md",
      "responseProfile": "ultra",
      "communicationLang": "es",
      "supportsSkillTool": false,
      "supportsMemTools": false,
      "adaptiveProfile": "scripts/utilities/adaptive-continue-copilot-profile.ps1",
      "note": "GitHub Copilot — shares adaptive profile with Continue.dev"
    },
    "antigravity": {
      "promptFile": "CLAUDE.md",
      "configFile": ".antigravity/config.json",
      "primaryEntryPoint": "docs/AGENTS.md",
      "responseProfile": "ultra",
      "communicationLang": "es",
      "supportsSkillTool": false,
      "supportsMemTools": false,
      "adaptiveProfile": "scripts/utilities/adaptive-antigravity-profile.ps1",
      "note": "Antigravity — v2.0 config with full skill emulation and engram memory. Dedicated adaptive profile."
    },
    "claude-generic": {
      "promptFile": "CLAUDE.md",
      "configFile": "",
      "primaryEntryPoint": "docs/AGENTS.md",
      "responseProfile": "ultra",
      "communicationLang": "es",
      "supportsSkillTool": true,
      "supportsMemTools": true,
      "adaptiveProfile": "scripts/utilities/adaptive-opencode-profile.ps1",
      "note": "Fallback for Claude variants — always prefer AGENTS.md"
    }
  },
  "governed_override_profiles": {
    "_comment": "Controlled overrides for response_policy. Each profile requires a reason and is audit-logged.",
    "allow_governed_overrides": true,
    "require_reason": true,
    "audit_log": ".logs/override-audit.jsonl",
    "abuse_detection": {
      "enabled": true,
      "window_hours": 24,
      "warn_total_overrides": 4,
      "warn_per_agent": 3,
      "warn_per_profile": 3
    },
    "profiles": {
      "verbose-debug": {
        "baseline_detail": "expanded",
        "baseline_profile": "lleno",
        "baseline_chat_level": "chat-detailed",
        "allowed_for_agents": ["BA", "DOC"],
        "max_duration_turns": 5,
        "rationale": "Temporary verbose mode for complex exploratory or documentation tasks"
      },
      "executive-review": {
        "baseline_detail": "expanded",
        "baseline_profile": "lite",
        "baseline_chat_level": "chat-balanced",
        "allowed_for_agents": ["GOV", "DOC"],
        "max_duration_turns": 3,
        "rationale": "Used for executive-facing reports where full prose is required"
      }
    }
  }
}
