{
  "version": "1.0.0",
  "name": "gentle-vanguard-security-privacy",
  "description": "Security and privacy configuration for Gentle-Vanguard orchestrator",

  "security": {
    "enabled": true,
    "autoInit": true,
    "autoSanitize": true,
    "autoBlock": true,
    "mode": "enforced",
    "audit": true
  },

  "privacy": {
    "prohibited": [
      {
        "category": "machineId",
        "patterns": ["COMPUTERNAME", "$env:COMPUTERNAME", "[System.Environment]::MachineName"],
        "replacement": "<MACHINE>",
        "severity": "HIGH"
      },
      {
        "category": "userId",
        "patterns": ["USERNAME", "$env:USERNAME", "[System.Environment]::UserName"],
        "replacement": "<USER>",
        "severity": "HIGH"
      },
      {
        "category": "homePath",
        "patterns": ["$env:USERPROFILE", "$env:HOME", "$env:APPDATA"],
        "replacement": "<HOME>",
        "severity": "HIGH"
      },
      {
        "category": "fullPaths",
        "patterns": ["C:\\\\Users\\\\[^\\\\]+", "/home/[^/]+", "\\\\\\\\[A-Za-z0-9_-]+\\\\\\\\"],
        "replacement": "<PATH>",
        "severity": "HIGH"
      },
      {
        "category": "credentials",
        "patterns": ["API_KEY", "SECRET", "PASSWORD", "TOKEN"],
        "replacement": "<REDACTED>",
        "severity": "CRITICAL"
      }
    ],
    "criticalBlock": [
      {
        "id": "aws-key",
        "pattern": "AKIA[0-9A-Z]{16}",
        "action": "BLOCK"
      },
      {
        "id": "github-token",
        "pattern": "ghp_[A-Za-z0-9]{36}",
        "action": "BLOCK"
      },
      {
        "id": "stripe-key",
        "pattern": "sk_live_[0-9a-zA-Z]{24,}",
        "action": "BLOCK"
      },
      {
        "id": "private-key",
        "pattern": "-----BEGIN (RSA|EC|DSA|PRIVATE) KEY-----",
        "action": "BLOCK"
      }
    ],
    "injectionBlock": [
      {
        "id": "injection-instruction-override",
        "pattern": "(?i)(?:\\bignore\\s+(?:all\\s+)?(?:previous\\s+)?(?:instructions|commands|directions|rules|prompts?|constraints?|guidelines?))\\b",
        "action": "BLOCK",
        "severity": "CRITICAL",
        "category": "instruction-override",
        "description": "Blocks attempts to override/skip previous instructions"
      },
      {
        "id": "injection-prompt-leakage",
        "pattern": "(?i)(?:\\b(?:repeat|output|print|show|display|reveal|leak|dump|copy)\\s+(?:your\\s+)?(?:system\\s+)?(?:prompt|instructions|rules))\\b",
        "action": "BLOCK",
        "severity": "CRITICAL",
        "category": "prompt-leakage",
        "description": "Blocks attempts to extract the system prompt"
      },
      {
        "id": "injection-jailbreak",
        "pattern": "(?i)(?:DAN|do\\s+anything\\s+now|jailbreak|unrestricted\\s+mode|developer\\s+mode|no\\s+(?:limits|restrictions|filter))",
        "action": "BLOCK",
        "severity": "CRITICAL",
        "category": "jailbreak",
        "description": "Blocks known jailbreak patterns"
      },
      {
        "id": "injection-code-execution",
        "pattern": "(?i)(?:\\$?(?:exec|eval|system|shell|cmd|powershell|bash|os\\.system|subprocess|child_process|execSync|spawn)\\s*\\()",
        "action": "BLOCK",
        "severity": "CRITICAL",
        "category": "code-execution",
        "description": "Blocks remote code execution attempts via agent"
      },
      {
        "id": "injection-role-takeover",
        "pattern": "(?i)(?:\\byou\\s+(?:are\\s+)?(?:now|must\\s+act\\s+as|will\\s+pretend|shall\\s+behave))\\b",
        "action": "BLOCK",
        "severity": "HIGH",
        "category": "role-takeover",
        "description": "Blocks role takeover/simulation attacks"
      },
      {
        "id": "injection-constraint-bypass",
        "pattern": "(?i)(?:forget|disregard|override|bypass|circumvent)\\s+(?:all\\s+)?(?:previous\\s+)?(?:instructions|rules|constraints|safeguards|protocols)\\b",
        "action": "BLOCK",
        "severity": "CRITICAL",
        "category": "constraint-bypass",
        "description": "Blocks attempts to bypass security constraints"
      },
      {
        "id": "injection-encoding-obfuscation",
        "pattern": "(?i)(?:base64\\s*(?:decode|encode)|rot[0-9]+|hex\\s*(?:decode|encode)|unicode\\s*escape)\\s*(?:the\\s+)?(?:following|above|below|this)\\s*(?:text|message|prompt|string|instructions)",
        "action": "BLOCK",
        "severity": "HIGH",
        "category": "encoding-obfuscation",
        "description": "Blocks encoding obfuscation used to bypass filters"
      }
    ]
  },

  "mcpSecurity": {
    "enabled": true,
    "scopeToWorkspace": true,
    "allowedPaths": ["$PWD/**", "$WORKSPACE/**", "<PROJECT>/**"],
    "deniedPaths": [
      "**/.env",
      "**/.ssh/**",
      "**/node_modules/.package-lock.json",
      "**/.git/objects/**"
    ],
    "noNetworkExternal": false,
    "auditFileAccess": true
  },

  "targets": {
    "ai-api": {
      "sanitize": true,
      "blockCritical": true,
      "audit": true
    },
    "mcp": {
      "sanitize": true,
      "scopeValidation": true,
      "audit": true
    },
    "log": {
      "sanitize": true,
      "blockCritical": false,
      "audit": true
    },
    "error": {
      "sanitize": true,
      "blockCritical": false,
      "audit": false
    }
  },

  "audit": {
    "enabled": true,
    "path": ".runtime/security-audit.log",
    "format": "json",
    "rotateDaily": true,
    "retentionDays": 30
  },

  "hooks": {
    "prePrompt": "scripts/security/privacy-gateway.ps1",
    "preMcp": "scripts/security/mcp-security-validator.ps1",
    "preCommit": "hooks/pre-commit-privacy.ps1"
  },

  "reporting": {
    "enabled": true,
    "weekly": true,
    "metrics": ["sanitizedCount", "violationsBlocked", "patternsDetected", "auditEntries"]
  }
}
