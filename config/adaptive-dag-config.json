{
  "version": "1.0",
  "enabled": true,
  "dag": {
    "agents": {
      "BA": {
        "name": "Business Analyst",
        "dependencies": [],
        "skills": ["bdd-scenarios-skill", "backlog-management-skill"],
        "priority": 1,
        "agentProfile": "$ref:agentProfiles.BA"
      },
      "SAD": {
        "name": "Solution Architect",
        "dependencies": ["BA"],
        "skills": ["architecture-governance", "api-design-skill", "database-relational-skill"],
        "priority": 2,
        "agentProfile": "$ref:agentProfiles.SAD"
      },
      "DEV": {
        "name": "Developer",
        "dependencies": ["SAD"],
        "skills": ["typescript-skill", "react-19-skill", "golang-api-skill"],
        "priority": 3,
        "agentProfile": "$ref:agentProfiles.DEV"
      },
      "QA": {
        "name": "QA Engineer",
        "dependencies": ["DEV"],
        "skills": ["testing-skill", "playwright-skill", "pytest-skill"],
        "priority": 4,
        "agentProfile": "$ref:agentProfiles.QA"
      },
      "OPS": {
        "name": "DevOps Engineer",
        "dependencies": ["QA"],
        "skills": ["docker-devops-skill", "kubernetes-deployment", "terraform-infrastructure"],
        "priority": 5,
        "agentProfile": "$ref:agentProfiles.OPS"
      },
      "GOV": {
        "name": "Governance",
        "dependencies": ["DEV", "QA"],
        "skills": ["security-expert-skill", "observability-skill", "incident-response-plan"],
        "priority": 4,
        "agentProfile": "$ref:agentProfiles.GOV"
      },
      "DOC": {
        "name": "Documentation",
        "dependencies": ["DEV", "QA"],
        "skills": ["documentation-governance", "documentation-skill"],
        "priority": 5,
        "agentProfile": "$ref:agentProfiles.DOC"
      }
    },
    "profileSource": "config/auto-delegation.json#agentProfiles",
    "hallucinationGuardPolicy": {
      "low": "Agent self-reports - no external verification",
      "medium": "Orchestrator spot-checks 1 requiredEvidence item",
      "high": "ALL requiredEvidence items verified before phase advances",
      "critical": "All evidence verified + hedging language scan + external command must exit 0"
    },
    "phases": {
      "planning": {
        "agents": ["BA"],
        "timeout": 3600,
        "parallel": false,
        "required": true
      },
      "design": {
        "agents": ["SAD"],
        "timeout": 3600,
        "parallel": false,
        "required": true,
        "dependencies": ["planning"]
      },
      "implementation": {
        "agents": ["DEV"],
        "timeout": 7200,
        "parallel": false,
        "required": true,
        "dependencies": ["design"]
      },
      "quality_assurance": {
        "agents": ["QA"],
        "timeout": 3600,
        "parallel": false,
        "required": true,
        "dependencies": ["implementation"],
        "feedback_target": "implementation"
      },
      "governance": {
        "agents": ["GOV"],
        "timeout": 1800,
        "parallel": true,
        "required": true,
        "dependencies": ["implementation"]
      },
      "documentation": {
        "agents": ["DOC"],
        "timeout": 1800,
        "parallel": true,
        "required": false,
        "dependencies": ["implementation"]
      },
      "deployment": {
        "agents": ["OPS"],
        "timeout": 3600,
        "parallel": false,
        "required": true,
        "dependencies": ["quality_assurance", "governance"],
        "agentProfile": "$ref:agentProfiles.OPS",
        "gateRef": "unmappedFlows.releaseManagement.gate"
      },
      "pr_review": {
        "agents": ["QA"],
        "timeout": 1800,
        "parallel": false,
        "required": true,
        "dependencies": ["implementation", "quality_assurance"],
        "agentProfile": "$ref:agentProfiles.QA",
        "gateRef": "unmappedFlows.prReview.gate",
        "skill": "code-review-orchestrator-skill"
      },
      "release": {
        "agents": ["OPS", "GOV"],
        "timeout": 2700,
        "parallel": false,
        "required": false,
        "dependencies": ["deployment"],
        "agentProfile": "$ref:agentProfiles.OPS",
        "govCoProfile": "$ref:agentProfiles.GOV",
        "gateRef": "unmappedFlows.releaseManagement.gate",
        "skill": "release-management-skill"
      },
      "session_close": {
        "agents": ["GOV"],
        "timeout": 900,
        "parallel": false,
        "required": true,
        "dependencies": [],
        "agentProfile": "$ref:agentProfiles.GOV",
        "gateRef": "unmappedFlows.sessionClose.gate",
        "skill": "project-orchestrator-skill"
      }
    },
    "feedback_loops": {
      "qa_to_dev": {
        "source": "QA",
        "target": "DEV",
        "trigger": "test_failure",
        "max_iterations": 3,
        "enabled": true
      },
      "qa_to_design": {
        "source": "QA",
        "target": "SAD",
        "trigger": "architecture_issue",
        "max_iterations": 2,
        "enabled": true
      },
      "gov_to_dev": {
        "source": "GOV",
        "target": "DEV",
        "trigger": "security_issue",
        "max_iterations": 2,
        "enabled": true
      }
    },
    "rollback_policy": {
      "enabled": true,
      "auto_rollback_on_qa_failure": true,
      "max_rollback_attempts": 2,
      "rollback_triggers": [
        "critical_test_failure",
        "security_vulnerability",
        "performance_degradation",
        "deployment_failure"
      ],
      "checkpoint_on_phase_complete": true,
      "preserve_artifacts": true
    },
    "execution_strategy": {
      "mode": "adaptive",
      "parallelization": {
        "enabled": true,
        "max_parallel_phases": 2,
        "max_parallel_agents": 3
      },
      "error_handling": {
        "strategy": "fail_fast",
        "retry_count": 2,
        "retry_delay_ms": 1000
      },
      "monitoring": {
        "enabled": true,
        "metrics_collection": true,
        "health_check_interval": 300
      }
    },
    "decision_points": {
      "after_qa": {
        "condition": "qa_pass_rate >= 95",
        "on_true": "proceed_to_deployment",
        "on_false": "trigger_feedback_loop"
      },
      "after_gov": {
        "condition": "security_issues == 0 AND compliance_check == true",
        "on_true": "proceed_to_deployment",
        "on_false": "trigger_feedback_loop"
      },
      "after_deployment": {
        "condition": "deployment_success == true AND health_check == true",
        "on_true": "mark_complete",
        "on_false": "trigger_rollback"
      }
    }
  },
  "thresholds": {
    "qa_pass_rate_min": 95,
    "code_coverage_min": 80,
    "security_issues_max": 0,
    "performance_degradation_max": 5,
    "timeout_buffer_percent": 10
  },
  "logging": {
    "enabled": true,
    "level": "info",
    "log_file": "logs/adaptive-mode.log",
    "metrics_file": "logs/adaptive-mode-metrics.json"
  }
}
