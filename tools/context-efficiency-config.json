{
  "contextEfficiency": {
    "targetPercentage": 70,
    "autoCompactionThreshold": 15000,
    "reduceRedundancy": true,
    "referenceInsteadOfRepeat": true,
    "autoEngramUsage": true,
    "memoryTiering": {
      "hot": {
        "retention": "none",
        "duration": "current session"
      },
      "warm": {
        "retention": 90,
        "duration": "1 day"
      },
      "cold": {
        "retention": 70,
        "duration": "7 days"
      }
    }
  },
  "engramOptimization": {
    "autoSaveThreshold": 300,
    "preSearchEnabled": true,
    "dualWriteRequired": true,
    "referenceResolution": true
  },
  "compactationSchedule": {
    "autoTrigger": true,
    "thresholdTokens": 15000,
    "compressionRatio": 0.90,
    "preservedContentTypes": [
      "FIXME",
      "TODO",
      "BUG",
      "DECISION",
      "RESULT"
    ]
  },
  "promptOptimization": {
    "maxAverageChars": 1302,
    "reusePreviousContext": true,
    "avoidRepeatedConstraints": true
  }
}