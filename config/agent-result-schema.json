{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://workspace-foundation/schemas/agent-result-schema.json",
  "title": "Agent Result Schema",
  "description": "Schema for structured sub-agent results produced during parallel execution. Enables merge/consolidation of outputs from dispatched agents. FF-007.",
  "type": "object",
  "definitions": {
    "evidence_item": {
      "type": "object",
      "description": "A single piece of evidence produced by the agent (file, test result, metric, etc.)",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["file", "test", "metric"],
          "description": "Category of evidence"
        },
        "path": {
          "type": "string",
          "description": "Path or identifier for the evidence"
        },
        "summary": {
          "type": "string",
          "description": "Human-readable summary of the evidence"
        },
        "status": {
          "type": "string",
          "enum": ["pass", "fail", "warn"],
          "description": "Evaluation status of this evidence item"
        }
      },
      "required": ["type", "path", "summary", "status"],
      "additionalProperties": false
    },
    "decision": {
      "type": "object",
      "description": "A decision made by the agent during execution",
      "properties": {
        "description": {
          "type": "string",
          "description": "What was decided"
        },
        "rationale": {
          "type": "string",
          "description": "Reasoning behind the decision"
        },
        "alternatives_considered": {
          "type": "array",
          "description": "Other options that were evaluated",
          "items": {
            "type": "string"
          }
        }
      },
      "required": ["description", "rationale"],
      "additionalProperties": false
    },
    "error_item": {
      "type": "object",
      "description": "An error encountered during agent execution",
      "properties": {
        "code": {
          "type": "string",
          "description": "Machine-readable error code (e.g. 'E_TIMEOUT', 'E_VALIDATION')"
        },
        "message": {
          "type": "string",
          "description": "Human-readable error description"
        },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"],
          "description": "Impact level of the error"
        },
        "recovery_action": {
          "type": "string",
          "description": "Suggested action to recover from this error"
        }
      },
      "required": ["code", "message", "severity"],
      "additionalProperties": false
    }
  },
  "properties": {
    "agent_id": {
      "type": "string",
      "description": "Unique identifier of the sub-agent that produced this result"
    },
    "skill_name": {
      "type": "string",
      "description": "Name of the skill/agent type that executed (e.g. 'frontend-design', 'django-drf')"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the result was produced"
    },
    "duration_ms": {
      "type": "integer",
      "description": "Execution duration in milliseconds",
      "minimum": 0
    },
    "session_id": {
      "type": "string",
      "description": "Identifier for the orchestration session this result belongs to"
    },
    "status": {
      "type": "string",
      "enum": ["success", "failure", "partial"],
      "description": "Overall execution status"
    },
    "output": {
      "type": "string",
      "description": "The actual result content produced by the agent"
    },
    "output_type": {
      "type": "string",
      "enum": ["text", "json", "markdown", "code"],
      "description": "Format of the output field"
    },
    "evidence": {
      "type": "array",
      "description": "List of evidence items produced (files changed, tests run, metrics collected)",
      "items": {
        "$ref": "#/definitions/evidence_item"
      }
    },
    "decisions": {
      "type": "array",
      "description": "Decisions made by the agent during execution",
      "items": {
        "$ref": "#/definitions/decision"
      }
    },
    "errors": {
      "type": "array",
      "description": "Errors encountered during execution (if any)",
      "items": {
        "$ref": "#/definitions/error_item"
      }
    },
    "token_usage": {
      "type": "object",
      "description": "Token consumption and cost tracking for the agent run",
      "properties": {
        "tokens_in": {
          "type": "integer",
          "description": "Input tokens consumed",
          "minimum": 0
        },
        "tokens_out": {
          "type": "integer",
          "description": "Output tokens produced",
          "minimum": 0
        },
        "total_tokens": {
          "type": "integer",
          "description": "Total token count (tokens_in + tokens_out)",
          "minimum": 0
        },
        "cost_estimate": {
          "type": "number",
          "description": "Estimated cost in USD for the agent run",
          "minimum": 0
        }
      },
      "required": ["tokens_in", "tokens_out", "total_tokens"],
      "additionalProperties": false
    }
  },
  "required": ["agent_id", "skill_name", "timestamp", "status", "output"],
  "additionalProperties": false,
  "examples": [
    {
      "agent_id": "agent-7f3a2b1c",
      "skill_name": "frontend-design",
      "timestamp": "2026-05-10T14:30:00Z",
      "duration_ms": 12450,
      "session_id": "session-2026-05-10-01",
      "status": "success",
      "output": "Created LoginPage component with Tailwind styling",
      "output_type": "text",
      "evidence": [
        {
          "type": "file",
          "path": "src/pages/LoginPage.tsx",
          "summary": "Main login page component",
          "status": "pass"
        }
      ],
      "decisions": [
        {
          "description": "Used controlled form inputs instead of uncontrolled",
          "rationale": "Better validation control and testability",
          "alternatives_considered": ["Uncontrolled ref-based inputs"]
        }
      ],
      "errors": [],
      "token_usage": {
        "tokens_in": 8500,
        "tokens_out": 1200,
        "total_tokens": 9700,
        "cost_estimate": 0.145
      }
    }
  ]
}
