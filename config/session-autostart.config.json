{
  "version": "1.0.0",
  "name": "session-autostart-config",
  "description": "Configuration for session autostart pipeline - controls which steps run and their parameters",

  "pipeline": {
    "steps": [
      {
        "id": "tool-detection",
        "enabled": true,
        "script": "scripts/utilities/detect-tool.ps1",
        "args": "-AsJson",
        "required": false,
        "description": "Detect AI tool/agent and load tool-specific configuration"
      },
      {
        "id": "session-manager",
        "enabled": true,
        "script": "scripts/utilities/session-manager.ps1",
        "args": "-Mode AutoStart",
        "required": true,
        "description": "Initialize session ID and create session file"
      },
      {
        "id": "github-bypass",
        "enabled": true,
        "script": "scripts/utilities/SESSION-MANAGEMENT/ensure-github-bypass.ps1",
        "args": "",
        "required": false,
        "description": "Ensure GitHub bypass policy for current user"
      },
      {
        "id": "notifications",
        "enabled": true,
        "script": "scripts/utilities/session-notification.ps1",
        "args": "-TimeZone \"Argentina Standard Time\" -PeakStart 9 -PeakEnd 15 -Region \"Argentina\"",
        "required": false,
        "description": "Time-based peak hour notifications"
      },
      {
        "id": "auth-session",
        "enabled": false,
        "script": "scripts/utilities/auth-session.ps1",
        "args": "",
        "required": false,
        "description": "Authenticate owner for restricted operations (requires manual trigger with -ApiKey or -UseSecurityQuestions)",
        "note": "Disabled by default - auth is demand-driven, not at session start. Enable if session-level auth is required."
      },
      {
        "id": "engram-policy",
        "enabled": true,
        "script": "scripts/gentle-vanguard/engram-policy.ps1",
        "args": "-Action enforce",
        "required": true,
        "description": "Verify Engram is installed and running"
      },
      {
        "id": "token-budget",
        "enabled": true,
        "script": "scripts/utilities/TELEMETRY-METRICS/token-budget-guard.ps1",
        "args": "-Task session-start -Risk low -Record -ActualPromptTokens 0 -ActualCompletionTokens 0",
        "required": false,
        "description": "Record session start for token budget tracking"
      },
      {
        "id": "engram-optimization",
        "enabled": true,
        "script": "scripts/utilities/optimize-engram-usage.ps1",
        "args": "-ProjectName workspace_gentle_vanguard",
        "required": false,
        "description": "Optimize Engram memory usage"
      },
      {
        "id": "cross-workspace-validation",
        "enabled": true,
        "script": "scripts/monitoring/cross-workspace-validator.ps1",
        "args": "-Detailed",
        "required": false,
        "description": "Validate cross-workspace consistency"
      },
      {
        "id": "security-orchestrator",
        "enabled": true,
        "script": "scripts/utilities/security-orchestrator.ps1",
        "args": "-Action init -AsJson",
        "required": true,
        "description": "Initialize Security Orchestrator with policy and privacy configs"
      },
      {
        "id": "skill-router",
        "enabled": true,
        "script": "scripts/utilities/skill-router.ps1",
        "args": "-Query \"session-start\"",
        "required": false,
        "description": "Verify skill router is active"
      },
      {
        "id": "karpathy-guidelines",
        "enabled": true,
        "script": "scripts/utilities/karpathy-enforcer.ps1",
        "args": "-Trigger session-start -VerboseOutput",
        "required": false,
        "description": "Enforce Karpathy guidelines (Think, Simplicity, Surgical, Goal-Driven)"
      },
      {
        "id": "session-metrics-start",
        "enabled": true,
        "script": "scripts/utilities/session-metrics-tracker.ps1",
        "args": "-Action start",
        "required": false,
        "description": "Initialize session metrics tracking (tokens, tool calls, files)"
      },
      {
        "id": "adaptive-opencode-profile",
        "enabled": true,
        "script": "scripts/utilities/adaptive-opencode-profile.ps1",
        "args": "-Mode Auto -TimeZone \"Argentina Standard Time\" -PeakStart 9 -PeakEnd 15",
        "required": false,
        "description": "Intelligent temporary OpenCode optimization with automatic restore when normalized"
      },
      {
        "id": "adaptive-codex-windsurf-profile",
        "enabled": true,
        "script": "scripts/utilities/adaptive-codex-windsurf-profile.ps1",
        "args": "-Mode Auto -TimeZone \"Argentina Standard Time\" -PeakStart 9 -PeakEnd 15",
        "required": false,
        "description": "Intelligent temporary Codex/Windsurf optimization with automatic restore when normalized"
      },
      {
        "id": "adaptive-claude-cline-profile",
        "enabled": true,
        "lazy": true,
        "script": "scripts/utilities/adaptive-claude-cline-profile.ps1",
        "args": "-Mode Auto -TimeZone \"Argentina Standard Time\" -PeakStart 9 -PeakEnd 15",
        "required": false,
        "description": "Intelligent temporary Claude Code/Cline optimization with automatic restore when normalized"
      },
      {
        "id": "lefthook-verify",
        "enabled": true,
        "script": "scripts/utilities/lefthook-verify.ps1",
        "args": "",
        "required": false,
        "description": "Verify Lefthook CLI + hooks are installed (post-commit/post-merge for CodeGraph auto-sync)"
      },
      {
        "id": "codegraph-sync",
        "enabled": true,
        "script": "scripts/utilities/codegraph-sync-autostart.ps1",
        "args": "",
        "required": false,
        "description": "Verify CodeGraph index freshness and sync if stale (>30min old)"
      },
      {
        "id": "self-diagnosis",
        "enabled": true,
        "lazy": true,
        "script": "scripts/utilities/self-diagnosis-autonomous.ps1",
        "args": "-Depth quick",
        "required": false,
        "description": "Proactive failure detection and autonomous learning capture"
      },
      {
        "id": "metrics-collection",
        "enabled": true,
        "lazy": true,
        "script": "scripts/metrics/collector.ps1",
        "args": "-Scope full -Quiet",
        "required": false,
        "description": "Auto-collect metrics after session start for live dashboard"
      },
      {
        "id": "dashboard-render",
        "enabled": true,
        "lazy": true,
        "script": "scripts/metrics/dashboard-render.ps1",
        "args": "",
        "required": false,
        "description": "Regenerate live HTML dashboard from latest metrics data"
      },
      {
        "id": "live-feed-start",
        "enabled": true,
        "lazy": true,
        "script": "scripts/utilities/live-feed-manager.ps1",
        "args": "-Action start -RefreshSeconds 15 -ServerPort 8090 -OpenDashboard",
        "required": false,
        "description": "Start live-feed + HTTP server + open dashboard in browser"
      },
      {
        "id": "post-autostart-summary",
        "enabled": true,
        "script": "scripts/utilities/post-autostart-summary.ps1",
        "args": "-TimeZone \"Argentina Standard Time\" -PeakStart 9 -PeakEnd 15 -Region \"Argentina\"",
        "required": false,
        "description": "Generate startup-summary.json with peak hour, session ID, workspace state"
      },
      {
        "id": "skill-usage-scan",
        "enabled": true,
        "script": "scripts/skills/usage-tracker.ps1",
        "args": "",
        "required": false,
        "description": "Inicializa/escanea métricas de uso de skills al inicio de sesion"
      },
      {
        "id": "skill-nudge-check",
        "enabled": false,
        "script": "scripts/skills/skill-nudge.ps1",
        "args": "-Report",
        "required": false,
        "description": "Reporta nudges pendientes de skills al inicio (desactivado por defecto, corre al cerrar)"
      },
      {
        "id": "skill-size-check",
        "enabled": true,
        "lazy": true,
        "script": "scripts/utilities/check-skill-sizes.ps1",
        "args": "-WarnOnly",
        "required": false,
        "description": "Audita skills que exceden limites de tokens/lineas y recomienda split a references/"
      },
      {
        "id": "post-autostart-consistency-check",
        "enabled": true,
        "script": "scripts/utilities/post-autostart-summary.ps1",
        "args": "",
        "required": false,
        "description": "Refresca startup-summary.json como ultimo paso para asegurar datos actuales post-pipeline"
      }
    ],

    "onStepFailure": "continue",
    "requiredStepFailureAction": "exit"
  },

  "notifications": {
    "timeZone": "Argentina Standard Time",
    "peakStart": 9,
    "peakEnd": 15,
    "region": "Argentina"
  },

  "sessionDirectory": ".session",
  "sessionFilePattern": "session-{date}-{number:D2}.json",
  "sessionExpiryHours": 8,

  "auth": {
    "integrateWithAutostart": false,
    "requireAuthForRestrictedOps": true,
    "sessionAuthFile": ".workspace/config/session-auth.json",
    "ownerAuthFile": "config/owner-auth.json",
    "lockoutFile": "config/owner-auth.json.lock",
    "encryptedAuthFile": "config/owner-auth.json.enc"
  },

  "orphanSessionCleanup": {
    "enabled": true,
    "maxAgeHours": 24,
    "statusesToClean": ["active", "orphaned", "ended"],
    "description": "Clean up sessions left in 'active' status after maxAgeHours (crash recovery)"
  }
}
