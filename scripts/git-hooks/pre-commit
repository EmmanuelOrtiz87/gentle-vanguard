#!/usr/bin/env bash
# pre-commit hook - Runs before every commit
# Install: ln -s ../../scripts/git-hooks/pre-commit .git/hooks/

set -e

echo "[pre-commit] Running checks..."

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Get staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
EXTENSIONS="ts tsx js jsx json md yaml yml ps1 sh go py"

# Check for debug code
echo "[pre-commit] Checking for debug code..."
DEBUG_PATTERNS="console\.log\|debugger\|TODO.*\|FIXME.*\|console\.debug"
for file in $STAGED_FILES; do
    if [[ -f "$file" ]]; then
        if grep -E "$DEBUG_PATTERNS" "$file" 2>/dev/null; then
            echo -e "${RED}[ERROR] Debug code found in: $file${NC}"
            echo -e "${YELLOW}Remove console.log, debugger, TODOs before committing${NC}"
            exit 1
        fi
    fi
done

# Check package.json integrity
if echo "$STAGED_FILES" | grep -q "package.json"; then
    echo "[pre-commit] Checking package.json..."
    if ! command -v npm &> /dev/null; then
        echo -e "${YELLOW}[WARN] npm not found, skipping package.json check${NC}"
    else
        npm run lint --silent 2>/dev/null || {
            echo -e "${RED}[ERROR] Linting failed${NC}"
            exit 1
        }
    fi
fi

# Check TypeScript files
TS_FILES=$(echo "$STAGED_FILES" | grep -E '\.(ts|tsx)$' || true)
if [[ -n "$TS_FILES" ]]; then
    echo "[pre-commit] Checking TypeScript..."
    if command -v npx &> /dev/null; then
        echo "$TS_FILES" | xargs npx tsc --noEmit --skipLibCheck 2>/dev/null || {
            echo -e "${RED}[ERROR] TypeScript check failed${NC}"
            exit 1
        }
    fi
fi

# Check Go files
GO_FILES=$(echo "$STAGED_FILES" | grep -E '\.go$' || true)
if [[ -n "$GO_FILES" ]]; then
    echo "[pre-commit] Checking Go..."
    if command -v go &> /dev/null; then
        go vet ./... 2>/dev/null || {
            echo -e "${RED}[ERROR] Go vet failed${NC}"
            exit 1
        }
    fi
fi

# Check for large files (>1MB)
echo "[pre-commit] Checking file sizes..."
MAX_SIZE=1048576  # 1MB
for file in $STAGED_FILES; do
    if [[ -f "$file" ]]; then
        SIZE=$(stat -f%z "$file" 2>/dev/null || stat -c%s "$file" 2>/dev/null || echo 0)
        if [[ $SIZE -gt $MAX_SIZE ]]; then
            echo -e "${RED}[ERROR] File too large (>1MB): $file${NC}"
            exit 1
        fi
    fi
done

# Check for sensitive data
echo "[pre-commit] Checking for secrets..."
SECRETS_PATTERNS="api[_-]?key.*=.*['\"][A-Za-z0-9]{20,}['\"]\|password.*=.*['\"][^'\"]{8,}['\"]\|secret.*=.*['\"][A-Za-z0-9]{20,}['\"]"
for file in $STAGED_FILES; do
    if [[ -f "$file" ]] && [[ ! "$file" =~ \.(env|example)$ ]]; then
        if grep -E "$SECRETS_PATTERNS" "$file" 2>/dev/null; then
            echo -e "${RED}[ERROR] Possible secret found in: $file${NC}"
            exit 1
        fi
    fi
done

# Check Markdown files
MD_FILES=$(echo "$STAGED_FILES" | grep -E '\.md$' || true)
if [[ -n "$MD_FILES" ]]; then
    echo "[pre-commit] Checking Markdown links..."
    for file in $MD_FILES; do
        if grep -E '\[.*\]\(.*\)' "$file" | grep -vE '\[.*\]\(https?://' 2>/dev/null; then
            echo -e "${YELLOW}[WARN] Check internal links in: $file${NC}"
        fi
    done
fi

echo -e "${GREEN}[pre-commit] All checks passed!${NC}"
exit 0
