{
  "version": "1.0.0",
  "description": "Testing policy for Foundation agent stack - pyramid, coverage, CI integration",
  "pyramid": {
    "unit": {
      "target_pct": 70,
      "description": "Tests without LLM calls - mocked responses, fast, deterministic",
      "coverage_target_pct": 80,
      "ci_frequency": "every_commit",
      "block_pr": true,
      "block_main": true
    },
    "integration": {
      "target_pct": 20,
      "description": "Tests with real LLM calls - cheap model in CI, full model pre-release",
      "coverage_target": "all_major_workflows",
      "ci_frequency": "merge_to_main",
      "cheap_model": "gpt-4o-mini",
      "temperature": 0,
      "retry_budget": 3,
      "block_pr": false,
      "block_main": true,
      "cost_tracking": true
    },
    "e2e": {
      "target_pct": 10,
      "description": "Golden dataset evaluations with LLM-as-judge",
      "coverage_target": "critical_user_journeys",
      "ci_frequency": "nightly_and_pre_release",
      "golden_dataset_path": "tests/e2e/golden-dataset.json",
      "judge_model": "claude-sonnet-4-20250514",
      "acceptance_bands": true,
      "dimensions": [
        "correctness",
        "safety",
        "format_compliance",
        "latency_p95",
        "robustness"
      ]
    }
  },
  "regression": {
    "trigger_on": [
      "prompt_change",
      "model_change",
      "rag_index_change",
      "tool_schema_change",
      "system_prompt_change"
    ],
    "feed_production_failures": true,
    "version_lock_dependencies": true
  },
  "quality_gates": {
    "lint": { "pr_block": true, "main_block": true, "frequency": "every_commit" },
    "unit_tests": { "pr_block": true, "main_block": true, "frequency": "every_pr" },
    "integration_tests": { "pr_block": false, "main_block": true, "frequency": "merge_main" },
    "coverage_drop": { "threshold_pct": 5, "pr_block": false, "main_block": true, "frequency": "merge_main" },
    "safety_regressions": { "pr_block": true, "main_block": true, "frequency": "every_pr" },
    "format_compliance": { "pr_block": true, "main_block": true, "frequency": "every_pr" },
    "cost_anomaly": { "pr_block": false, "main_block": false, "frequency": "nightly" }
  },
  "structure": {
    "test_directories": [
      "tests/unit",
      "tests/integration",
      "tests/e2e",
      "tests/fixtures"
    ],
    "naming_convention": "<component>.<type>.tests.{ps1,py}",
    "unit_suffix": "unit",
    "integration_suffix": "integration",
    "fixtures_path": "tests/fixtures/"
  },
  "llm_as_judge": {
    "enabled": true,
    "rubric_required": true,
    "dimensions": [
      "correctness",
      "safety",
      "format_compliance",
      "latency_p95",
      "robustness"
    ],
    "acceptance_bands": true,
    "human_review_sample_pct": 5
  },
  "norms": {
    "document": "docs/NORMATIVAS-TESTING.md"
  }
}
