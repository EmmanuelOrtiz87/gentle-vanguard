{
  "version": "1.0",
  "description": "Mapa de frameworks de razonamiento (cc-thinking-skills + pre-mortem) a fases SDD",
  "phases": {
    "INIT": {
      "agent": "BA",
      "frameworks": [],
      "note": "Fase bootstrap — no requiere framework de razonamiento"
    },
    "EXPLORE": {
      "agent": "BA",
      "frameworks": [
        {
          "skill": "cynefin-skill",
          "purpose": "Classificar complejidad del dominio del problema antes de explorar",
          "triggers": ["problem domain unclear", "unknown complexity", "complicated vs complex"],
          "applyBefore": ["socratic-skill"]
        },
        {
          "skill": "socratic-skill",
          "purpose": "Cuestionar supuestos del usuario y sondear requisitos ocultos",
          "triggers": ["vague requirements", "assumptions need probing", "uncover hidden needs"],
          "applyAfter": ["cynefin-skill"]
        }
      ]
    },
    "PROPOSE": {
      "agent": "SAD",
      "frameworks": [
        {
          "skill": "first-principles-skill",
          "purpose": "Descomponer el problema hasta fundamentos antes de proponer soluciones",
          "triggers": ["complex proposal", "need fundamental reasoning", "break down problem"],
          "applyBefore": ["systems-thinking-skill"]
        },
        {
          "skill": "systems-thinking-skill",
          "purpose": "Analizar interconexiones y comportamiento emergente de la solución propuesta",
          "triggers": ["system impact", "interconnections", "emergent behavior"],
          "applyAfter": ["first-principles-skill"]
        }
      ]
    },
    "SPEC": {
      "agent": "SAD",
      "frameworks": [
        {
          "skill": "inversion-skill",
          "purpose": "Pensar al revés: qué haría que la spec falle, escribir criterios que lo prevengan",
          "triggers": ["edge cases", "failure scenarios", "complete spec"],
          "applyBefore": ["bdd-scenarios-skill"]
        }
      ]
    },
    "DESIGN": {
      "agent": "SAD",
      "frameworks": [
        {
          "skill": "second-order-skill",
          "purpose": "Evaluar efectos secundarios y consecuencias no intencionadas del diseño",
          "triggers": ["design decisions", "architecture choices", "ripple effects"],
          "applyBefore": ["leverage-points-skill"]
        },
        {
          "skill": "leverage-points-skill",
          "purpose": "Identificar puntos de apalancamiento donde pequeños cambios tienen gran impacto",
          "triggers": ["optimization", "high impact change", "where to intervene"],
          "applyAfter": ["second-order-skill"]
        },
        {
          "skill": "feedback-loops-skill",
          "purpose": "Modelar bucles de retroalimentación en el diseño del sistema",
          "triggers": ["system dynamics", "feedback", "balancing loops"],
          "applyAfter": ["leverage-points-skill"]
        }
      ]
    },
    "TASKS": {
      "agent": "DEV",
      "frameworks": [
        {
          "skill": "fermi-skill",
          "purpose": "Estimar esfuerzo de tareas con aproximaciones de orden de magnitud",
          "triggers": ["effort estimation", "task sizing", "order of magnitude"],
          "applyBefore": ["writing-plans-skill"]
        },
        {
          "skill": "writing-plans-skill",
          "purpose": "Crear plan detallado de implementación con dependencias y orden",
          "triggers": ["implementation plan", "task breakdown", "plan tasks"],
          "applyAfter": ["fermi-skill"]
        }
      ]
    },
    "APPLY": {
      "agent": "DEV",
      "frameworks": [
        {
          "skill": "ooda-loop-skill",
          "purpose": "Iteración rápida: observar, orientar, decidir, actuar por cada micro-tarea",
          "triggers": ["rapid iteration", "implementation cycle", "apply code"],
          "applyBefore": ["systematic-debugging-skill"]
        },
        {
          "skill": "systematic-debugging-skill",
          "purpose": "Debugging sistemático cuando algo falla durante implementación",
          "triggers": ["bug", "error", "debug", "investigate fix verify defend"],
          "applyAfter": ["ooda-loop-skill"]
        },
        {
          "skill": "executing-plans-skill",
          "purpose": "Ejecutar plan con batch processing y checkpoints",
          "triggers": ["execute plan", "batch tasks", "checkpoint"],
          "applyAfter": ["ooda-loop-skill"]
        },
        {
          "skill": "subagent-driven-dev-skill",
          "purpose": "Delegar tareas complejas a sub-agentes con contexto fresco",
          "triggers": ["complex task", "subagent delegation", "fresh context per task"],
          "applyAfter": ["executing-plans-skill"]
        }
      ]
    },
    "VERIFY": {
      "agent": "QA",
      "frameworks": [
        {
          "skill": "red-team-skill",
          "purpose": "Revisión adversaria de la implementación contra la spec",
          "triggers": ["adversarial review", "security review", "stress test implementation"],
          "applyBefore": ["five-whys-skill"]
        },
        {
          "skill": "five-whys-skill",
          "purpose": "Análisis de causa raíz de defectos encontrados",
          "triggers": ["root cause", "defect analysis", "why analysis"],
          "applyAfter": ["red-team-skill"]
        },
        {
          "skill": "debiasing-skill",
          "purpose": "Identificar sesgos cognitivos en la revisión",
          "triggers": ["review bias", "confirmation bias", "objective verification"],
          "applyAfter": ["five-whys-skill"]
        }
      ]
    },
    "ARCHIVE": {
      "agent": "DOC",
      "frameworks": [
        {
          "skill": "feedback-loops-skill",
          "purpose": "Capturar dinámicas del sistema aprendidas durante el ciclo",
          "triggers": ["lessons learned", "system dynamics", "retrospective"],
          "applyBefore": []
        },
        {
          "skill": "bayesian-skill",
          "purpose": "Actualizar creencias con evidencia del ciclo completado",
          "triggers": ["belief update", "evidence based", "posterior analysis"],
          "applyAfter": ["feedback-loops-skill"]
        }
      ]
    }
  },
  "crossCutting": {
    "model-router-skill": {
      "purpose": "Seleccionar el framework de razonamiento correcto para cada fase",
      "triggers": ["which framework", "thinking model", "reasoning approach"],
      "applyTo": ["ALL_PHASES"]
    },
    "premortem-skill": {
      "purpose": "Análisis pre-mortem antes de comenzar fases críticas (SPEC, APPLY)",
      "triggers": ["risk analysis", "what could go wrong", "failure mode"],
      "applyTo": ["SPEC", "APPLY"],
      "agent": "QA"
    }
  }
}
