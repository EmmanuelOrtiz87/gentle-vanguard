{
  "enabled": true,
  "version": "1.0",
  "automation_rules": {
    "pre_push": {
      "enabled": true,
      "description": "Run Judgment Day before git push",
      "trigger": "pre-push hook",
      "scope": "changed_files",
      "require_approval": true,
      "fail_on_critical": true,
      "max_iterations": 2
    },
    "pre_merge": {
      "enabled": true,
      "description": "Run Judgment Day before PR merge",
      "trigger": "pre-merge-commit hook",
      "scope": "pr_files",
      "require_approval": true,
      "require_both_reviewers": true,
      "fail_on_critical": true,
      "fail_on_real_warnings": true,
      "max_iterations": 2
    },
    "session_start": {
      "enabled": true,
      "description": "Initialize Judgment Day orchestration on session start",
      "trigger": "session-autostart",
      "action": "register_hooks",
      "setup_git_integration": true
    }
  },
  "reviewer_requirements": {
    "require_both_reviewers": true,
    "reviewer_approval_threshold": 2,
    "allow_self_approval": false,
    "approval_comment_pattern": "LGTM|Approved|✅"
  },
  "pr_merge_policy": {
    "block_on_judgment_failure": true,
    "require_judgment_approval": true,
    "auto_label_judgment_status": true,
    "labels": {
      "judgment_approved": "judgment-day-approved",
      "judgment_failed": "judgment-day-failed",
      "judgment_pending": "judgment-day-pending"
    }
  },
  "orchestrator_integration": {
    "enabled": true,
    "auto_detect_pr": true,
    "auto_detect_branch": true,
    "coordinate_with_ci": true,
    "fail_ci_on_judgment_failure": true,
    "report_to_event_bus": true
  },
  "logging": {
    "enabled": true,
    "log_path": ".session/judgment-day-logs",
    "log_level": "INFO",
    "archive_after_days": 7
  }
}