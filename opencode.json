{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "openrouter": {
      "options": {
        "setCacheKey": true,
        "timeout": 600000
      }
    },
    "anthropic": {
      "options": {
        "setCacheKey": true,
        "timeout": 600000
      }
    }
  },
  "agent": {
    "default": {
      "model": "anthropic/claude-sonnet-4-5",
      "options": {
        "minTokens": 2000,
        "maxTokens": 4500
      },
      "permission": {
        "websearch": "deny",
        "codesearch": "deny",
        "webfetch": "deny"
      }
    },
    "orchestrator": {
      "model": "anthropic/claude-sonnet-4-5",
      "options": {
        "minTokens": 2000,
        "maxTokens": 4500
      },
      "permission": {
        "websearch": "allow",
        "codesearch": "allow",
        "webfetch": "allow"
      }
    }
  }
}
