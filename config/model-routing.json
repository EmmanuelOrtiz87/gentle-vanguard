{
  "version": "1.1.0",
  "description": "Model routing per agent — assigns specific models and effort levels to gentle-vanguard agents",
  "routing_thresholds": {
    "fast_cheap_to_strong_reasoning": {
      "description": "Escalate to strong reasoning when task complexity exceeds threshold",
      "text_length_chars": 10000,
      "item_count": 30,
      "indicators": ["architectural decision", "security review", "data model design"]
    },
    "retry_strategy": {
      "transient_errors": ["APIConnectionError", "RateLimitError", "InternalServerError"],
      "fail_fast_errors": ["AuthenticationError", "BadRequestError", "NotFoundError"],
      "max_retries": 3,
      "backoff_ms": 1000
    }
  },
  "cost_tracking": {
    "enabled": true,
    "immutable": true,
    "budget_limits": {
      "daily_tokens": 30000,
      "per_session_tokens": 15000,
      "hard_cap_enabled": true
    },
    "tracking_level": "per_call"
  },
  "defaults": {
    "model": "inherit",
    "thinking": "inherit"
  },
  "agents": {
    "BA": {
      "model": "fast-cheap",
      "thinking": "off",
      "rationale": "BA explores and asks questions — fast model is sufficient"
    },
    "SAD": {
      "model": "strong-reasoning",
      "thinking": "high",
      "rationale": "SAD makes architectural decisions — needs strong reasoning"
    },
    "DEV": {
      "model": "strong-coding",
      "thinking": "medium",
      "rationale": "DEV writes code — needs strong coding + tool-use model"
    },
    "QA": {
      "model": "strong-review",
      "thinking": "high",
      "rationale": "QA reviews and validates — fresh-context model required"
    },
    "OPS": {
      "model": "fast-cheap",
      "thinking": "off",
      "rationale": "OPS runs commands and validates config — speed over reasoning"
    },
    "GOV": {
      "model": "strong-review",
      "thinking": "high",
      "rationale": "GOV audits security/compliance — needs thorough reasoning"
    },
    "DOC": {
      "model": "fast-cheap",
      "thinking": "low",
      "rationale": "DOC writes docs — clarity over compute"
    },
    "SESSION": {
      "model": "fast-cheap",
      "thinking": "off",
      "rationale": "Session management is deterministic state tracking"
    },
    "PREMORTEM": {
      "model": "strong-reasoning",
      "thinking": "high",
      "rationale": "Premortem needs creative scenario generation + structured synthesis"
    },
    "MKT": {
      "model": "fast-cheap",
      "thinking": "low",
      "rationale": "Marketing content — creativity over compute"
    },
    "SALES": {
      "model": "fast-cheap",
      "thinking": "low",
      "rationale": "Sales methodology — structured but not compute-heavy"
    },
    "FINANCE": {
      "model": "strong-reasoning",
      "thinking": "medium",
      "rationale": "Finance models need precision"
    },
    "HR": {
      "model": "fast-cheap",
      "thinking": "low",
      "rationale": "HR processes — structured templates"
    },
    "LEGAL": {
      "model": "strong-review",
      "thinking": "high",
      "rationale": "Legal compliance is non-negotiable — thorough review needed"
    },
    "SELF-DIAG": {
      "model": "fast-cheap",
      "thinking": "off",
      "rationale": "Self-diagnosis is quick checks"
    },
    "BUS-TELE": {
      "model": "fast-cheap",
