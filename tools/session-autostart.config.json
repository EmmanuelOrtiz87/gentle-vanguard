{
  "defaultMode": "full",
  "detailedOnStartup": false,
  "runDemoOnFull": false,
  "primaryRuntime": "opencode",
  "autoStartGentleAi": false,
  "fallbackToStack": true,
  "enableIdleAutoClose": true,
  "idleTimeoutMinutes": 60,
  "strictCompatibilityChecks": true,
  "optimization": {
    "handoffCompress": true,
    "preCompactHook": "tools/pre-compact-hook.ps1",
    "compressionRatio": 0.90,
    "adaptiveSkills": true,
    "tieredMemory": true,
    "engramOptimization": "tools/optimize-engram-usage.ps1",
    "autoEngramContext": true,
    "autoCompactStart": true,
    "compactStartThreshold": 50
  },
  "deprecated": {
    "note": "gentle-ai, GGA, Gentleman-Skills are DEPRECATED. Use opencode + 7-dimension review."
  },
  "contextEfficiency": {
    "targetPercentage": 70,
    "autoCompactionThreshold": 15000,
    "reduceRedundancy": true,
    "referenceInsteadOfRepeat": true,
    "forceCompactOnStartup": true
  },
  "tokenGuard": {
    "enabled": true,
    "autoStart": true,
    "configPath": "tools/token-guard-config.json",
    "tokenBudget": 128000,
    "alertThreshold": 0.80,
    "pauseThreshold": 0.95,
    "maxRounds": 5,
    "roundTokenBudget": 25600,
    "enableFragmentation": true,
    "enableAutoDispatchPause": true,
    "enableAlerts": true,
    "monitoring": {
      "enableRealTimeTracking": true,
      "enableDetailedLogging": true
    },
    "alerting": {
      "alertAt80Percent": true,
      "alertAt90Percent": true,
      "alertAt95Percent": true,
      "pauseAt95Percent": true
    },
    "fragmentation": {
      "strategy": "round-robin",
      "autoRestartOnCompletion": true
    },
    "dispatch": {
      "autoResume": true,
      "resumeThreshold": 0.70,
      "pauseOnCritical": true
    }
  }
}
