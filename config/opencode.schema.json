{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpenCode Configuration Schema",
  "description": "Esquema de validación para opencode.json - Configuración centralizada de Gentle-Vanguard",
  "type": "object",
  "required": ["provider", "agent", "skills"],
  "properties": {
    "provider": {
      "type": "object",
      "description": "Configuración de proveedores de IA",
      "required": ["anthropic"],
      "properties": {
        "anthropic": {
          "type": "object",
          "description": "Configuración de Anthropic Claude",
          "required": ["enabled", "model"],
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Habilitar proveedor Anthropic"
            },
            "model": {
              "type": "string",
              "description": "Modelo de Claude a utilizar",
              "pattern": "^claude-3-[0-9a-z-]+$"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "agent": {
      "type": "object",
      "description": "Configuración de agentes",
      "required": ["default", "orchestrator"],
      "properties": {
        "default": {
          "oneOf": [
            {
              "type": "string",
              "description": "Nombre del agente por defecto",
              "minLength": 1
            },
            {
              "type": "object",
              "description": "Configuración del agente por defecto",
              "required": ["name"],
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Nombre del agente",
                  "minLength": 1
                },
                "config": {
                  "type": "object",
                  "description": "Configuración adicional del agente"
                }
              },
              "additionalProperties": false
            }
          ]
        },
        "orchestrator": {
          "oneOf": [
            {
              "type": "string",
              "description": "Nombre del agente orquestador",
              "minLength": 1
            },
            {
              "type": "object",
              "description": "Configuración del agente orquestador",
              "required": ["name"],
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Nombre del agente",
                  "minLength": 1
                },
                "config": {
                  "type": "object",
                  "description": "Configuración adicional del agente"
                }
              },
              "additionalProperties": false
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "skills": {
      "type": "object",
      "description": "Configuración de skills",
      "required": ["directory", "auto_load"],
      "properties": {
        "directory": {
          "type": "string",
          "description": "Directorio de skills",
          "minLength": 1
        },
        "auto_load": {
          "type": "boolean",
          "description": "Cargar skills automáticamente"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
