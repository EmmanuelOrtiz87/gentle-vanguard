{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "openrouter": {
      "options": {
        "setCacheKey": true,
        "timeout": 600000
      }
    },
    "anthropic": {
      "options": {
        "setCacheKey": true,
        "timeout": 600000
      }
    }
  },
  "agent": {
    "default": {
      "model": "anthropic/claude-sonnet-4-5",
      "options": {
        "minTokens": 2000,
        "maxTokens": 4500,
        "temperature": 0.3,
        "language": "es"
      },
      "permission": {
        "websearch": "deny",
        "codesearch": "deny",
        "webfetch": "deny"
      },
      "routing": {
        "preProcess": "scripts/utilities/pre-process-input.ps1",
        "mappings": "config/auto-delegation.json#keywordMappings",
        "agentProfiles": "config/auto-delegation.json#agentProfiles",
        "fallbackStrategy": "clarify-ba"
      }
    },
    "orchestrator": {
      "model": "anthropic/claude-sonnet-4-5",
