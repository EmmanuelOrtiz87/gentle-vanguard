{
  "_comment": "Pester code coverage thresholds and declared workflow targets",
  "version": "1.0.0",
  "minimumCoverage": 85,
  "thresholds": {
    "lines": 70,
    "functions": 75,
    "branches": 65
  },
  "coverageTargets": [
    {
      "name": "session-manager-critical-workflow",
      "threshold": 85,
      "tests": ["tests/integration/engram-session-persistence.integration.tests.ps1"],
      "scripts": ["scripts/utilities/SESSION/session-manager.ps1"]
    },
    {
      "name": "post-session-learning-persistence",
      "threshold": 85,
      "tests": [
        "tests/integration/engram-session-persistence.integration.tests.ps1",
        "tests/integration/post-session-learning.integration.tests.ps1"
      ],
      "scripts": ["scripts/utilities/ENGRAM/post-session-learning.ps1"]
    },
    {
      "name": "session-autostart-critical-workflow",
      "threshold": 85,
      "tests": ["tests/integration/session-autostart.integration.tests.ps1"],
      "scripts": ["scripts/utilities/SESSION/session-autostart.ps1"]
    },
    {
      "name": "detect-tool-critical-workflow",
      "threshold": 85,
      "tests": ["tests/integration/detect-tool.integration.tests.ps1"],
      "scripts": ["scripts/utilities/DETECT/detect-tool.ps1"]
    },
    {
      "name": "pre-close-validator-critical-workflow",
      "threshold": 70,
      "tests": ["tests/integration/pre-close-validator.integration.tests.ps1"],
      "scripts": ["scripts/utilities/GUARD/pre-close-validator.ps1"]
    }
  ],
  "include": ["scripts/**/*.ps1"],
  "exclude": [
    "scripts/setup-complete.ps1",
    "scripts/run-tests-simple.ps1",
    "scripts/testing/run-tests.ps1",
    "build/**",
    "bin/**"
  ],
  "outputDir": "tests/coverage",
  "reportFormats": ["JaCoCo"],
  "_notes": {
    "thresholds": "Set conservatively at start; raise by 5% each quarter",
    "target_2026_Q3": {
      "lines": 75,
      "functions": 80,
      "branches": 70
    },
    "target_2026_Q4": {
      "lines": 80,
      "functions": 85,
      "branches": 75
    }
  }
}
