{
  "version": "1.0.0",
  "name": "code-review-orchestrator",
  "description": "Configuration for Code Review Orchestrator",

  "review": {
    "scope": {
      "default": "all",
      "available": [
        "all",
        "security",
        "quality",
        "architecture",
        "testing",
        "docs",
        "api",
        "git",
        "quick",
        "full"
      ]
    },
    "output": {
      "path": "docs/code-reviews",
      "format": "markdown",
      "includeTimestamp": true,
      "includeStats": true
    }
  },

  "skills": {
    "security-expert-skill": {
      "enabled": true,
      "order": 1,
      "checks": ["secrets", "vulnerabilities", "dependencies"]
    },
    "testing-skill": {
      "enabled": true,
      "order": 2,
      "checks": ["coverage", "patterns", "organization"]
    },
    "architecture-governance": {
      "enabled": true,
      "order": 3,
      "checks": ["structure", "patterns", "modularity"]
    },
    "documentation-governance": {
      "enabled": true,
      "order": 4,
      "checks": ["readme", "api-docs", "inline-comments"]
    },
    "api-design-skill": {
      "enabled": true,
      "order": 5,
      "checks": ["rest-compliance", "validation", "errors"]
    },
    "git-workflow-skill": {
      "enabled": true,
      "order": 6,
      "checks": ["commits", "branches", "hooks"]
    },
    "docker-devops-skill": {
      "enabled": true,
      "order": 7,
      "checks": ["dockerfile", "docker-compose", "ci-cd"]
    }
  },

  "severity": {
    "critical": {
      "action": "block",
      "exitCode": 1,
      "threshold": 0,
      "autoFix": false
    },
    "high": {
      "action": "warn",
      "exitCode": 0,
      "threshold": 0,
      "autoFix": false
    },
    "medium": {
      "action": "info",
      "exitCode": 0,
      "threshold": 10,
      "autoFix": false
    },
    "low": {
      "action": "info",
      "exitCode": 0,
      "threshold": 20,
      "autoFix": false
    }
  },

  "exclusions": {
    "paths": [
      "**/node_modules/**",
      "**/dist/**",
      "**/build/**",
      "**/coverage/**",
      "**/.git/**",
      "**/vendor/**",
      "**/__pycache__/**",
      "**/venv/**",
      "**/.venv/**",
      "**/test*/**",
      "**/*.test.*",
      "**/*.spec.*",
      "**/mocks/**",
      "**/*.min.js"
    ],
    "filePatterns": ["\\.min\\.(js|css)$", "\\.bundle\\.js$", "\\.compiled\\.ts$"]
  },

  "thresholds": {
    "testCoverage": {
      "minimum": 70,
      "warning": 50
    },
    "documentation": {
      "requireReadme": true,
      "requireChangelog": false,
      "requireArchitecture": true
    },
    "complexity": {
      "maxFunctionLength": 100,
      "maxFileLength": 500,
      "maxCyclomaticComplexity": 10
    }
  },

  "patterns": {
    "codeQuality": [
      {
        "id": "console-log",
        "pattern": "console\\.(log|debug|info)",
        "severity": "low",
        "message": "Console logging found in code"
      },
      {
        "id": "empty-catch",
        "pattern": "catch\\s*\\([^)]*\\)\\s*\\{\\s*\\}",
        "severity": "medium",
        "message": "Empty catch block suppresses errors"
      },
      {
        "id": "sync-in-async",
        "pattern": "async\\s+function[^}]*readFileSync",
        "severity": "high",
        "message": "Synchronous operation in async function"
      },
      {
        "id": "todo",
        "pattern": "(?i)(TODO|FIXME|HACK):",
        "severity": "low",
        "message": "TODO comment needs tracking"
      }
    ],
    "security": [
      {
        "id": "hardcoded-secret",
        "pattern": "(?i)(password|secret|key|token)\\s*[=:]\\s*['\"][^'\"]{8,}['\"]",
        "severity": "critical",
        "message": "Hardcoded secret detected"
      }
    ]
  },

  "interactive": {
    "enabled": true,
    "showDescriptions": true,
    "showFixSuggestions": true,
    "allowSkip": true,
    "requireJustification": true,
    "createIssues": true
  },

  "issueTracker": {
    "enabled": true,
    "format": "markdown",
    "csvExport": true,
    "jiraIntegration": false
  },

  "reporting": {
    "console": {
      "colorEnabled": true,
      "showProgress": true,
      "verboseOutput": false
    },
    "file": {
      "enabled": true,
      "path": "docs/code-reviews",
      "filenamePattern": "{date}-{scope}-review.md"
    }
  }
}
