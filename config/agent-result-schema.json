{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Result Schema",
  "description": "Structured output schema for sub-agent execution results",
  "type": "object",
  "required": ["agent_id", "status", "task", "timestamp"],
  "properties": {
    "agent_id": {
      "type": "string",
      "description": "Agent identifier (BA, SAD, DEV, QA, OPS, GOV, DOC)",
      "enum": ["BA", "SAD", "DEV", "QA", "OPS", "GOV", "DOC"]
    },
    "agent_name": {
      "type": "string",
      "description": "Human-readable agent name"
    },
    "status": {
      "type": "string",
      "description": "Execution status",
      "enum": ["success", "partial", "failed", "skipped", "timeout"]
    },
    "task": {
      "type": "string",
      "description": "Original task description"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of completion"
    },
    "duration_ms": {
      "type": "integer",
      "description": "Execution duration in milliseconds"
    },
    "deliverables": {
      "type": "array",
      "description": "List of deliverables produced",
      "items": {
        "type": "object",
        "required": ["type", "path"],
        "properties": {
          "type": { "type": "string" },
          "path": { "type": "string" },
          "status": { "type": "string", "enum": ["created", "updated", "unchanged"] }
        }
      }
    },
    "summary": {
      "type": "string",
      "description": "Executive summary of what was done"
    },
    "details": {
      "type": "string",
      "description": "Detailed description of changes made"
    },
    "metrics": {
      "type": "object",
      "properties": {
        "tokens_used": { "type": "integer" },
        "files_touched": { "type": "integer" },
        "lines_added": { "type": "integer" },
        "lines_deleted": { "type": "integer" }
      }
    },
    "issues": {
      "type": "array",
      "description": "Issues encountered during execution",
      "items": {
        "type": "object",
        "properties": {
          "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
          "message": { "type": "string" },
          "resolution": { "type": "string" }
        }
      }
    },
    "next_steps": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Confidence score for the result quality"
    }
  }
}
