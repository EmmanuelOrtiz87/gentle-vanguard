{
  "mission": {
    "name": "Foundation Multi-Agent Mission",
    "max_agents": 5,
    "timeout": 7200
  },
  "agents": [
    {
      "role": "orchestrator",
      "model": "gemini-3-pro",
      "instructions": "Coordinate overall execution, decompose tasks, manage quality. Use Foundation skills for task execution.",
      "tools": ["task_manager", "status_monitor", "skill_loader"]
    },
    {
      "role": "frontend",
      "model": "gemini-3-pro",
      "instructions": "Implement UI components using react-19-skill or angular-spa-skill",
      "depends_on": ["orchestrator"],
      "tools": ["file_writer", "code_executor", "browser_tester"]
    },
    {
      "role": "backend",
      "model": "gemini-3-pro",
      "instructions": "Implement API endpoints using go-api or django-drf-skill",
      "depends_on": ["orchestrator"],
      "tools": ["file_writer", "terminal", "database_client"]
    },
    {
      "role": "tester",
      "model": "gemini-3-flash",
      "instructions": "Write and execute tests using testing-skill",
      "depends_on": ["frontend", "backend"],
      "tools": ["test_runner", "coverage_analyzer"]
    },
    {
      "role": "reviewer",
      "model": "gemini-3-pro",
      "instructions": "Perform code review using code-review plugin",
      "depends_on": ["frontend", "backend"],
      "tools": ["diff_viewer", "static_analyzer"]
    }
  ],
  "parallel_groups": [
    {
      "name": "Independent Development",
      "agents": ["frontend", "backend"],
      "strategy": "parallel"
    },
    {
      "name": "Quality Assurance",
      "agents": ["tester", "reviewer"],
      "strategy": "parallel"
    }
  ]
}
