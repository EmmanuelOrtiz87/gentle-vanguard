{
  "scripts": {
    "test": "pwsh ./scripts/run-tests-simple.ps1",
    "lint:json": "pwsh ./hooks/json-lint.ps1",
    "lint:workflows": "pwsh ./hooks/workflow-lint.ps1",
    "format:check": "npx prettier --check \"**/*.{md,json,yml,yaml,ps1}\" --ignore-path .gitignore",
    "format:fix": "npx prettier --write \"**/*.{md,json,yml,yaml,ps1}\" --ignore-path .gitignore",
    "prepare": "npx lefthook install"
  },
  "devDependencies": {
    "lefthook": "^2.1.6",
    "prettier": "^3.0.0"
  }
}
