{
  "name": "Windsurf - Local-First Configuration",
  "version": "1.0.0",
  "description": "Local-first policy for Windsurf IDE with tool restrictions",
  "workspace": {
    "projectRoot": ".",
    "configFiles": ["opencode.json", "AGENTS.md", "CLAUDE.md", ".cursorrules"],
    "skillPaths": ["skills/", "~/.config/opencode/skills/"]
  },
  "aiSettings": {
    "model": "opencode/claude-sonnet-4-5",
    "temperature": 0.3,
    "maxTokens": 4500,
    "localFirst": true
  },
  "toolPermissions": {
    "websearch": "deny",
    "codesearch": "deny",
    "webfetch": "deny",
    "note": "External tools only available via orchestrator agent"
  },
  "contextManagement": {
    "useEngramMemory": true,
    "useLocalSkills": true,
    "useProjectDocs": true,
    "compressionRatio": 0.9,
    "memoryTiering": {
      "hot": "active session",
      "warm": "1 day",
      "cold": "7 days"
    }
  },
  "mcpServers": {
    "context7": {
      "enabled": false,
      "note": "Enable only when local skills insufficient"
    }
  },
  "governanceLayers": {
    "GOV": ["project-orchestrator-skill"],
    "SAD": ["sdd-design"],
    "DEV": ["sdd-apply"],
    "QA": ["sdd-verify"],
    "OPS": ["docker-devops-skill"],
    "DOC": ["documentation-governance"],
    "SCRIPT-GOV": ["sdd-apply"],
    "REPORT": ["management-reporting-skill"]
  },
  "gitflowCapabilities": {
    "branch": ["create-gitflow-branch.ps1"],
    "pr": ["create-pull-request.ps1"],
    "hooks": ["pre-commit-validation.ps1"],
    "merge": ["post-merge-sync.ps1"],
    "workflow": ["git-workflow-skill"],
    "commit": ["git-workflow-skill"],
    "conflict": ["git-workflow-skill"]
  },
  "preProcessing": {
    "enabled": true,
    "mandatory": true,
    "script": "scripts/utilities/pre-process-input.ps1",
    "scriptArgs": {
      "UserInput": "USER_INPUT_HERE",
      "WorkspaceRoot": "."
    },
    "fallbackBehavior": "continue"
  },
  "sessionManagement": {
    "autostart": {
      "enabled": true,
      "script": "scripts/utilities/session-autostart.cmd",
      "platform": "windows",
      "alternatives": {
        "linux": "bash ./scripts/utilities/session-autostart.sh",
        "macos": "bash ./scripts/utilities/session-autostart.sh"
      }
    },
    "tracking": {
      "project": "foundation",
      "directory": ".",
      "sessionIdPattern": "session-YYYY-MM-DD-XX"
    }
  },
  "language": {
    "default": "es",
    "technicalTerms": "en",
    "responseStyle": "concise, direct, <4 lines"
  },
  "cascade": {
    "restrictToLocal": true,
    "allowExternalTools": false
  }
}
