{
  "documentation": {
    "version": "1.0",
    "lastUpdated": "2026-04-22",
    "governance": {
      "essentialGuides": [
        {
          "file": "docs/guides/README.md",
          "purpose": "Navigation hub",
          "maxLines": 500,
          "category": "navigation"
        },
        {
          "file": "docs/guides/GETTING-STARTED.md",
          "purpose": "New user entry point",
          "maxLines": 1500,
          "category": "guide"
        },
        {
          "file": "docs/guides/GITFLOW-WORKFLOW.md",
          "purpose": "GitFlow workflow guide",
          "maxLines": 1500,
          "category": "guide"
        },
        {
          "file": "docs/guides/SCRIPT-STANDARDS.md",
          "purpose": "Script normalization standards",
          "maxLines": 2000,
          "category": "standard"
        },
        {
          "file": "docs/guides/AI-TOOLS-INTEGRATION.md",
          "purpose": "AI tool integration guide",
          "maxLines": 2000,
          "category": "guide"
        },
        {
          "file": "docs/guides/TROUBLESHOOTING.md",
          "purpose": "Common issues and solutions",
          "maxLines": 1500,
          "category": "reference"
        },
        {
          "file": "docs/architecture/OVERVIEW.md",
          "purpose": "System architecture overview",
          "maxLines": 2000,
          "category": "architecture"
        },
        {
          "file": "docs/architecture/COMPONENTS.md",
          "purpose": "Component descriptions",
          "maxLines": 2000,
          "category": "architecture"
        },
        {
          "file": "docs/architecture/MESSAGE-FORMATS.md",
          "purpose": "Message protocol definitions",
          "maxLines": 1500,
          "category": "api"
        },
        {
          "file": "docs/DOCUMENTATION-STANDARDS.md",
          "purpose": "Documentation standards",
          "maxLines": 2000,
          "category": "standard"
        }
      ],
      "redundantDocuments": [
        "docs/guides/GITHUB-ACTIONS-TROUBLESHOOTING.md",
        "docs/guides/PRE-DEPLOYMENT-CHECKLIST.md",
        "docs/guides/DEPLOYMENT-OPTIMIZATION-GUIDE.md",
        "docs/guides/REMAINING-SCRIPTS-TO-FIX.md",
        "docs/guides/QUICK-FIX-GUIDE.md",
        "docs/guides/SCRIPT-NORMALIZATION-COMPLETION-REPORT.md"
      ],
      "autoGeneratedReports": ["docs/audit/*.md", "docs/reports/*.md", "docs/metrics/*.md"],
      "rules": {
        "maxFileSize": 2000,
        "requirePurpose": true,
        "requireExamples": true,
        "requireLinks": true,
        "noDuplication": true,
        "noTemporaryInfo": true,
        "noOutdatedContent": true
      },
      "maintenance": {
        "monthlyReview": {
          "checkDuplicates": true,
          "updateOutdated": true,
          "verifyLinks": true,
          "reviewSizes": true
        },
        "quarterlyAudit": {
          "consolidateRedundant": true,
          "archiveOldVersions": true,
          "updateExamples": true,
          "verifyCompleteness": true
        }
      }
    },
    "categories": {
      "navigation": {
        "description": "Navigation and index files",
        "maxFiles": 2
      },
      "guide": {
        "description": "User guides and how-to documents",
        "maxFiles": 10
      },
      "standard": {
        "description": "Standards and best practices",
        "maxFiles": 5
      },
      "architecture": {
        "description": "Architecture and design documents",
        "maxFiles": 5
      },
      "api": {
        "description": "API and protocol documentation",
        "maxFiles": 3
      },
      "reference": {
        "description": "Reference and troubleshooting",
        "maxFiles": 3
      }
    },
    "automation": {
      "validator": "skills/documentation-manager.ps1",
      "actions": ["validate", "consolidate", "cleanup", "audit"],
      "schedule": {
        "validation": "on-commit",
        "consolidation": "weekly",
        "cleanup": "monthly",
        "audit": "quarterly"
      }
    }
  }
}
