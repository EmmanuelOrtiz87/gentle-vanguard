{
  "version": "1.0.0",
  "description": "OWASP-aligned security controls for Gentle-Vanguard LLM agents",
  "framework": "OWASP LLM Top 10 2025 + OWASP Agentic Top 10 2026",
  "prompt_injection": {
    "treat_external_input_as_untrusted": true,
    "sanitize_before_context_injection": true,
    "use_delimiters_between_instructions_and_data": true,
    "separate_llm_for_untrusted_validation": true,
    "content_filtering_for_injection_patterns": true
  },
  "excessive_agency": {
    "least_privilege_tools": true,
    "per_tool_permission_scoping": true,
    "human_in_the_loop_high_impact": true,
    "separate_tool_sets_by_trust_level": true,
    "per_tool_rate_limiting": true,
    "tool_call_audit_logging": true
  },
  "sensitive_information_disclosure": {
    "no_secrets_in_logs": true,
    "pii_redaction_before_persist": true,
    "output_filtering_for_data_leakage": true,
    "data_classification_and_protection": true,
    "output_validation_with_schema": true
  },
  "system_prompt_leakage": {
    "system_prompts_not_secrets": true,
    "sensitive_data_separate_from_instructions": true,
    "periodic_system_prompt_audit": true
  },
  "supply_chain": {
    "sbom_generation": true,
    "trivy_scan_on_pr": true,
    "gitleaks_on_push": true,
    "signed_commits": true,
    "dependency_update_max_days": 30
  },
  "data_poisoning": {
    "validate_before_memory_storage": true,
    "memory_isolation_per_user_session": true,
    "memory_expiration_hours": 24,
    "memory_size_limit_kb": 500,
    "memory_audit_before_persist": true
  },
  "tool_misuse": {
    "least_privilege_per_tool": true,
    "pre_execution_tool_validation": true,
    "tool_usage_pattern_monitoring": true,
    "execution_logs_for_anomaly_detection": true,
    "circuit_breaker_per_tool": true
  },
  "inter_agent_communication": {
    "validate_inter_agent_messages": true,
    "isolate_agent_environments": true,
    "circuit_breaker_cascading_failures": true,
    "communication_integrity_verification": true
  },
  "observability": {
    "track_token_usage_per_session": true,
    "track_cost_per_user": true,
    "audit_trail_decisions_and_actions": true,
    "alerts_for_security_events": true,
    "allow_agent_interrupt_and_rollback": true,
    "anomaly_detection_in_agent_behavior": true
  },
  "compliance": {
    "norms_document": "docs/NORMATIVAS-SEGURIDAD.md",
    "risk_matrix": {
      "prompt_injection": "CRITICAL",
      "excessive_agency": "CRITICAL",
      "tool_misuse": "CRITICAL",
      "supply_chain": "HIGH",
      "data_leakage": "HIGH",
      "system_prompt_leakage": "HIGH",
      "memory_poisoning": "HIGH",
      "inter_agent_attack": "MEDIUM",
      "observability_gap": "MEDIUM"
    }
  }
}

