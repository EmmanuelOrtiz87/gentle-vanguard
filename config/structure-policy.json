{
  "_comment": "structureMode: enforce-canonical (greenfield/new repos) | adopt-existing (legacy/production repos  advisory only, no auto-refactor)",
  "structureMode": "enforce-canonical",
  "allowedScriptDirs": [
    "scripts/utilities",
    "scripts/diagnostics",
    "scripts/validation",
    "scripts/gentle-vanguard",
    "scripts/project",
    "scripts/git-hooks",
    "skills",
    "tests"
  ],
  "allowedRootDirs": [
    ".cursor",
    ".cline",
    ".vscode",
    ".codex",
    ".antigravity",
    ".windsurf",
    ".github"
  ],
  "allowedRootFiles": ["README.md", "config/mcp-servers.json"],
  "allowedRootMarkdownFiles": [
    "CLAUDE.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "ROADMAP.md",
    "CHANGELOG.md"
  ],
  "allowedRootJsonFiles": ["opencode.json", "skills-lock.json"],
  "allowedRootConfigFiles": [".cursorrules", ".clinerules", ".gitignore"],
  "deprecatedPathPatterns": [".\\scripts\\update-all.ps1", "scripts/update-all.ps1"]
}
