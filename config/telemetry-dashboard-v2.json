{
  "telemetryDashboard": {
    "version": "2.0.0",
    "lastUpdated": "2026-05-12T19:55:00Z",
    "name": "Gentle-Vanguard Telemetry Dashboard v2",
    "description": "Business metrics and analytics for Gentle-Vanguard platform",
    
    "metrics": {
      "agent_performance": {
        "name": "Agent Performance",
        "widgets": [
          {
            "id": "agent_dispatch_latency",
            "type": "histogram",
            "title": "Agent Dispatch Latency (ms)",
            "metric": "agent_dispatch_seconds",
            "buckets": [10, 50, 100, 250, 500, 1000],
            "targets": ["p50", "p95", "p99", "max"],
            "threshold": 500
          },
          {
            "id": "agent_success_rate",
            "type": "gauge",
            "title": "Agent Success Rate (%)",
            "metric": "agent_success_rate",
            "targets": ["current", "24h_avg", "7d_avg"],
            "threshold": 0.95
          },
          {
            "id": "agents_by_code",
            "type": "bar_chart",
            "title": "Dispatch Count by Agent",
            "groupBy": "agent_code",
            "timeRange": "24h"
          }
        ]
      },
      
      "skill_performance": {
        "name": "Skill Performance",
        "widgets": [
          {
            "id": "skill_execution_time",
            "type": "heatmap",
            "title": "Skill Execution Time Distribution",
            "metric": "skill_execution_seconds",
            "groupBy": "skill_name",
            "timeRange": "24h"
          },
          {
            "id": "skill_failure_rate",
            "type": "gauge",
            "title": "Skill Failure Rate (%)",
            "metric": "skill_failure_rate",
            "alert_threshold": 0.05,
            "severity": "CRITICAL"
          },
          {
            "id": "top_skills",
            "type": "table",
            "title": "Top 10 Skills by Usage",
            "columns": ["rank", "skill_name", "call_count", "success_rate", "avg_duration_ms"],
            "sort": "call_count",
            "limit": 10
          },
          {
            "id": "skill_errors",
            "type": "table",
            "title": "Skills with Recent Errors",
            "columns": ["skill_name", "error_count", "last_error", "error_type"],
            "timeRange": "24h"
          }
        ]
      },
      
      "token_usage": {
        "name": "Token & Budget Management",
        "widgets": [
          {
            "id": "token_usage_daily",
            "type": "line_chart",
            "title": "Daily Token Usage vs Budget",
            "metrics": ["token_usage", "token_budget"],
            "timeRange": "30d"
          },
          {
            "id": "token_budget_status",
            "type": "gauge",
            "title": "Current Budget Usage (%)",
            "metric": "token_usage_ratio",
            "warning_threshold": 0.75,
            "critical_threshold": 0.90
          },
          {
            "id": "token_by_agent",
            "type": "pie_chart",
            "title": "Token Usage by Agent",
            "metric": "token_usage",
            "groupBy": "agent_code",
            "timeRange": "24h"
          },
          {
            "id": "token_by_skill",
            "type": "bar_chart",
            "title": "Top Token Consumers (Skills)",
            "metric": "token_usage",
            "groupBy": "skill_name",
            "limit": 10,
            "timeRange": "24h"
          }
        ]
      },
      
      "user_satisfaction": {
        "name": "User Satisfaction & Feedback",
        "widgets": [
          {
            "id": "nps_score",
            "type": "gauge",
            "title": "Net Promoter Score (NPS)",
            "metric": "nps_score",
            "target": 50
          },
          {
            "id": "satisfaction_by_agent",
            "type": "bar_chart",
            "title": "Satisfaction Score by Agent",
            "metric": "user_satisfaction",
            "groupBy": "agent_code",
            "timeRange": "7d"
          },
          {
            "id": "feedback_sentiment",
            "type": "pie_chart",
            "title": "User Feedback Sentiment",
            "values": ["positive", "neutral", "negative"],
            "timeRange": "7d"
          },
          {
            "id": "common_issues",
            "type": "table",
            "title": "Most Reported Issues (This Week)",
            "columns": ["issue_category", "count", "sentiment", "examples"],
            "sort": "count",
            "limit": 10
          }
        ]
      },
      
      "system_health": {
        "name": "System Health & SLOs",
        "widgets": [
          {
            "id": "slo_compliance",
            "type": "gauge",
            "title": "SLO Compliance (%)",
            "metric": "slo_compliance_ratio",
            "target": 0.99,
            "alert_threshold": 0.95
          },
          {
            "id": "error_rates",
            "type": "line_chart",
            "title": "Error Rate by Severity",
            "metrics": ["errors_critical", "errors_high", "errors_medium", "errors_low"],
            "timeRange": "24h"
          },
          {
            "id": "uptime",
            "type": "gauge",
            "title": "System Uptime (%)",
            "metric": "uptime_ratio",
            "target": 0.9999,
            "timeRange": "30d"
          },
          {
            "id": "incidents",
            "type": "table",
            "title": "Recent Incidents",
            "columns": ["timestamp", "severity", "title", "duration_minutes", "status"],
            "sort": "timestamp",
            "limit": 10
          }
        ]
      },
      
      "trends": {
        "name": "Trends & Analytics",
        "widgets": [
          {
            "id": "usage_trend",
            "type": "area_chart",
            "title": "Platform Usage Trend (Last 30d)",
            "metric": "request_count",
            "aggregation": "daily",
            "trend_indicator": true
          },
          {
            "id": "performance_trend",
            "type": "line_chart",
            "title": "Performance Trend (p95 latency)",
            "metric": "latency_p95",
            "aggregation": "daily",
            "timeRange": "30d"
          },
          {
            "id": "user_growth",
            "type": "bar_chart",
            "title": "Active Users Trend",
            "metric": "active_users",
            "aggregation": "weekly",
            "timeRange": "90d"
          },
          {
            "id": "skill_adoption",
            "type": "heatmap",
            "title": "Skill Adoption Heatmap (30d)",
            "metric": "skill_usage_count",
            "groupBy": ["skill_name", "date"]
          }
        ]
      }
    },
    
    "dashboards": {
      "executive": {
        "name": "Executive Summary",
        "sections": ["system_health", "user_satisfaction", "trends"],
        "refresh": 300,
        "layout": "grid-3col"
      },
      "operations": {
        "name": "Operations Dashboard",
        "sections": ["agent_performance", "skill_performance", "system_health"],
        "refresh": 60,
        "layout": "grid-3col"
      },
      "product": {
        "name": "Product Analytics",
        "sections": ["user_satisfaction", "trends", "token_usage"],
        "refresh": 300,
        "layout": "grid-2col"
      },
      "engineering": {
        "name": "Engineering Metrics",
        "sections": ["skill_performance", "token_usage", "system_health"],
        "refresh": 60,
        "layout": "grid-3col"
      }
    },
    
    "alerts": {
      "enabled": true,
      "rules": [
        {
          "id": "agent_dispatch_slow",
          "condition": "agent_dispatch_seconds_p95 > 1000",
          "severity": "WARN",
          "channels": ["slack", "email"]
        },
        {
          "id": "skill_failure_spike",
          "condition": "skill_failure_rate > 0.05",
          "severity": "CRITICAL",
          "channels": ["slack", "pagerduty"]
        },
        {
          "id": "token_budget_warning",
          "condition": "token_usage_ratio > 0.75",
          "severity": "WARN",
          "channels": ["slack"]
        },
        {
          "id": "slo_breach",
          "condition": "slo_compliance_ratio < 0.95",
          "severity": "CRITICAL",
          "channels": ["pagerduty", "email"]
        }
      ]
    },
    
    "exports": {
      "formats": ["csv", "json", "pdf"],
      "schedules": {
        "daily": "06:00 UTC",
        "weekly": "Monday 06:00 UTC",
        "monthly": "1st of month 06:00 UTC"
      }
    },
    
    "retention": {
      "raw_data": 7,
      "hourly_aggregates": 30,
      "daily_aggregates": 365
    }
  }
}

