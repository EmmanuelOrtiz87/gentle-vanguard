# npm Security Configuration — foundation
# Hardened against supply chain attacks (npm-security-best-practices)

# Disable post-install lifecycle scripts for all packages
# Prevents arbitrary code execution during npm install
ignore-scripts=true

# Minimum release age: skip packages published less than 3 days ago
# Reduces risk of installing compromised packages before community detects them
min-release-age=3

# Block git-based dependencies (npm CLI 11.10.0+)
# Forces all packages through registry security scanning
allow-git=none
