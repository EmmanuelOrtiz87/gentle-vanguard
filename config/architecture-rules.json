{
  "version": "1.0.0",
  "description": "Foundation Project - Architecture Rules Configuration",
  "layers": [
    {
      "id": "presentation",
      "name": "Presentation Layer",
      "description": "UI, API, CLI interfaces",
      "path": "src/presentation",
      "canDependOn": ["application"],
      "responsibilities": [
        "Handle user input/output",
        "Format responses",
        "Validate user requests",
        "Route requests to application layer"
      ],
      "restrictions": [
        "NO business logic allowed",
        "NO direct data access",
        "NO infrastructure dependencies"
      ]
    },
    {
      "id": "application",
      "name": "Application Layer",
      "description": "Business logic, orchestration",
      "path": "src/application",
      "canDependOn": ["domain", "infrastructure"],
      "responsibilities": [
        "Orchestrate business processes",
        "Coordinate between layers",
        "Handle transactions",
        "Manage workflows"
      ],
      "restrictions": [
        "NO direct data access",
        "NO presentation logic",
        "NO infrastructure details"
      ]
    },
    {
      "id": "domain",
      "name": "Domain Layer",
      "description": "Core entities, business rules",
      "path": "src/domain",
      "canDependOn": [],
      "responsibilities": [
        "Define core entities",
        "Implement business rules",
        "Define value objects",
        "Express domain concepts"
      ],
      "restrictions": [
        "NO infrastructure dependencies",
        "NO external service calls",
        "NO framework dependencies"
      ]
    },
    {
      "id": "infrastructure",
      "name": "Infrastructure Layer",
      "description": "Data access, external services",
      "path": "src/infrastructure",
      "canDependOn": ["domain"],
      "responsibilities": [
        "Data persistence",
        "External service integration",
        "Resource management",
        "Technical implementations"
      ],
      "restrictions": [
        "NO business logic",
        "NO presentation logic",
        "NO orchestration"
      ]
    },
    {
      "id": "cross-cutting",
      "name": "Cross-Cutting Concerns",
      "description": "Logging, security, caching",
      "path": "src/cross-cutting",
      "canDependOn": [],
      "responsibilities": [
        "Logging and monitoring",
        "Security and authentication",
        "Caching strategies",
        "Error handling"
      ],
      "restrictions": [
        "NO business logic",
        "NO layer-specific logic"
      ]
    }
  ],
  "rules": [
    {
      "id": "no-circular-deps",
      "name": "No Circular Dependencies",
      "description": "No circular dependencies allowed between any components",
      "severity": "error",
      "enforcedAt": "build-time"
    },
    {
      "id": "layer-isolation",
      "name": "Layer Isolation",
      "description": "Layers must only depend on layers below them",
      "severity": "error",
      "enforcedAt": "build-time",
      "details": {
        "presentation": ["application"],
        "application": ["domain", "infrastructure"],
        "domain": [],
        "infrastructure": ["domain"],
        "cross-cutting": []
      }
    },
    {
      "id": "single-responsibility",
      "name": "Single Responsibility Principle",
      "description": "Each component has one reason to change",
      "severity": "warning",
      "enforcedAt": "code-review"
    },
    {
      "id": "no-skipping-layers",
      "name": "No Skipping Layers",
      "description": "Cannot skip layers (e.g., Presentation -> Infrastructure)",
      "severity": "error",
      "enforcedAt": "build-time"
    },
    {
      "id": "dependency-injection",
      "name": "Dependency Injection",
      "description": "All dependencies must be injected",
      "severity": "warning",
      "enforcedAt": "code-review"
    },
    {
      "id": "interface-abstraction",
      "name": "Interface Abstraction",
      "description": "Interfaces must be used for abstraction",
      "severity": "warning",
      "enforcedAt": "code-review"
    },
    {
      "id": "encapsulation",
      "name": "Encapsulation",
      "description": "Hide implementation details, expose only necessary interfaces",
      "severity": "warning",
      "enforcedAt": "code-review"
    },
    {
      "id": "no-god-objects",
      "name": "No God Objects",
      "description": "Components should not have too many responsibilities",
      "severity": "warning",
      "enforcedAt": "code-review",
      "threshold": {
        "maxMethods": 20,
        "maxProperties": 15
      }
    },
    {
      "id": "cohesion",
      "name": "High Cohesion",
      "description": "Related functionality should be grouped together",
      "severity": "warning",
      "enforcedAt": "code-review"
    },
    {
      "id": "loose-coupling",
      "name": "Loose Coupling",
      "description": "Components should have minimal dependencies",
      "severity": "warning",
      "enforcedAt": "code-review"
    }
  ],
  "componentTypes": [
    {
      "name": "Controller",
      "description": "Handle HTTP requests/responses",
      "layer": "presentation",
      "pattern": "*Controller.ts"
    },
    {
      "name": "Service",
      "description": "Implement business logic",
      "layer": "application",
      "pattern": "*Service.ts"
    },
    {
      "name": "Repository",
      "description": "Manage data access",
      "layer": "infrastructure",
      "pattern": "*Repository.ts"
    },
    {
      "name": "Entity",
      "description": "Represent domain objects",
      "layer": "domain",
      "pattern": "*Entity.ts"
    },
    {
      "name": "DTO",
      "description": "Transfer data between layers",
      "layer": "presentation",
      "pattern": "*.dto.ts"
    },
    {
      "name": "Validator",
      "description": "Validate input/output",
      "layer": "application",
      "pattern": "*Validator.ts"
    },
    {
      "name": "Mapper",
      "description": "Transform between types",
      "layer": "application",
      "pattern": "*Mapper.ts"
    },
    {
      "name": "Factory",
      "description": "Create complex objects",
      "layer": "application",
      "pattern": "*Factory.ts"
    },
    {
      "name": "Strategy",
      "description": "Implement algorithms",
      "layer": "application",
      "pattern": "*Strategy.ts"
    },
    {
      "name": "Decorator",
      "description": "Add behavior to objects",
      "layer": "cross-cutting",
      "pattern": "*Decorator.ts"
    }
  ],
  "namingConventions": {
    "classes": {
      "pattern": "PascalCase",
      "example": "UserRepository",
      "description": "Class names in PascalCase"
    },
    "functions": {
      "pattern": "camelCase",
      "example": "getUserById",
      "description": "Function names in camelCase, verb form"
    },
    "variables": {
      "pattern": "camelCase",
      "example": "userName",
      "description": "Variable names in camelCase, noun form"
    },
    "constants": {
      "pattern": "UPPER_SNAKE_CASE",
      "example": "MAX_RETRIES",
      "description": "Constants in UPPER_SNAKE_CASE"
    },
    "privateMembers": {
      "pattern": "_camelCase",
      "example": "_internalState",
      "description": "Private members prefixed with underscore"
    },
    "booleans": {
      "pattern": "is/has/can/should + PascalCase",
      "example": "isActive",
      "description": "Boolean variables prefixed with is/has/can/should"
    }
  },
  "fileOrganization": {
    "maxLinesPerFile": 500,
    "maxMethodLength": 30,
    "maxClassComplexity": 15,
    "structure": {
      "order": [
        "imports",
        "constants",
        "types",
        "class declaration",
        "static properties",
        "instance properties",
        "constructor",
        "public methods",
        "protected methods",
        "private methods"
      ]
    }
  },
  "enforcement": {
    "tools": [
      {
        "name": "eslint-plugin-architecture",
        "description": "Enforce architecture rules",
        "enabled": true
      },
      {
        "name": "dependency-cruiser",
        "description": "Detect circular dependencies",
        "enabled": true
      },
      {
        "name": "sonarqube",
        "description": "Code quality and architecture analysis",
        "enabled": true
      }
    ],
    "checkpoints": [
      {
        "stage": "pre-commit",
        "checks": ["naming-conventions", "file-organization"]
      },
      {
        "stage": "build",
        "checks": ["circular-dependencies", "layer-isolation", "no-skipping-layers"]
      },
      {
        "stage": "code-review",
        "checks": ["single-responsibility", "encapsulation", "cohesion"]
      }
    ]
  }
}