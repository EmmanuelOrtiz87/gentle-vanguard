# Foundation .gitignore

# Auto-generated reports and temporary files
docs/audit/
docs/reports/
docs/metrics/
*.report.md
*.audit.md

# Temporary documentation
docs/temp/
docs/draft/
docs/.backup/

# Build and runtime
bin/
obj/
dist/
build/
*.exe
*.dll
*.so

# Cache and temp
.cache/
.temp/
tmp/
*.tmp
*.log

# IDE
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
*.bak

# Environment
.env
.env.local
.env.*.local
config/github-runner.local.json

# Workspace Security (NEVER commit)
.workspace/config/owner-auth.json
config/owner-auth.json
config/owner-auth.template.json

# Generated reports (runtime artifacts — not source)
reports/dashboard.html
reports/metrics-export.csv
reports/wf-benchmark.json
reports/trivy-report.json
trivy-report.json

# Rate-limit and event-bus runtime state
.event-bus/rate-limit-state.json
scripts/.event-bus/

# Session temp & local-only artifacts (NORMATIVA: no subir al repo)
.session/
session/
.local/
.workspace/config/session-auth.json
.workspace/config/dev-credentials.json
.runtime/security-*.json
.runtime/*-audit.log
.runtime/quality/

# Telemetry & engram runtime data
.telemetry/
.engram-data/
.engram/session-*.md
.engram/lessons-*.md
logs/session-*.json
logs/*.session.*

# Session artifact docs — local-only, never commit to repo
# Rule: closure reports, delivery checklists, implementation logs,
# next-session guides, strategic plans, phase plans → stay in .local/
docs/sessions/*-session-start.md
docs/sessions/*-context-pack.md
docs/sessions/*-delivery-closure.md
docs/sessions/closure-report-*.md
docs/sessions/metrics/*.csv
docs/.local-archive/
docs/*SESSION-COMPLETION-REPORT*.md
docs/*SESSION-IMPLEMENTATION-START*.md
docs/*SESSION-AUTH-FLOW*.md
docs/*NEXT_SESSION_GUIDE*.md
docs/*STRATEGIC-OPTIMIZATION-PLAN*.md
docs/*IMPLEMENTATION-STRUCTURE*.md
docs/*PHASE-*-ARCHITECTURE*.md
docs/*TOKEN-REPORTING-PROCESS*.md
docs/*LESSONS-LEARNED-*.md
docs/tasks/*session-hardening*.md
FINAL-DELIVERY-CHECKLIST.md
IMPLEMENTATION-LOG.md
PROJECT-CLOSURE-REPORT.md
README-IMPLEMENTATION.md

# Scripts runtime session data
scripts/docs/sessions/
scripts/utilities/docs/sessions/

# Dependencies
node_modules/
packages/
vendor/

# Test coverage
coverage/
.coverage
*.lcov

# Performance profiling
*.prof
*.pprof

# Local development artifacts
.local/
.local/social/images/

# Encrypted backups (security)
.backups/

# Engram data
.engram-data/
logs/*.json
logs/*.jsonl
logs/.session-active

# Telemetry
.telemetry/

# Tool-specific configs (local-only)
.claude/
.opencode/

# OpenCode generated
config/opencode.schema.json

# Audit reports (auto-generated)
LESSONS-LEARNED-*.md
docs/reference/LESSONS-LEARNED-*.md

# Judgment-day auto-generated artifacts
scripts/docs/judgment/
docs/judgment/
keys/

# Runtime audit logs
.logs/

*.lib
