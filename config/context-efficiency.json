{
  "activeProfile": "recommended",
  "profiles": {
    "default": {
      "windowDays": 7,
      "promptChars": {
        "yellowMax": 1200,
        "redMax": 1800
      },
      "adoptionPercent": {
        "yellowMin": 70,
        "redMin": 40
      }
    },
    "recommended": {
      "windowDays": 7,
      "promptChars": {
        "yellowMax": 1100,
        "redMax": 1600
      },
      "adoptionPercent": {
        "yellowMin": 75,
        "redMin": 50
      }
    }
  },
  "liveAssist": {
    "enabled": true,
    "showOnCommands": [
      "status",
      "health",
      "start-session",
      "end-session",
      "day-end-closure",
      "review",
      "audit",
