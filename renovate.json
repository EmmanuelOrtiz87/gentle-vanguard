{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":separateMajorMinor",
    ":combinePatchMinorUpdates",
    ":enablePreCommit",
    ":gitSignOff"
  ],
  "labels": ["dependencies", "renovate"],
  "timezone": "America/Argentina/Buenos_Aires",
  "schedule": ["before 9am on monday"],
  "prHourlyLimit": 2,
  "prConcurrentLimit": 5,
  "branchConcurrentLimit": 10,
  "recreateWhen": "auto",
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "🤖 Renovate Dependency Dashboard",
  "commitMessagePrefix": "chore(deps)",
  "commitMessageAction": "update",
  "packageRules": [
    {
      "description": "Group minor/patch GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "groupSlug": "github-actions",
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "description": "Separate major GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "Group minor/patch npm updates (lefthook)",
      "matchManagers": ["npm"],
      "groupName": "npm dependencies",
      "groupSlug": "npm",
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "description": "Separate major npm updates",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "Ignore node_modules/ and .engram-data/",
      "matchPaths": ["node_modules/**", ".engram-data/**"],
      "enabled": false
    }
  ],
  "ignorePaths": [
    "node_modules/**",
    ".engram-data/**",
    ".git/**",
    "**/node_modules/**"
  ],
  "pre-commit": {
    "enabled": true
  }
}
