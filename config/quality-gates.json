{
  "version": "1.0.0",
  "description": "Canonical quality gates for CI and branch protection.",
  "requiredWorkflows": [
    "script-governance",
    "workflow-lint",
    "foundation-quality-gate"
  ],
  "requiredStatusChecks": {
    "strict": true,
    "contexts": [
      "Validate Script Governance and Process Alerts",
      "Workflow Lint",
      "Foundation Quality Gate"
    ]
  },
  "pullRequestRules": {
    "requiredApprovingReviewCount": 1,
    "dismissStaleReviews": true,
    "requireCodeOwnerReviews": false,
    "requireConversationResolution": true
  }
}
