{
  "version": "1.0.0",
  "name": "Testing Configuration",
  "description": "Automated testing suite configuration for workspace-foundation",
  "enabled": true,
  "testFramework": "pester",
  "testFrameworkBash": "bats",
  "testCoverage": {
    "enabled": true,
    "minimumThreshold": 0.80,
    "targetThreshold": 0.90,
    "excludePaths": [
      "node_modules",
      ".git",
      "docs",
      ".session"
    ]
  },
  "testTypes": {
    "unit": {
      "enabled": true,
      "description": "Unit tests for individual functions",
      "location": "tests/unit",
      "pattern": "*.tests.ps1",
      "timeout": 30
    },
    "integration": {
      "enabled": true,
      "description": "Integration tests for component interactions",
      "location": "tests/integration",
      "pattern": "*.integration.tests.ps1",
      "timeout": 60
    },
    "regression": {
      "enabled": true,
      "description": "Regression tests to prevent known issues",
      "location": "tests/regression",
      "pattern": "*.regression.tests.ps1",
      "timeout": 45
    },
    "performance": {
      "enabled": true,
      "description": "Performance and load tests",
      "location": "tests/performance",
      "pattern": "*.perf.tests.ps1",
      "timeout": 120,
      "thresholds": {
        "engram_creation": 50,
        "engram_consolidation": 100,
        "engram_compression": 200,
        "dynamic_optimization": 150
      }
    },
    "security": {
      "enabled": true,
      "description": "Security and vulnerability tests",
      "location": "tests/security",
      "pattern": "*.security.tests.ps1",
      "timeout": 60
    }
  },
  "testScripts": {
    "engram_memory_manager": {
      "enabled": true,
      "description": "Tests for Engram Memory Manager",
      "functions": [
        "Get-CleanupTargets",
        "Execute-Cleanup",
        "Verify-ProjectIntegrity",
        "Create-MemoryPack",
        "Consolidate-Packs",
        "Compress-Pack"
      ]
    },
    "dynamic_optimizer": {
      "enabled": true,
      "description": "Tests for Dynamic Optimizer",
      "functions": [
        "Get-SystemMetrics",
        "Analyze-Performance",
        "Optimize-Parameters",
        "Validate-Optimization"
      ]
    },
    "ai_tool_detector": {
      "enabled": true,
      "description": "Tests for AI Tool Detector",
      "functions": [
        "Detect-AITool",
        "Validate-Detection",
        "Load-Configuration"
      ]
    },
    "cleanup_project": {
      "enabled": true,
      "description": "Tests for Project Cleanup",
      "functions": [
        "Get-CleanupTargets",
        "Show-CleanupPlan",
        "Execute-Cleanup",
        "Verify-ProjectIntegrity"
      ]
    }
  },
  "cicd": {
    "enabled": true,
    "runOnCommit": true,
    "runOnPR": true,
    "runOnMerge": true,
    "failOnCoverageLow": true,
    "failOnTestFailure": true,
    "generateReport": true,
    "uploadArtifacts": true
  },
  "reporting": {
    "enabled": true,
    "formats": [
      "console",
      "json",
      "html",
      "junit"
    ],
    "outputPath": "test-results",
    "coveragePath": "coverage",
    "archiveResults": true,
    "retentionDays": 90
  },
  "hooks": {
    "preTest": {
      "enabled": true,
      "script": "scripts/testing/pre-test.ps1"
    },
    "postTest": {
      "enabled": true,
      "script": "scripts/testing/post-test.ps1"
    },
    "onFailure": {
      "enabled": true,
      "script": "scripts/testing/on-failure.ps1"
    }
  },
  "notifications": {
    "enabled": true,
    "onSuccess": true,
    "onFailure": true,
    "channels": [
      "console",
      "log",
      "email"
    ]
  }
}