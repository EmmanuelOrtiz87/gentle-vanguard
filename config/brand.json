      "to": "#06B6D4",
      "direction": "diagonal",
      "use": "GitHub repository header logo"
    }
  },

  "typography": {
    "displayFont": "Orbitron, Rajdhani, 'Share Tech Mono', monospace",
    "bodyFont": "'Inter', 'Segoe UI', sans-serif",
    "monoFont": "'JetBrains Mono', 'Cascadia Code', monospace",
    "weight": {
      "display": 700,
      "heading": 600,
      "body": 400
    },
    "letterSpacing": {
      "display": "0.1em",
      "heading": "0.05em"
    }
  },

  "logo": {
