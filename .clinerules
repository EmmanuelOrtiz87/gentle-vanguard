# Cline Rules - Context-Optimized Configuration
# BASED ON: https://github.com/cline/cline (official best practices)
# Purpose: Minimal rules file with external references to avoid context bloat

---
name: gentle-vanguard-orchestrator
version: "2.6.0"
description: SDD-driven AI agent orchestration platform — optimized context loading

# ============================================================================
# PHASE 0: TOOL DETECTION (First action before anything)
# ============================================================================
detection:
  command: >
    pwsh -NoProfile -File scripts/utilities/detect-tool.ps1 -AsJson | ConvertFrom-Json
  fields:
    - name: name  # opencode|claude-code|cline|cursor|windsurf|unknown
    - name: os.platform  # windows|linux|macos
    - name: os.shell  # powershell|bash|zsh
  action: Load config from config/orchestrator.json#toolProfiles.<name>

# ============================================================================
# PHASE 1: CONTEXT BOUNDARIES (Critical for performance)
# ============================================================================

context:
  include:
    - "rules/**/*.md"
    - "config/*.json"
    - "skills/*/SKILL.md"
    - "scripts/utilities/pre-process-input.ps1"
    - "docs/AGENTS.md"
    - ".clinerules"

  exclude:
    - "node_modules/**"
    - ".git/**"
    - ".engram-data/**"
    - "dist/**"
    - "build/**"
    - "*.lock.json"
    - ".vscode/**"
    - "tmp-session-debug/**"
    - "logs/**"
    - "session/**"
    - "**/node_modules/**"
    - "**/.next/**"
    - "**/dist/**"
    - "**/build/**"

  memory:
    persist:
      - "config/orchestrator.json"
      - "config/auto-delegation.json"
      - "rules/AI-NORMATIVES.md"
    expire: 300
    strategy: "reference"

# ============================================================================
# PHASE 2: PRE-PROCESSING (BEFORE every response — response cache enabled)
# ============================================================================
# pre-process-input.ps1 now has SHA256 response cache (TTL 30min, -33-41% latency)
# Use -DisableCache flag to bypass when needed

preprocess:
  command: >
    pwsh -NoProfile -File scripts/utilities/pre-process-input.ps1
    -UserInput "USER_INPUT" -WorkspaceRoot "."
  cache: enabled  # SHA256 key, TTL 30min, auto-prune >1hr
  bypass: -DisableCache
  parse:
    TRIGGER_MATCH_FOUND: Load triggered skill
    PLAN_MODE_REQUIRED: Activate BA/sdd-explore first
    NO_TRIGGER_MATCH: Normal behavior

triggers:
  session:
    keywords: ["inicia sesion", "iniciar sesion", "start session", "begin session"]
    reference: "skills/session-workflow-skill/SKILL.md"
    rule: "Load only session-specific context"

  sdd:
    keywords: ["implement", "code", "feature", "design", "architecture", "test", "deploy"]
    reference: "skills/sdd-lifecycle/SKILL.md"
    rule: "Follow EXPLORE -> SPEC -> APPLY -> VERIFY phases"

  security:
    keywords: ["security", "auth", "vulnerability", "penetration", "audit"]
    reference: "skills/security-skill/SKILL.md"
    rule: "Load security context only if triggered"

  devops:
    keywords: ["deploy", "docker", "kubernetes", "ci/cd", "helm"]
    reference: "skills/docker-devops-skill/SKILL.md"
    rule: "Load infra context only if triggered"

  git:
    keywords: ["branch", "pr", "merge", "commit", "conflict", "rebase"]
    reference: "skills/git-workflow-skill/SKILL.md"
    rule: "Load git context only if triggered"

# ============================================================================
# PHASE 3: STARTUP SEQUENCE (Run on first turn)
# ============================================================================
startup:
  description: >
    Run docs/AGENTS.md#Mandatory-Startup-Sequence.
    session-start-optimized.ps1 now runs in-process (no Start-Job overhead)
    and uses lazy loading (6 non-critical steps deferred post-pipeline).
  script: scripts/utilities/session-start-optimized.ps1
  config: config/session-autostart.config.json

# ============================================================================
# PHASE 4: AGENT RULES
# ============================================================================

agent:
  mode: "plan-and-act"
  approval: "all-actions"
  contextStrategy: "selective"
  rules:
    - "pre-process-input.ps1 BEFORE every response (-UserInput param, not -Prompt)"
    - "Never grep/search on node_modules or dist/"
    - "Use local-first approach: project knowledge before external search"
    - "Reference external docs, don't embed them"
    - "Batch independent tool calls in parallel"
    - "mem_search 'lessons learned' at session start"
    - "mem_save after every significant task"
  errorHandling:
    reference: "rules/NORMATIVAS-ERROR-HANDLING.md"
    strategy: "escalate-on-pattern-match"

# ============================================================================
# PHASE 5: SKILL CONTEXT SEGMENTATION
# ============================================================================

skills:
  dev-context:
    trigger: ["implement", "code", "feature", "refactor"]
    load:
      - "skills/sdd-lifecycle/SKILL.md"
      - "skills/typescript-skill/SKILL.md"
      - "rules/DEVELOPMENT-STANDARDS.md"
    exclude:
      - "rules/NORMATIVAS-PERFORMANCE.md"
      - "config/docker-*"

  ops-context:
    trigger: ["deploy", "docker", "kubernetes", "ci/cd"]
    load:
      - "skills/docker-devops-skill/SKILL.md"
      - "config/docker-*"
    exclude:
      - "rules/DEVELOPMENT-STANDARDS.md"
      - "src/**"

  qa-context:
    trigger: ["test", "testing", "e2e", "unit"]
    load:
      - "skills/testing-skill/SKILL.md"
      - "skills/playwright-skill/SKILL.md"
    exclude:
      - "build/**"

# ============================================================================
# PHASE 6: PERFORMANCE TUNING
# ============================================================================

performance:
  maxSearchDepth: 3
  maxSearchResults: 20
  searchTimeout: 5000
  memoryMode: "selective"
  contextWindowSize: "adaptive"
  maxContextTokens: 80000
  parallelTasks: 2
  batchToolCalls: true

# ============================================================================
# PHASE 7: CANONICAL REFERENCES
# ============================================================================

references:
  entry: "docs/AGENTS.md"
  routing: "config/auto-delegation.json"
  normatives: "rules/AI-NORMATIVES.md"
  standards: "rules/DEVELOPMENT-STANDARDS.md"
  orchestrator: "config/orchestrator.json"
  skills: "skills/SKILL_INDEX.md"

# ============================================================================
# PERFORMANCE OPTIMIZATIONS (2026-05-24)
# ============================================================================
optimizations:
  response_cache:
    location: scripts/utilities/pre-process-input.ps1
    benefit: -33-41% latency on repeated inputs
    mechanism: SHA256 hash key, TTL 30min, auto-prune >1hr
    bypass: -DisableCache flag
  lazy_autostart:
    location: config/session-autostart.config.json
    benefit: Pipeline 24->18 steps; 6 lazy steps post-pipeline
    mechanism: '"lazy": true on non-critical steps (self-diagnosis, metrics, dashboard, live-feed, skill-size, adaptive-profile)'
  in_process_pipeline:
    location: scripts/utilities/session-start-optimized.ps1
    benefit: -~400ms startup time
    mechanism: Replaced Start-Job with & directo in-process
  skill_split:
    benefit: 86 oversized skills -> 0 warnings
    mechanism: Split verbose content to references/detail.md per skill

