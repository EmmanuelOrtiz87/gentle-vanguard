{
  "workspaceName": "workspace-foundation-portable",
  "dataRoot": ".engram-data",
  "toolsRoot": "tools",
  "projectsRoot": "projects",
  "aiModelSettings": {
    "provider": "opencode",
    "model": "claude-sonnet-4-20250514",
    "protocol": "openai"
  },
  "mcpIntegrations": {
    "context7": {
      "enabled": false,
      "serverName": "context7",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "requiredEnv": ["CONTEXT7_API_KEY"],
      "purpose": "Version-aware docs and snippets for implementation support"
    },
    "notion": {
      "enabled": false,
      "serverName": "notion",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@notionhq/notion-mcp-server"],
      "requiredEnv": ["NOTION_TOKEN", "NOTION_DATABASE_ID"],
      "purpose": "Shared knowledge base and delivery notes"
    }
  },
  "projectTemplate": "templates/project-root",
  "projectDefaults": {
    "repositoryMode": "template",
    "kind": "service",
    "preset": "default",
    "architecture": "layered",
    "profile": "general",
    "aiModelMode": "none",
    "aiModelProvider": "",
    "aiModelName": "",
    "aiModelEndpoint": "",
    "aiModelNotes": "",
    "repoUrl": "",
    "cloneDir": "",
    "buildCommand": "go build ./...",
    "testCommand": "go test ./...",
    "postInstallCommand": ""
  },
  "projectKinds": ["service", "cli", "library"],
  "systemDependencies": [
    {
      "name": "go",
      "checkCommand": "go",
      "minVersion": "1.21",
      "versionArgs": ["version"],
      "versionRegex": "go(\\d+\\.\\d+\\.\\d+)",
      "optional": false,
      "install": {
        "windows": {
          "winget": "GoLang.Go",
          "url": "https://go.dev/dl/",
          "notes": "Restart terminal after install so PATH includes Go"
        },
        "linux": {
          "url": "https://go.dev/dl/",
          "notes": "Download tarball, extract to /usr/local/go, add /usr/local/go/bin to PATH"
        },
        "macos": {
          "brew": "go",
          "url": "https://go.dev/dl/"
        }
      }
    },
    {
      "name": "git",
      "checkCommand": "git",
      "minVersion": "2.30",
      "versionArgs": ["--version"],
      "versionRegex": "git version (\\d+\\.\\d+\\.\\d+)",
      "optional": false,
      "install": {
        "windows": {
          "winget": "Git.Git",
          "url": "https://git-scm.com/download/win",
          "notes": "Git Bash (bash.exe) is included — restart terminal after install"
        },
        "linux": {
          "url": "https://git-scm.com/download/linux",
          "notes": "sudo apt install git  OR  sudo dnf install git"
        },
        "macos": {
          "brew": "git",
          "url": "https://git-scm.com/download/mac"
        }
      }
    },
    {
      "name": "node",
      "checkCommand": "node",
      "minVersion": "18",
      "versionArgs": ["--version"],
      "versionRegex": "v(\\d+\\.\\d+)",
      "optional": true,
      "usedBy": ["MCP integrations (context7, notion)", "opencode npm fallback"],
      "install": {
        "windows": {
          "winget": "OpenJS.NodeJS.LTS",
          "url": "https://nodejs.org/en/download/",
          "notes": "Restart terminal after install"
        },
        "linux": {
          "url": "https://nodejs.org/en/download/",
          "notes": "sudo apt install nodejs  OR use nvm: https://github.com/nvm-sh/nvm"
        },
        "macos": {
          "brew": "node",
          "url": "https://nodejs.org/en/download/"
        }
      }
    }
  ],
  "tools": [
    {
      "name": "engram",
      "checkCommand": "engram",
      "requires": ["go"],
      "install": {
        "windows": "go install github.com/Gentleman-Programming/engram/cmd/engram@latest",
        "linux": "go install github.com/Gentleman-Programming/engram/cmd/engram@latest",
        "macos": "go install github.com/Gentleman-Programming/engram/cmd/engram@latest"
      }
    },
    {
      "name": "gga",
      "checkCommand": "gga",
      "optional": true,
      "requires": ["git", "bash"],
      "install": {
        "windows": "$target = Join-Path '{toolsRoot}' 'gentleman-guardian-angel'; if (-not (Test-Path $target)) { git clone https://github.com/Gentleman-Programming/gentleman-guardian-angel.git $target }; Set-Location $target; bash ./install.sh",
        "linux": "$target = Join-Path '{toolsRoot}' 'gentleman-guardian-angel'; if (-not (Test-Path $target)) { git clone https://github.com/Gentleman-Programming/gentleman-guardian-angel.git $target }; Set-Location $target; bash ./install.sh",
        "macos": "$target = Join-Path '{toolsRoot}' 'gentleman-guardian-angel'; if (-not (Test-Path $target)) { git clone https://github.com/Gentleman-Programming/gentleman-guardian-angel.git $target }; Set-Location $target; bash ./install.sh"
      }
    },
    {
      "name": "gentleman-skills",
      "checkPath": "{toolsRoot}/Gentleman-Skills",
      "optional": true,
      "requires": ["git"],
      "install": {
        "windows": "$target = Join-Path '{toolsRoot}' 'Gentleman-Skills'; if (-not (Test-Path $target)) { git clone https://github.com/Gentleman-Programming/Gentleman-Skills.git $target } else { Set-Location $target; git pull --ff-only }",
        "linux": "$target = Join-Path '{toolsRoot}' 'Gentleman-Skills'; if (-not (Test-Path $target)) { git clone https://github.com/Gentleman-Programming/Gentleman-Skills.git $target } else { Set-Location $target; git pull --ff-only }",
        "macos": "$target = Join-Path '{toolsRoot}' 'Gentleman-Skills'; if (-not (Test-Path $target)) { git clone https://github.com/Gentleman-Programming/Gentleman-Skills.git $target } else { Set-Location $target; git pull --ff-only }"
      }
    },
    {
      "name": "gentle-ai",
      "checkCommand": "gentle-ai",
      "optional": true,
      "requires": ["go"],
      "install": {
        "windows": "go install github.com/gentleman-programming/gentle-ai/cmd/gentle-ai@latest",
        "linux": "go install github.com/gentleman-programming/gentle-ai/cmd/gentle-ai@latest",
        "macos": "go install github.com/gentleman-programming/gentle-ai/cmd/gentle-ai@latest"
      }
    },
    {
      "name": "opencode",
      "checkCommand": "opencode",
      "requires": [],
      "install": {
        "windows": "irm https://opencode.ai/install | iex",
        "linux": "curl -fsSL https://opencode.ai/install | bash",
        "macos": "curl -fsSL https://opencode.ai/install | bash"
      }
    }
  ]
}
