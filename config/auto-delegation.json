    "adaptive_mode":  {
                          "enabled":  true,
                          "integration":  "orchestrator",
                          "feedback_loop_support":  true,
                          "rollback_support":  true,
                          "auto_detect_integration":  true,
                          "complexity_detection":  {
                                                       "enabled":  true,
