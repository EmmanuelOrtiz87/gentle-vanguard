{
  "version": "1.0",
  "_note": "This is the LOCAL configuration template. Copy your secrets here. This file is GITIGNORED - never commit!",
  "_instructions": "Run: invoke-cloud-agent.ps1 -Config and select option 2 to create your cloud-agents.local.json",
  "providers": {
    "bedrock": {
      "enabled": false,
      "description": "AWS Bedrock - Claude and other AWS-hosted models",
      "endpoint": "https://bedrock-runtime.us-east-1.amazonaws.com/model/anthropic.claude-3-5-sonnet-20241022/invoke",
      "model": "anthropic.claude-3-5-sonnet-20241022",
      "region": "us-east-1",
      "auth_type": "aws_sigv4",
      "response_format": {
        "type": "json_object"
      },
      "_secrets": {
        "aws_access_key_id": "AWS_ACCESS_KEY_ID (env var)",
        "aws_secret_access_key": "AWS_SECRET_ACCESS_KEY (env var)",
        "aws_session_token": "AWS_SESSION_TOKEN (for temp credentials)"
      }
    },
    "dify": {
      "enabled": false,
      "description": "Dify AI - Custom AI platform",
      "endpoint": "https://api.dify.ai/v1/chat/completions",
      "model": "dify-model",
      "api_key_env": "DIFY_API_KEY",
      "_secrets": {
        "api_key": "Set DIFY_API_KEY in your environment or .env.local"
      }
    },
    "azure": {
      "enabled": false,
      "description": "Azure OpenAI - Microsoft's OpenAI deployment",
      "endpoint": "https://YOUR_RESOURCE.openai.azure.com/openai/deployments/YOUR_DEPLOYMENT/chat/completions?api-version=2024-02-01",
      "model": "gpt-4o",
      "api_key_env": "AZURE_OPENAI_KEY",
      "api_version": "2024-02-01",
      "_secrets": {
        "api_key": "Set AZURE_OPENAI_KEY and AZURE_OPENAI_ENDPOINT in your environment"
      }
    },
    "openai": {
      "enabled": false,
      "description": "OpenAI - GPT models directly from OpenAI",
      "endpoint": "https://api.openai.com/v1/chat/completions",
      "model": "gpt-4o",
      "api_key_env": "OPENAI_API_KEY",
      "_secrets": {
        "api_key": "Set OPENAI_API_KEY in your environment"
      }
    },
    "anthropic": {
      "enabled": false,
      "description": "Anthropic - Claude models directly from source",
      "endpoint": "https://api.anthropic.com/v1/messages",
      "model": "claude-3-5-sonnet-20241022",
      "api_key_env": "ANTHROPIC_API_KEY",
      "_secrets": {
        "api_key": "Set ANTHROPIC_API_KEY in your environment"
      }
    },
    "gemini": {
      "enabled": false,
      "description": "Google Gemini - Vertex AI or Gemini API",
      "endpoint": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent",
      "model": "gemini-2.0-flash",
      "api_key_env": "GEMINI_API_KEY",
      "_secrets": {
        "api_key": "Set GEMINI_API_KEY in your environment"
      }
    },
    "ollama": {
      "enabled": false,
      "description": "Ollama - Local models (no API key needed)",
      "endpoint": "http://localhost:11434/api/chat",
      "model": "llama3.2",
      "local": true,
      "_secrets": {
        "note": "No API key needed for local Ollama"
      }
    },
    "custom": {
      "enabled": false,
      "description": "Custom/Generic API endpoint",
      "endpoint": "https://your-custom-endpoint.com/v1/chat",
      "model": "your-model",
      "api_key_env": "CUSTOM_API_KEY",
      "_secrets": {
        "api_key": "Set CUSTOM_API_KEY in your environment"
      }
    }
  }
}
