# JetBrains IDEs (IntelliJ, WebStorm, GoLand, PyCharm)
# Import via: File > Settings > Editor > Code Style > Import Scheme

# Code Style XML
<code_scheme name="Workspace" version="173">
  <HTML code_style_defaults="K&R">
    <option name="HTML_QUOTE_STYLE" value="Single" />
    <option name="HTML_ELEMENTS_TO_USE_LINE_BREAK_BEFORE" value="" />
  </HTML>
  <XML>
    <option name="XML_LEGACY_SETTINGS_IMPORTED" value="true" />
  </XML>
  <codeStyleSettings language="CSS">
    <option name="CSS_QUOTE_STYLE" value="Single" />
    <option name="CSS_SPACE_BEFORE_COLON" value="false" />
    <option name="CSS_SPACE_AFTER_COLON" value="oneSpace" />
  </codeStyleSettings>
  <codeStyleSettings language="JSON">
    <option name="SPACE_WITHIN_BRACKETS" value="false" />
    <option name="SPACE_WITHIN_BRACES" value="false" />
  </codeStyleSettings>
  <codeStyleSettings language="JavaScript">
    <option name="SPACE_WITHIN_BRACKETS" value="true" />
    <option name="SPACE_WITHIN_BRACES" value="true" />
    <option name="USE_DOUBLE_QUOTES" value="false" />
    <option name="SEMICOLON" value="true" />
  </codeStyleSettings>
  <codeStyleSettings language="TypeScript">
    <option name="SPACE_WITHIN_BRACKETS" value="true" />
    <option name="SPACE_WITHIN_BRACES" value="true" />
    <option name="USE_DOUBLE_QUOTES" value="false" />
    <option name="SEMICOLON" value="true" />
  </codeStyleSettings>
  <codeStyleSettings language="Python">
    <option name="SPACE_BEFORE_COLON" value="false" />
    <option name="SPACE_AFTER_COLON" value="true" />
    <option name="USE_DOUBLE_QUOTES" value="true" />
    <option name="ADD_BLANK_AFTER_IMPORTS" value="true" />
    <option name="ALIGN_MULTILINE_PARAMETERS" value="false" />
  </codeStyleSettings>
</code_scheme>
