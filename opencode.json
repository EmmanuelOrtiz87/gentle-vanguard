{
  "$schema": "https://opencode.ai/config.json",
  "model": "openrouter/z-ai/glm-5",
  "small_model": "openrouter/qwen/qwen-3.6-plus",
  "provider": {
    "ollama": {
      "id": "ollama",
      "name": "Ollama Local",
      "api": "openai",
      "options": {
        "baseURL": "http://localhost:11434/v1",
        "apiKey": "ollama"
      },
      "models": {
        "qwen2.5-coder:3b": {
          "id": "qwen2.5-coder:3b",
          "name": "Qwen2.5 Coder 3B",
          "family": "qwen2.5-coder",
          "attachment": false,
          "reasoning": false,
          "temperature": true,
          "tool_call": true
        },
        "qwen2.5-coder:7b": {
          "id": "qwen2.5-coder:7b",
          "name": "Qwen2.5 Coder 7B",
          "family": "qwen2.5-coder",
          "attachment": false,
          "reasoning": false,
          "temperature": true,
          "tool_call": true
        },
        "qwen2.5-coder:14b": {
          "id": "qwen2.5-coder:14b",
          "name": "Qwen2.5 Coder 14B",
          "family": "qwen2.5-coder",
          "attachment": false,
          "reasoning": false,
          "temperature": true,
          "tool_call": true
        },
        "qwen3-coder:latest": {
          "id": "qwen3-coder:latest",
          "name": "Qwen3 Coder 30B MoE",
          "family": "qwen3-coder",
          "attachment": false,
          "reasoning": true,
          "temperature": true,
          "tool_call": true
        }
      }
    },
    "openrouter": {
      "options": {
        "setCacheKey": true,
        "timeout": 600000
      }
    },
    "anthropic": {
      "options": {
        "setCacheKey": true,
        "timeout": 600000
      }
    }
  },
  "agent": {
    "orchestrator": {
      "description": "Main orchestrator agent — coordinates all subagents autonomously",
      "mode": "primary",
      "model": "openrouter/qwen/qwen-3.6-plus",
      "options": {
        "minTokens": 2000,
        "maxTokens": 4500,
        "temperature": 0.3
      },
      "permission": {
        "websearch": "allow",
        "codesearch": "allow",
        "webfetch": "allow",
        "task": {
          "*": "allow"
        }
      }
    },
    "sdd-explore": {
      "description": "BA exploration agent — requirements gathering and analysis",
      "mode": "subagent",
      "hidden": true,
      "model": "openrouter/moonshot/kimi-k2.6",
      "options": {
        "minTokens": 2000,
        "maxTokens": 5000,
        "temperature": 0.7
      },
      "permission": {
        "websearch": "deny",
        "codesearch": "allow",
        "webfetch": "deny"
      },
      "routing": {
        "preProcess": "scripts/utilities/pre-process-input.ps1",
        "mappings": "config/auto-delegation.json#keywordMappings",
        "agentProfiles": "config/auto-delegation.json#agentProfiles",
        "fallbackStrategy": "clarify-ba"
      }
    },
    "sdd-design": {
      "description": "SAD architecture design agent — system design and API contracts",
      "mode": "subagent",
      "hidden": true,
      "model": "openrouter/moonshot/kimi-k2.6",
      "options": {
