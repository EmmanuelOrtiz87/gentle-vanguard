# Workspace Foundation .gitignore

# Auto-generated reports and temporary files
docs/audit/
docs/reports/
docs/metrics/
*.report.md
*.audit.md

# Temporary documentation
docs/temp/
docs/draft/
docs/.backup/

# Build and runtime
bin/
obj/
dist/
build/
*.exe
*.dll
*.so

# Cache and temp
.cache/
.temp/
tmp/
*.tmp
*.log

# IDE
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
*.bak

# Environment
.env
.env.local
.env.*.local

# Workspace Security (NEVER commit)
.workspace/config/owner-auth.json
.workspace/config/session-auth.json
.workspace/config/dev-credentials.json
.runtime/security-*.json
.runtime/*-audit.log

# Dependencies
node_modules/
packages/
vendor/

# Test coverage
coverage/
.coverage
*.lcov

# Performance profiling
*.prof
*.pprof

# Local development artifacts
.local/
.local/social/images/
.gga
.gga/
templates/gga/
scripts/optional/run-gga.ps1
scripts/utilities/run-gga.ps1
*gga*.local/

# Encrypted backups (security)
.backups/

# Session data (runtime)
.session/
.engram-data/
logs/*.json
logs/.session-active

# Telemetry
.telemetry/

# OpenCode generated
opencode.json
config/opencode.schema.json

# Audit reports (auto-generated)
LESSONS-LEARNED-*.md
docs/reference/LESSONS-LEARNED-*.md
