# EditorConfig - Universal editor settings
# https://editorconfig.org
# This file works with ALL modern editors

root = true

# All files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = off
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_size = 2

# JSON files
[*.json]
indent_size = 2

# Go files
[*.go]
indent_size = 4

# Python files
[*.py]
indent_size = 4
max_line_length = 88

# Shell scripts
[*.sh]
indent_size = 2
shell_variant = bash

# PowerShell
[*.ps1]
indent_size = 4

# Dockerfile
[Dockerfile]
indent_size = 4

# Makefile
[Makefile]
indent_style = tab

# TypeScript/JavaScript
[*.{ts,tsx,js,jsx}]
indent_size = 2

# Vue files
[*.vue]
indent_size = 2

# HTML/CSS
[*.{html,css,scss,sass}]
indent_size = 2

# XML files
[*.{xml,xsl}]
indent_size = 2

# TOML files
[*.toml]
indent_size = 2

# Docker Compose
[docker-compose*.{yml,yaml}]
indent_size = 2

# Git files
[.gitignore, .gitattributes]
trim_trailing_whitespace = false
