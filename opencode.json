{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "openrouter": {
      "options": {
        "setCacheKey": true,
        "timeout": 600000
      }
    },
    "anthropic": {
      "options": {
        "setCacheKey": true,
        "timeout": 600000
      }
    }
  },
  "agent": {
    "default": {
      "model": "anthropic/claude-sonnet-4-5",
      "options": {
        "minTokens": 2000,
        "maxTokens": 4500
      },
      "permission": {
        "websearch": "deny",
        "codesearch": "deny",
        "webfetch": "deny"
      }
    },
    "orchestrator": {
      "model": "anthropic/claude-sonnet-4-5",
      "options": {
        "minTokens": 2000,
        "maxTokens": 4500
      },
      "permission": {
        "websearch": "allow",
        "codesearch": "allow",
        "webfetch": "allow"
      }
    }
  },
  "hooks": {
    "pre_process": {
      "enabled": true,
      "mandatory": true,
      "description": "MANDATORY pre-processing hook - runs BEFORE any AI response",
      "script": "tools/pre-process-input.ps1",
      "args": {
        "UserInput": "${user_input}",
        "WorkspaceRoot": "."
      },
      "parseOutput": {
        "triggerFound": "TRIGGER_MATCH_FOUND",
        "noMatch": "NO_TRIGGER_MATCH"
      },
      "actions": {
        "onMatch": "Load skill using skill tool",
        "onNoMatch": "Continue with normal behavior"
      }
    }
  }
}