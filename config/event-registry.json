{
  "version": "2.0",
  "description": "Event Registry - Define all allowed events, schemas, permissions, and policies",
  "created": "2026-04-23",
  "last_updated": "2026-04-23",
  "registry": {
    "dispatch.started": {
      "description": "Fired when parallel dispatch begins",
      "category": "orchestration",
      "schema": {
        "type": "object",
        "required": ["execution_id", "mode", "agents"],
        "properties": {
          "execution_id": { "type": "string", "pattern": "^dispatch-[0-9]{8}$" },
          "mode": { "type": "string", "enum": ["parallel", "sequential"] },
          "agents": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      },
      "emitters": ["orchestrator", "dispatch-coordinator"],
      "listeners": ["session-manager", "token-guard", "audit-logger"],
      "policies": ["audit", "rate-limit", "security-check"],
      "rate_limit": { "max_per_minute": 10, "max_per_hour": 100 },
      "severity": "high",
      "enabled": true
    },
    "dispatch.completed": {
      "description": "Fired when parallel dispatch finishes",
      "category": "orchestration",
      "schema": {
        "type": "object",
        "required": ["execution_id", "results_count", "status"],
        "properties": {
          "execution_id": { "type": "string", "pattern": "^dispatch-[0-9]{8}$" },
          "results_count": { "type": "integer", "minimum": 0 },
          "status": { "type": "string", "enum": ["success", "partial", "failed"] },
          "duration_ms": { "type": "integer", "minimum": 0 },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      },
      "emitters": ["orchestrator", "dispatch-coordinator"],
      "listeners": ["session-manager", "token-guard", "audit-logger", "metrics-collector"],
      "policies": ["audit", "rate-limit"],
      "rate_limit": { "max_per_minute": 10, "max_per_hour": 100 },
      "severity": "high",
      "enabled": true
    },
    "agent.dispatched": {
      "description": "Fired when single agent is dispatched",
      "category": "agent",
      "schema": {
        "type": "object",
        "required": ["agent", "task", "lane_id"],
        "properties": {
          "agent": { "type": "string", "pattern": "^[A-Z]+$" },
          "task": { "type": "string", "minLength": 1 },
          "lane_id": { "type": "string", "pattern": "^agent-[A-Z]+-[0-9]+$" },
          "priority": { "type": "string", "enum": ["low", "normal", "high"] },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      },
      "emitters": ["orchestrator", "agent-router"],
      "listeners": ["session-manager", "audit-logger", "metrics-collector"],
      "policies": ["audit", "rate-limit"],
      "rate_limit": { "max_per_minute": 50, "max_per_hour": 500 },
      "severity": "medium",
      "enabled": true
    },
    "agent.completed": {
      "description": "Fired when single agent completes",
      "category": "agent",
      "schema": {
        "type": "object",
        "required": ["agent", "status", "lane_id"],
        "properties": {
          "agent": { "type": "string", "pattern": "^[A-Z]+$" },
          "status": { "type": "string", "enum": ["ready", "success", "error", "timeout"] },
          "lane_id": { "type": "string", "pattern": "^agent-[A-Z]+-[0-9]+$" },
          "token_estimate": { "type": "integer", "minimum": 0 },
          "duration_ms": { "type": "integer", "minimum": 0 },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      },
      "emitters": ["agent-executor", "orchestrator"],
      "listeners": ["session-manager", "token-guard", "audit-logger", "metrics-collector"],
      "policies": ["audit", "rate-limit"],
      "rate_limit": { "max_per_minute": 50, "max_per_hour": 500 },
      "severity": "medium",
      "enabled": true
    },
    "session.started": {
      "description": "Fired when session begins",
      "category": "session",
      "schema": {
        "type": "object",
        "required": ["session_id", "project"],
        "properties": {
          "session_id": {
            "type": "string",
            "pattern": "^session-[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{2}$"
          },
          "project": { "type": "string", "minLength": 1 },
          "user": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      },
      "emitters": ["session-manager"],
      "listeners": ["audit-logger", "token-guard", "metrics-collector"],
      "policies": ["audit", "security-check"],
      "rate_limit": { "max_per_minute": 5, "max_per_hour": 50 },
      "severity": "high",
      "enabled": true
    },
    "session.ended": {
      "description": "Fired when session closes",
      "category": "session",
      "schema": {
        "type": "object",
        "required": ["session_id", "duration_minutes", "tokens_used"],
        "properties": {
          "session_id": {
            "type": "string",
            "pattern": "^session-[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{2}$"
          },
          "duration_minutes": { "type": "integer", "minimum": 0 },
          "tokens_used": { "type": "integer", "minimum": 0 },
          "status": { "type": "string", "enum": ["completed", "interrupted", "error"] },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      },
      "emitters": ["session-manager"],
      "listeners": ["audit-logger", "token-guard", "metrics-collector"],
      "policies": ["audit"],
      "rate_limit": { "max_per_minute": 5, "max_per_hour": 50 },
      "severity": "high",
      "enabled": true
    },
    "security.violation": {
      "description": "Fired when security policy is violated",
      "category": "security",
      "schema": {
        "type": "object",
        "required": ["violation_type", "severity", "details"],
        "properties": {
          "violation_type": {
            "type": "string",
            "enum": [
              "unauthorized_emit",
              "unauthorized_listen",
              "rate_limit_exceeded",
              "schema_invalid",
              "policy_violation"
            ]
          },
          "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
          "details": { "type": "object" },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      },
      "emitters": ["governance-layer"],
      "listeners": ["audit-logger", "alert-manager"],
      "policies": ["audit", "alert"],
      "rate_limit": { "max_per_minute": 100, "max_per_hour": 1000 },
      "severity": "critical",
      "enabled": true
    },
    "audit.event": {
      "description": "Fired for audit trail logging",
      "category": "audit",
      "schema": {
        "type": "object",
        "required": ["action", "actor", "resource"],
        "properties": {
          "action": { "type": "string" },
          "actor": { "type": "string" },
          "resource": { "type": "string" },
          "result": { "type": "string", "enum": ["success", "failure"] },
          "details": { "type": "object" },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      },
      "emitters": ["governance-layer", "audit-logger"],
      "listeners": ["audit-logger"],
      "policies": ["audit"],
      "rate_limit": { "max_per_minute": 1000, "max_per_hour": 10000 },
      "severity": "low",
      "enabled": true
    }
  },
  "permissions": {
    "orchestrator": {
      "can_emit": ["dispatch.started", "dispatch.completed", "agent.dispatched", "agent.completed"],
      "can_listen": ["session.started", "session.ended", "security.violation"],
      "can_audit": true,
      "trust_level": "high"
    },
    "session-manager": {
      "can_emit": ["session.started", "session.ended"],
      "can_listen": ["dispatch.started", "dispatch.completed", "agent.completed"],
      "can_audit": true,
      "trust_level": "high"
    },
    "token-guard": {
      "can_emit": [],
      "can_listen": [
        "dispatch.started",
        "dispatch.completed",
        "agent.dispatched",
        "agent.completed",
        "session.started",
        "session.ended"
      ],
      "can_audit": true,
      "trust_level": "high"
    },
    "audit-logger": {
      "can_emit": ["audit.event"],
      "can_listen": ["security.violation", "audit.event"],
      "can_audit": true,
      "trust_level": "high"
    },
    "metrics-collector": {
      "can_emit": [],
      "can_listen": ["dispatch.completed", "agent.completed", "session.ended"],
      "can_audit": false,
      "trust_level": "medium"
    },
    "alert-manager": {
      "can_emit": [],
      "can_listen": ["security.violation"],
      "can_audit": false,
      "trust_level": "medium"
    }
  },
  "global_policies": {
    "require_schema_validation": true,
    "require_permission_check": true,
    "require_audit_logging": true,
    "enable_rate_limiting": true,
    "enable_security_checks": true,
    "max_event_size_bytes": 10240,
    "event_retention_days": 30,
    "audit_retention_days": 90
  }
}
