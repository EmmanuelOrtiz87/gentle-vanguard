{
  "version": "1.0.0",
  "description": "System Prompt Tiering Configuration",
  "strategy": "lazy-loading-with-tiering",
  "tiers": {
    "hot": {
      "description": "Always loaded - Core functionality",
      "maxTokens": 500,
      "files": [
        "CLAUDE.md#core-rules",
        "AGENTS.md#tool-detection",
        "rules/NORMATIVAS-JSON-CONSTRUCTION.md"
      ],
      "inlined": true,
      "cache": "permanent"
    },
    "warm": {
      "description": "Loaded on demand by task type",
      "maxTokens": 1500,
      "triggeredBy": {
        "code-modification": [
          "rules/NORMATIVAS-CODIGO.md",
          "rules/DEVELOPMENT-STANDARDS.md"
        ],
        "git-operations": [
          "rules/NORMATIVAS-GIT.md"
        ],
        "security-privacy": [
          "rules/NORMATIVAS-GDPR.md"
        ],
        "performance": [
          "rules/NORMATIVAS-PERFORMANCE.md"
        ]
      },
      "cache": "session",
      "ttl": "1h"
    },
    "cold": {
      "description": "Reference only",
      "maxTokens": 75000,
      "files": [
        "rules/NORMATIVAS-MULTI-REPO.md",
        "rules/NORMATIVAS-FALLBACK-STRATEGY.md"
      ],
      "inlined": false,
      "referenceFormat": "[REF:file#section]",
      "cache": "disk",
      "ttl": "24h"
    }
  },
  "compression": {
    "enabled": true,
    "abbreviations": {
      "impl": "implementation",
      "fn": "function",
      "cfg": "configuration"
    }
  },
  "dynamicInjection": {
    "enabled": true,
    "triggerPatterns": {
      "codegraph": ["codegraph", "symbol", "caller"],
      "sdd": ["sdd", "feature", "implement"],
      "security": ["security", "auth", "privacy"]
    },
    "maxInjectedTokens": 2000
  },
  "resolver": {
    "enabled": true,
    "script": "scripts/utilities/normativa-resolver.ps1",
    "cacheDir": ".session/normativa-cache"
  }
}
