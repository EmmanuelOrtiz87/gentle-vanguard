{
  "version": "1.0.0",
  "description": "Gentle-Vanguard Project - Performance Targets Configuration",
  "targets": {
    "api_response_time": {
      "value": 5000,
      "unit": "ms",
      "percentile": "p99",
      "description": "API endpoint response time",
      "category": "latency"
    },
    "database_query_time": {
      "value": 100,
      "unit": "ms",
      "percentile": "p95",
      "description": "Database query execution time",
      "category": "latency"
    },
    "cache_hit_time": {
      "value": 1,
      "unit": "ms",
      "percentile": "p50",
      "description": "Cache hit response time",
      "category": "latency"
    },
    "page_load_time": {
      "value": 3000,
      "unit": "ms",
      "percentile": "p95",
      "description": "Page load time",
      "category": "latency"
    },
    "search_response_time": {
      "value": 2000,
      "unit": "ms",
      "percentile": "p95",
      "description": "Search query response time",
      "category": "latency"
    },
    "memory_usage": {
      "value": 500,
      "unit": "MB",
      "percentile": "p95",
      "description": "Application memory usage",
      "category": "resource"
    },
    "cpu_usage": {
      "value": 80,
      "unit": "%",
      "percentile": "p95",
      "description": "CPU utilization",
      "category": "resource"
    },
    "disk_usage": {
      "value": 80,
      "unit": "%",
      "percentile": "p95",
      "description": "Disk space utilization",
      "category": "resource"
    },
    "network_bandwidth": {
      "value": 80,
      "unit": "%",
      "percentile": "p95",
      "description": "Network bandwidth utilization",
      "category": "resource"
    },
    "throughput": {
      "value": 1000,
      "unit": "requests/sec",
      "percentile": "p50",
      "description": "Application throughput",
      "category": "throughput"
    },
    "error_rate": {
      "value": 0.1,
      "unit": "%",
      "percentile": "p99",
      "description": "Application error rate",
      "category": "reliability"
    },
    "cache_hit_rate": {
      "value": 90,
      "unit": "%",
      "percentile": "p50",
      "description": "Cache hit rate",
      "category": "efficiency"
    }
  },
  "benchmarks": [
    {
      "name": "api-get-user",
      "description": "GET /api/users/:id",
      "endpoint": "/api/users/123",
      "method": "GET",
      "target": 500,
      "unit": "ms",
      "category": "api"
    },
    {
      "name": "api-list-users",
      "description": "GET /api/users",
      "endpoint": "/api/users",
      "method": "GET",
      "target": 1000,
      "unit": "ms",
      "category": "api"
    },
    {
      "name": "api-create-user",
      "description": "POST /api/users",
      "endpoint": "/api/users",
      "method": "POST",
      "target": 1500,
      "unit": "ms",
      "category": "api"
    },
    {
      "name": "search-benchmark",
      "description": "POST /api/search",
      "endpoint": "/api/search",
      "method": "POST",
      "target": 2000,
      "unit": "ms",
      "category": "search"
    },
    {
      "name": "database-query",
      "description": "Simple database query",
      "target": 100,
      "unit": "ms",
      "category": "database"
    },
    {
      "name": "cache-lookup",
      "description": "Cache lookup operation",
      "target": 1,
      "unit": "ms",
      "category": "cache"
    }
  ],
  "profiling": {
    "tools": [
      {
        "name": "cpu-profiler",
        "description": "CPU profiling tool",
        "enabled": true
      },
      {
        "name": "memory-profiler",
        "description": "Memory profiling tool",
        "enabled": true
      },
      {
        "name": "io-profiler",
        "description": "I/O profiling tool",
        "enabled": true
      },
      {
        "name": "network-profiler",
        "description": "Network profiling tool",
        "enabled": true
      }
    ],
    "schedule": {
      "beforeOptimization": true,
      "afterOptimization": true,
      "weekly": true,
      "onRegression": true,
      "beforeRelease": true
    }
  },
  "optimization": {
    "strategies": [
      {
        "name": "caching",
        "description": "Implement multi-level caching",
        "priority": "high",
        "expectedImprovement": "40-60%"
      },
      {
        "name": "database-optimization",
        "description": "Optimize database queries",
        "priority": "high",
        "expectedImprovement": "30-50%"
      },
      {
        "name": "code-optimization",
        "description": "Optimize application code",
        "priority": "medium",
        "expectedImprovement": "10-20%"
      },
      {
        "name": "network-optimization",
        "description": "Optimize network I/O",
        "priority": "medium",
        "expectedImprovement": "20-30%"
      },
      {
        "name": "resource-pooling",
        "description": "Implement resource pooling",
        "priority": "low",
        "expectedImprovement": "5-10%"
      }
    ]
  },
  "monitoring": {
    "metrics": [
      {
        "name": "response_time_p50",
        "description": "Response time 50th percentile",
        "unit": "ms",
        "alertThreshold": 2500
      },
      {
        "name": "response_time_p95",
        "description": "Response time 95th percentile",
        "unit": "ms",
        "alertThreshold": 4000
      },
      {
        "name": "response_time_p99",
        "description": "Response time 99th percentile",
        "unit": "ms",
        "alertThreshold": 5000
      },
      {
        "name": "throughput",
        "description": "Requests per second",
        "unit": "req/s",
        "alertThreshold": 500
      },
      {
        "name": "error_rate",
        "description": "Error rate percentage",
        "unit": "%",
        "alertThreshold": 0.5
      },
      {
        "name": "memory_usage",
        "description": "Memory usage",
        "unit": "MB",
        "alertThreshold": 400
      },
      {
        "name": "cpu_usage",
        "description": "CPU utilization",
        "unit": "%",
        "alertThreshold": 70
      },
      {
        "name": "cache_hit_rate",
        "description": "Cache hit rate",
        "unit": "%",
        "alertThreshold": 80
      }
    ],
    "dashboards": [
      {
        "name": "performance-overview",
        "description": "Overall performance metrics",
        "refreshInterval": 30,
        "unit": "seconds"
      },
      {
        "name": "latency-analysis",
        "description": "Detailed latency analysis",
        "refreshInterval": 60,
        "unit": "seconds"
      },
      {
        "name": "resource-utilization",
        "description": "Resource utilization metrics",
        "refreshInterval": 60,
        "unit": "seconds"
      },
      {
        "name": "cache-performance",
        "description": "Cache performance metrics",
        "refreshInterval": 30,
        "unit": "seconds"
      }
    ]
  },
  "testing": {
    "loadTest": {
      "enabled": true,
      "tool": "k6",
      "scenarios": [
        {
          "name": "normal-load",
          "vus": 100,
          "duration": "5m",
          "description": "Normal load test"
        },
        {
          "name": "peak-load",
          "vus": 500,
          "duration": "10m",
          "description": "Peak load test"
        },
        {
          "name": "stress-test",
          "vus": 1000,
          "duration": "15m",
          "description": "Stress test"
        }
      ]
    },
    "spikeTest": {
      "enabled": true,
      "tool": "k6",
      "description": "Test system response to sudden traffic spikes"
    },
    "enduranceTest": {
      "enabled": true,
      "tool": "k6",
      "duration": "24h",
      "description": "Test system stability over extended period"
    }
  },
  "reporting": {
    "frequency": "weekly",
    "format": "html",
    "metrics": ["response_time", "throughput", "error_rate", "resource_usage", "cache_performance"],
    "comparisons": ["baseline", "previous_week", "target"]
  }
}
