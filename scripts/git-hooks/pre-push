#!/bin/sh
# pre-push hook - governance-aligned pre-push checks

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"

if [ -z "$REPO_ROOT" ]; then
    exit 0
fi

GITFLOW_SCRIPT="$REPO_ROOT/scripts/diagnostics/validate-gitflow.ps1"
GOV_SCRIPT="$REPO_ROOT/scripts/diagnostics/validate-script-governance.ps1"
HOMOLOGATE_SCRIPT="$REPO_ROOT/scripts/validation/homologate-workspace.ps1"

echo "[pre-push] Running governance checks..."

if [ -f "$GITFLOW_SCRIPT" ]; then
    if command -v pwsh >/dev/null 2>&1; then
        pwsh -NoProfile -ExecutionPolicy Bypass -File "$GITFLOW_SCRIPT"
    else
        powershell -NoProfile -ExecutionPolicy Bypass -File "$GITFLOW_SCRIPT"
    fi
    if [ $? -ne 0 ]; then
        echo "[pre-push][ERROR] GitFlow policy validation failed"
        exit 1
    fi
fi

if command -v gga >/dev/null 2>&1; then
    GGA_OUTPUT="$(gga run --no-cache 2>&1)"
    GGA_EXIT=$?

    # Hide noisy env dumps (declare -x ...) while preserving actionable output.
    printf '%s\n' "$GGA_OUTPUT" | while IFS= read -r line; do
        case "$line" in
            "declare -x "*) ;;
            *) printf '%s\n' "$line" ;;
        esac
    done

    if [ $GGA_EXIT -ne 0 ]; then
        echo "[pre-push][ERROR] gga local check failed"
        exit 1
    fi
else
    echo "[pre-push][WARN] gga not found. Skipping gga check."
fi

if [ -f "$GOV_SCRIPT" ]; then
    if command -v pwsh >/dev/null 2>&1; then
        pwsh -NoProfile -ExecutionPolicy Bypass -File "$GOV_SCRIPT" -SkipFallbackTests
    else
        powershell -NoProfile -ExecutionPolicy Bypass -File "$GOV_SCRIPT" -SkipFallbackTests
    fi
    if [ $? -ne 0 ]; then
        echo "[pre-push][ERROR] governance validation failed"
        exit 1
    fi
fi

if [ -f "$HOMOLOGATE_SCRIPT" ]; then
    if command -v pwsh >/dev/null 2>&1; then
        pwsh -NoProfile -ExecutionPolicy Bypass -File "$HOMOLOGATE_SCRIPT" -FailOnChanges
    else
        powershell -NoProfile -ExecutionPolicy Bypass -File "$HOMOLOGATE_SCRIPT" -FailOnChanges
    fi
    if [ $? -ne 0 ]; then
        echo "[pre-push][ERROR] homologation drift detected"
        echo "[pre-push][INFO] Run: .\\scripts\\utilities\\wf.ps1 homologate apply"
        exit 1
    fi
fi

echo "[pre-push] All governance checks passed"
exit 0
