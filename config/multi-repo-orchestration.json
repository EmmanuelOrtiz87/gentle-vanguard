{
  "multiRepoOrchestration": {
    "enabled": true,
    "version": "1.0.0",
    "strategy": "hybrid",
    "lastUpdated": "2026-05-12T19:55:00Z",
    
    "strategies": {
      "monorepo": {
        "enabled": true,
        "name": "Monorepo (v3.0 target)",
        "description": "Single repository with multiple projects",
        "targetVersion": "3.0.0",
        "workspaceManager": "pnpm",
        "structure": {
          "apps": "Deployable applications",
          "packages": "Shared libraries",
          "skills": "MCP skills (127+)",
          "infrastructure": "Terraform, Kubernetes",
          "docs": "Documentation",
          "scripts": "Shared utilities"
        }
      },
      "polyrepo": {
        "enabled": false,
        "name": "Polyrepo (v3.x community phase)",
        "description": "Multiple independent repositories",
        "targetVersion": "3.5.0",
        "orchestrator": "gentle-vanguard-sync",
        "repositories": [
          "gentle-vanguard-core",
          "gentle-vanguard-web-ui",
          "gentle-vanguard-plugins",
          "gentle-vanguard-marketplace"
        ]
      },
      "hybrid": {
        "enabled": true,
        "name": "Hybrid (Recommended current)",
        "description": "Monorepo for core + polyrepo for community",
        "coreStructure": "monorepo",
        "communityStructure": "polyrepo",
        "syncTool": "gentle-vanguard-sync"
      }
    },
    
    "monorepoConfig": {
      "root": "gentle-vanguard/",
      "workspaceManager": "pnpm",
      "workspaceFile": "pnpm-workspace.yaml",
      "workspaces": {
        "apps": ["web-dashboard", "api-gateway", "cli"],
        "packages": ["core-sdk", "ui-components", "types", "utils"],
        "skills": "skills/*"
      },
      "dependencies": {
        "pnpm": "^9.0.0",
        "turbo": "^1.12.0",
        "typescript": "^5.3.0"
      },
      "scripts": {
        "setup": "pnpm install",
        "build": "pnpm -r build",
        "test": "pnpm -r test",
        "dev": "pnpm -r --parallel dev",
        "lint": "pnpm -r lint",
        "clean": "pnpm -r clean && rm -rf node_modules"
      }
    },
    
    "versionManagement": {
      "centralVersionFile": "VERSION_MANIFEST.json",
      "syncStrategy": "atomic",
      "breakingChangeHandling": {
        "enabled": true,
        "notificationChannels": ["github-issue", "slack", "email"],
        "depreciationPeriod_months": 6
      },
      "changelog": {
        "file": "CHANGELOG.md",
        "format": "keepachangelog",
        "perPackage": false
      }
    },
    
    "cicd": {
      "platform": "github-actions",
      "workflow": ".github/workflows/monorepo-ci.yml",
      "changeDetection": {
        "enabled": true,
        "strategy": "git-diff"
      },
      "buildMatrices": [
        {
          "os": ["ubuntu-latest", "macos-latest", "windows-latest"],
          "node": ["18", "20"],
          "pwsh": ["7.3", "7.4"]
        }
      ]
    },
    
    "governance": {
      "codeowners": ".github/CODEOWNERS",
      "branchProtection": {
        "main": {
          "requiredStatusChecks": true,
          "requiredReviews": 2,
          "enforceAdmins": true
        },
        "develop": {
          "requiredStatusChecks": true,
          "requiredReviews": 1,
          "enforceAdmins": false
        }
      }
    },
    
    "polyrepoSync": {
      "enabled": false,
      "tool": "gentle-vanguard-sync",
      "schedule": "0 */6 * * *",
      "sources": [
        {
          "repo": "gentle-vanguard-core",
          "path": "skills/",
          "syncMode": "mirror"
        }
      ],
      "targets": [
        {
          "repo": "gentle-vanguard-plugins",
          "path": "node_modules/@gentle-vanguard/skills",
          "syncMode": "merge"
        }
      ]
    },
    
    "migration": {
      "currentPhase": "phase-4",
      "targetPhase": "phase-6",
      "timeline": {
        "phase1_planning": "Week 1",
        "phase2_setup": "Week 2",
        "phase3_migration": "Weeks 3-4",
        "phase4_validation": "Week 5",
        "phase5_release": "Week 6",
        "phase6_stabilization": "Weeks 7-8"
      },
      "checkpoints": [
        "Package boundaries defined",
        "Root config created",
        "All apps moved",
        "All tests passing",
        "Performance benchmarks OK",
        "Documentation complete",
        "v3.0.0 released"
      ]
    }
  }
}

