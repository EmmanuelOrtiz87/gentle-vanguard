{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpenCode Configuration Schema",
  "description": "Schema de validación para opencode.json - SOLO propiedades oficiales de OpenCode. NO agregar props custom.",
  "type": "object",
  "properties": {
    "$schema": { "type": "string", "description": "JSON Schema reference" },
    "model": { "type": "string", "description": "Default model ID" },
    "small_model": { "type": "string", "description": "Small/fast model ID" },
    "agent": { "type": "object", "description": "Agent configurations" },
    "attachment": { "type": "boolean", "description": "Enable file attachments" },
    "autoshare": { "type": "boolean", "description": "Auto-share sessions" },
    "autoupdate": { "type": "boolean", "description": "Auto-update OpenCode" },
    "command": { "type": "array", "items": { "type": "string" }, "description": "Custom commands" },
    "compaction": { "type": "object", "description": "Context compaction settings" },
    "default_agent": { "type": "string", "description": "Default agent name" },
    "disabled_providers": { "type": "array", "items": { "type": "string" }, "description": "Disabled provider IDs" },
    "enabled_providers": { "type": "array", "items": { "type": "string" }, "description": "Enabled provider IDs" },
    "enterprise": { "type": "object", "description": "Enterprise settings" },
    "experimental": { "type": "object", "description": "Experimental features" },
    "formatter": { "type": "object", "description": "Formatter config" },
    "instructions": { "type": "string", "description": "Additional system instructions" },
    "layout": { "type": "string", "description": "Layout mode" },
    "logLevel": { "type": "string", "enum": ["DEBUG","INFO","WARN","ERROR"], "description": "Log level" },
    "lsp": { "type": "object", "description": "LSP configuration" },
    "mcp": { "type": "object", "description": "MCP server configuration" },
    "mode": { "type": "string", "description": "Agent mode (plan/code/ask)" },
    "permission": { "type": "object", "description": "Permission policies" },
    "plugin": { "type": "object", "description": "Plugin configuration" },
    "provider": { "type": "object", "description": "AI provider configurations" },
    "reference": { "type": "object", "description": "Reference repositories" },
    "server": { "type": "object", "description": "OpenCode server config" },
    "share": { "type": "string", "description": "Share mode (manual/auto)" },
    "shell": { "type": "string", "description": "Shell command" },
    "skills": { "type": "object", "description": "Skills configuration" },
    "snapshot": { "type": "object", "description": "Snapshot configuration" },
    "tools": { "type": "object", "description": "Tool permissions" },
    "tool_output": { "type": "object", "description": "Tool output settings" },
    "username": { "type": "string", "description": "OpenCode username" },
    "watcher": { "type": "object", "description": "File watcher config" }
  },
  "additionalProperties": false
}
