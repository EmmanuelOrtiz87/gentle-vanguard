{
  "enabled": true,
  "version": "1.0",
  "orchestrator_integration": {
    "description": "Judgment Day integration with project orchestrator",
    "auto_trigger_events": [
      "pre-push",
      "pre-merge-commit",
      "pr-created",
      "pr-ready-for-merge"
    ],
    "coordinate_with_ci": true,
    "fail_ci_on_judgment_failure": true
  },
  "workflow_stages": {
    "pre_push": {
      "enabled": true,
      "description": "Run Judgment Day before pushing to remote",
      "trigger_on_branch_patterns": [
        "feature/*",
        "bugfix/*",
        "hotfix/*",
        "release/*"
      ],
      "skip_on_branch_patterns": [
        "main",
        "develop"
      ],
      "scope": "changed_files",
      "require_approval": true,
      "fail_on_critical": true,
      "fail_on_real_warnings": false,
      "max_iterations": 2,
      "auto_fix_suggestions": true
    },
    "pre_merge": {
      "enabled": true,
      "description": "Run Judgment Day before merging PR",
      "trigger_on_branch_patterns": [
        "feature/*",
        "bugfix/*",
        "hotfix/*",
        "release/*"
      ],
      "scope": "pr_files",
      "require_approval": true,
      "require_both_reviewers": true,
      "fail_on_critical": true,
      "fail_on_real_warnings": true,
      "max_iterations": 2,
      "auto_label_pr": true,
      "block_merge_on_failure": true
    },
    "session_start": {
      "enabled": true,
      "description": "Initialize Judgment Day on session start",
      "register_hooks": true,
      "setup_git_integration": true,
      "validate_configuration": true
    }
  },
  "reviewer_coordination": {
    "require_both_reviewers": true,
    "reviewer_approval_threshold": 2,
    "allow_self_approval": false,
    "approval_patterns": [
      "LGTM",
      "Approved",
      "",
      "approved"
    ],
    "rejection_patterns": [
      "NACK",
      "Rejected",
      "",
      "rejected",
      "needs work"
    ]
  },
  "pr_merge_policy": {
    "block_on_judgment_failure": true,
    "require_judgment_approval": true,
    "require_all_checks_pass": true,
    "auto_label_judgment_status": true,
    "labels": {
      "judgment_approved": "judgment-day-approved ",
      "judgment_failed": "judgment-day-failed ",
      "judgment_pending": "judgment-day-pending ",
      "judgment_escalated": "judgment-day-escalated "
    }
  },
  "decision_tree": {
    "no_issues_found": {
      "action": "APPROVED",
      "message": "Code passes Judgment Day review",
      "allow_merge": true
    },
    "confirmed_critical": {
      "action": "BLOCK",
      "message": "CRITICAL issues found - must fix before merge",
      "allow_merge": false,
      "auto_fix": false
    },
    "confirmed_real_warnings": {
      "action": "BLOCK",
      "message": "Real WARNINGs found - must fix before merge",
      "allow_merge": false,
      "auto_fix": true
    },
    "theoretical_warnings": {
      "action": "INFO",
      "message": "Theoretical WARNINGs reported - may proceed",
      "allow_merge": true,
      "auto_fix": false
    },
    "suggestions": {
      "action": "SUGGESTION",
      "message": "Suggestions for improvement",
      "allow_merge": true,
      "auto_fix": true
    }
  },
  "escalation_policy": {
    "after_iterations": 2,
    "escalation_action": "ask_user",
    "escalation_message": "Issues remain after 2 fix iterations. Continue iterating or escalate?",
    "max_total_iterations": 5,
    "auto_escalate_after_max": true
  },
  "logging_and_reporting": {
    "enabled": true,
    "log_path": ".session/judgment-day-logs",
    "log_level": "INFO",
    "archive_after_days": 7,
    "generate_report": true,
    "report_format": "markdown",
    "report_path": "docs/sessions/judgment-day-reports"
  },
  "integration_points": {
    "event_bus": {
      "enabled": true,
      "publish_events": [
        "judgment-day-initiated",
        "judgment-day-judges-started",
        "judgment-day-verdict-ready",
        "judgment-day-fixes-applied",
        "judgment-day-approved",
        "judgment-day-escalated"
      ]
    },
    "session_orchestrator": {
      "enabled": true,
      "coordinate_with_workflow": true,
      "update_session_status": true
    },
    "ci_cd": {
      "enabled": true,
      "fail_build_on_judgment_failure": true,
      "report_to_ci": true
    }
  }
}