{
  "version": "1.0",
  "description": "Skill dependency graph - defines execution order constraints",
  "dependencies": {
    "sdd-apply": {
      "requires": ["sdd-design", "sdd-spec"],
      "reason": "Implementation needs completed design and specs",
      "blocking": true
    },
    "sdd-verify": {
      "requires": ["sdd-apply"],
      "reason": "Verification needs implemented code",
      "blocking": true
    },
    "sdd-archive": {
      "requires": ["sdd-verify"],
      "reason": "Archive needs verified implementation",
      "blocking": true
    },
    "sdd-tasks": {
      "requires": ["sdd-spec"],
      "reason": "Task breakdown needs completed specs",
      "blocking": false
    },
    "sdd-design": {
      "requires": ["sdd-explore"],
      "reason": "Design needs exploration findings",
      "blocking": false
    },
    "sdd-spec": {
      "requires": ["sdd-propose"],
      "reason": "Specs need approved proposal",
      "blocking": false
    }
  },
  "ordering_rules": {
    "sdd-explore": 1,
    "sdd-propose": 2,
    "sdd-design": 3,
    "sdd-spec": 4,
    "sdd-tasks": 5,
    "sdd-apply": 6,
    "sdd-verify": 7,
    "sdd-archive": 8
  },
  "resolution_strategy": {
    "auto_wait": true,
    "timeout_seconds": 600,
    "escalate_on_timeout": true
  }
}
