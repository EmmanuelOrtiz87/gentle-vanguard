{
  "tool": "cline",
  "displayName": "Cline",
  "version": "latest",
  "preProcess": {
    "loadSkills": true,
    "skillTool": "skill",
    "autoLoad": true,
    "mcpBridge": true
  },
  "capabilities": ["mcp", "skills", "code_completion", "terminal"],
  "configFiles": [".clinerules", ".cline/config.json"],
  "adapter": {
    "type": "mcp-bridge",
    "path": "adapters/mcp-bridge",
    "status": "available"
  },
  "hooks": {
    "preToolCall": "scripts/utilities/pre-process-input.ps1",
    "sessionStart": "scripts/utilities/session-autostart.cmd"
  }
}
