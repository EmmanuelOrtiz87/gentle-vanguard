    "adaptive_mode":  {
                          "enabled":  true,
                          "integration":  "orchestrator",
                          "feedback_loop_support":  true,
                          "rollback_support":  true,
                          "auto_detect_integration":  true,
                          "complexity_detection":  {
                                                       "enabled":  true,
                                                       "min_agents_for_adaptive":  2,
                                                       "complexity_keywords":  [
                                                                                   "multi-phase",
                                                                                   "feedback-loop",
                                                                                   "rollback",
                                                                                   "cross-team",
                                                                                   "high-risk"
                                                                               ]
                                                   }
                      },
    "agentProfiles":  {
                          "BA":  {
                                     "temperature":  0.7,
                                     "hallucinationGuard":  "low",
                                     "requiredEvidence":  [ "at least 3 clarification questions answered", "problem statement documented" ],
                                     "hedgingBlocked":  false,
                                     "maxRetries":  2,
                                     "escalateOnFailure":  "orchestrator",
                                     "rationale":  "BA explores and asks questions - creative latitude needed"
                                 },
                          "SAD":  {
                                      "temperature":  0.3,
                                      "hallucinationGuard":  "medium",
                                      "requiredEvidence":  [ "architecture decision documented", "API contract defined", "at least 1 tradeoff explained" ],
                                      "hedgingBlocked":  false,
                                      "maxRetries":  2,
                                      "escalateOnFailure":  "orchestrator",
                                      "rationale":  "SAD decides with precision - must justify decisions but needs some reasoning latitude"
                                  },
                          "DEV":  {
                                      "temperature":  0.15,
                                      "hallucinationGuard":  "high",
                                      "requiredEvidence":  [ "file exists on disk", "no lint/compile errors", "at least 1 test covers the change" ],
                                      "hedgingBlocked":  true,
                                      "maxRetries":  3,
                                      "escalateOnFailure":  "QA",
                                      "rationale":  "DEV writes code - deterministic, no invention, must be verifiable"
                                  },
                          "QA":  {
                                     "temperature":  0.1,
                                     "hallucinationGuard":  "critical",
                                     "requiredEvidence":  [ "test file exists", "test passes (exit code 0)", "coverage report generated" ],
                                     "hedgingBlocked":  true,
                                     "maxRetries":  1,
                                     "escalateOnFailure":  "orchestrator",
                                     "rationale":  "QA is binary pass/fail - no ambiguity allowed"
                                 },
                          "OPS":  {
                                      "temperature":  0.1,
                                      "hallucinationGuard":  "critical",
                                      "requiredEvidence":  [ "deployment config validated", "rollback plan documented", "environment verified" ],
                                      "hedgingBlocked":  true,
                                      "maxRetries":  1,
                                      "escalateOnFailure":  "orchestrator",
                                      "rationale":  "OPS touches production - error = outage"
                                  },
                          "GOV":  {
                                      "temperature":  0.1,
                                      "hallucinationGuard":  "critical",
                                      "requiredEvidence":  [ "audit trail with file path and line", "no secrets detected", "compliance checklist signed off" ],
                                      "hedgingBlocked":  true,
                                      "maxRetries":  1,
                                      "escalateOnFailure":  "orchestrator",
                                      "rationale":  "GOV is security/compliance - zero tolerance for ambiguity"
                                  },
                          "DOC":  {
                                      "temperature":  0.4,
                                      "hallucinationGuard":  "low",
                                      "requiredEvidence":  [ "doc file written to disk", "all referenced paths exist" ],
                                      "hedgingBlocked":  false,
                                      "maxRetries":  2,
                                      "escalateOnFailure":  "orchestrator",
                                      "rationale":  "DOC needs clarity and style - some creative latitude acceptable"
                                  },
                          "GITFLOW":  {
                                          "temperature":  0.1,
                                          "hallucinationGuard":  "critical",
                                          "requiredEvidence":  [ "branch name matches naming convention", "commit follows conventional commits format", "no push to protected branch (main/develop) without PR" ],
                                          "hedgingBlocked":  true,
                                          "maxRetries":  1,
                                          "escalateOnFailure":  "orchestrator",
                                          "rationale":  "GitFlow is structural governance - wrong branch = broken history",
                                          "aliases":  [ "GITFLOW-BRANCH", "GITFLOW-PR", "GITFLOW-HOOKS", "GITFLOW-MERGE", "GITFLOW-WORKFLOW", "GITFLOW-COMMIT", "GITFLOW-CONFLICT" ]
                                      },
                          "SCRIPT":  {
                                         "temperature":  0.15,
                                         "hallucinationGuard":  "high",
                                         "requiredEvidence":  [ "script parses without syntax errors (pwsh -NoProfile -Command)", "no hardcoded secrets", "idempotent execution verified" ],
                                         "hedgingBlocked":  true,
                                         "maxRetries":  2,
                                         "escalateOnFailure":  "orchestrator",
                                         "rationale":  "Scripts are automation - a bad script runs unattended and causes damage",
                                         "aliases":  [ "SCRIPT-GOV" ]
                                     },
                          "hallucinationGuardLevels":  {
                                                           "low":      "Log only - agent self-reports output, no external verification",
                                                           "medium":   "Spot-check - orchestrator verifies at least 1 requiredEvidence item",
                                                           "high":     "Full check - ALL requiredEvidence items verified before task marked done",
                                                           "critical": "Full check + hedging language scan + external command verification required"
                                                       }
                      }
