# =============================================================================
# Workspace Foundation - Environment Variables
# =============================================================================
# Copy this file to .env.local and configure the required variables
# NEVER commit .env.local - it contains sensitive information
# =============================================================================

# =============================================================================
# AI Provider API Keys (Optional - for external tool access)
# =============================================================================
# Only needed when orchestrator enables external tools (websearch, codesearch)
# Local-first policy: Deny by default, see docs/guides/LOCAL-FIRST-POLICY.md

# OpenRouter (for opencode.json provider)
# OPENROUTER_API_KEY=sk-or-v1-...

# Anthropic (direct Claude access)
# ANTHROPIC_API_KEY=sk-ant-...

# Dify.io (for Cline plugin)
# DIFY_API_KEY=...

# Context7 MCP (for codesearch when enabled)
# CONTEXT7_API_KEY=...

# Notion MCP (for knowledge base integration)
# NOTION_TOKEN=secret_...
# NOTION_DATABASE_ID=...

# =============================================================================
# Engram Memory Configuration
# =============================================================================
# Engram persistent memory system settings
# See: tools/engram.exe --help

# Engram project name (default: workspace_local)
# ENGRAM_PROJECT=workspace_local

# Engram data directory (default: .engram-data)
# ENGRAM_DATA_DIR=.engram-data

# =============================================================================
# Workspace Paths (Optional - defaults usually work)
# =============================================================================

# Workspace root directory
# WORKSPACE_ROOT=C:\Workspace_local

# Projects directory
# PROJECTS_ROOT=projects

# Tools directory
# TOOLS_ROOT=tools

# =============================================================================
# Session Management
# =============================================================================

# Session ID pattern (default: session-YYYY-MM-DD-XX)
# SESSION_PATTERN=session-YYYY-MM-DD-XX

# Auto-start script (default: tools/session-autostart.cmd)
# SESSION_AUTOSTART_SCRIPT=tools/session-autostart.cmd

# =============================================================================
# Agent Configuration
# =============================================================================

# Default agent (default: default)
# DEFAULT_AGENT=default

# Orchestrator agent (for external tool access)
# ORCHESTRATOR_AGENT=orchestrator

# =============================================================================
# Language & Locale
# =============================================================================

# Default language for AI responses (default: es)
# AI_LANGUAGE=es

# Locale for date/time formatting (default: es-AR)
# AI_LOCALE=es-AR

# =============================================================================
# Token Optimization
# =============================================================================

# Enable prompt caching (default: true)
# ENABLE_PROMPT_CACHE=true

# Compression ratio for context (default: 0.90)
# COMPRESSION_RATIO=0.90

# Max tokens per response (default: 4500)
# MAX_TOKENS=4500

# Temperature for model (default: 0.3 for local-first)
# MODEL_TEMPERATURE=0.3

# =============================================================================
# Notes
# =============================================================================
# 1. Local-first policy: External tools DENIED by default
# 2. Only orchestrator can enable: websearch, codesearch, webfetch
# 3. See opencode.json for agent-specific permissions
# 4. See docs/guides/LOCAL-FIRST-POLICY.md for full details
# =============================================================================
