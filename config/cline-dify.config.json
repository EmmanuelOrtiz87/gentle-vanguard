{
  "name": "Cline VSCode Plugin - Dify.io Integration",
  "version": "1.1.0",
  "description": "Local-first configuration for Cline VSCode plugin using Dify.io as LLM provider",
  "provider": {
    "type": "dify",
    "endpoint": "https://api.dify.io/v1",
    "authMethod": "api-key",
    "requiredEnv": ["DIFY_API_KEY"],
    "notes": "Set DIFY_API_KEY environment variable with your Dify.io API key"
  },
  "tokenOptimization": {
    "enabled": true,
    "profile": "recommended",
    "maxContextWindow": 128000,
    "safetyMargin": 10000,
    "effectiveWindow": 118000,
    "compressionRatio": 0.90,
    "rules": {
      "promptChars": {
        "yellowThreshold": 1100,
        "redThreshold": 1600,
        "unit": "characters"
      },
      "adoptionPercent": {
        "yellowThreshold": 75,
        "redThreshold": 50,
        "unit": "percentage"
      },
      "windowDays": 7
    }
  },
  "contextManagement": {
    "memoryTiering": {
      "hot": {
        "duration": "active session",
        "compression": "none",
        "retention": "100%"
      },
      "warm": {
        "duration": "1 day",
        "compression": "light",
        "retention": "90%"
      },
      "cold": {
        "duration": "7 days",
        "compression": "aggressive",
        "retention": "70%"
      }
    },
    "preCompactHook": {
      "enabled": true,
      "triggerAt": 15000,
      "script": "scripts/utilities/pre-compact-hook.ps1",
      "preservePatterns": ["FIXME", "TODO", "BUG", "DECISION", "RESULT"],
      "compressionRatio": 0.90
    },
    "handoffCompression": {
      "enabled": true,
      "script": "scripts/utilities/handoff-compress.ps1",
      "preserves": ["decisions", "results", "FIXMEs", "status flags"],
      "truncates": ["verbose outputs", "repeated patterns"],
      "expectedReduction": "30%"
    }
  },
  "sessionManagement": {
    "autostart": {
      "enabled": true,
      "script": "scripts/utilities/session-autostart.cmd",
      "configFile": "scripts/utilities/session-autostart.config.json"
    },
    "tracking": {
      "project": "workspace_local",
      "directory": "c:\\Workspace_local",
      "sessionIdPattern": "session-YYYY-MM-DD-XX"
    },
    "reliability": {
      "treatReadyAsPass": true,
      "treatPartialAsActionable": true,
      "useFullModeForCritical": true
    }
  },
  "skillLoading": {
    "adaptive": true,
    "triggers": {
      "angular": ["angular-core", "angular-spa"],
      "react": ["react-19"],
      "go": ["golang-api"],
      "docker": ["docker-devops"],
      "powershell": ["workspace-automation"],
      "session": ["session-lifecycle"]
    },
    "rulesPath": "rules/adaptive/"
  },
  "customRules": {
    "enabled": true,
    "loadOrder": ["technical", "business", "review"],
    "paths": {
      "technical": "rules/custom/technical/",
      "business": "rules/custom/business/",
      "review": "rules/custom/review/"
    },
    "ruleIdPrefixes": {
      "technical": "TECH-",
      "business": "BIZ-",
      "review": "REV-"
    }
  },
  "promptEngineering": {
    "systemPromptTemplate": "templates/cline-system-prompt.md",
    "contextInjection": {
      "includeProjectStructure": true,
      "includeActiveSkills": true,
      "includeCustomRules": true,
      "includeSessionContext": true
    },
"responseFormat": {
        "enforceStructure": true,
  "maxResponseTokens": 2000,
        "requireSummary": true,
        "conciseMode": true
      },
    "localFirst": {
      "enabled": true,
      "denyWebSearch": true,
      "denyCodeSearch": true,
      "denyWebFetch": true,
      "note": "External tools only available via orchestrator agent"
    }
  },
  "monitoring": {
    "tokenUsageTracking": true,
    "logFile": "logs/cline-token-usage.log",
    "alertThresholds": {
      "yellowAt": 1100,
      "redAt": 1600
    },
    "reportingInterval": "session-end"
  },
  "integrations": {
    "vscodeSettings": ".vscode/settings.json",
    "gitHooks": "hooks/",
    "workspaceConfig": "config/workspace.config.json"
  },
  "performanceTuning": {
    "cacheResponses": true,
    "cacheDuration": 7200,
    "batchRequests": true,
    "maxBatchSize": 5,
    "requestTimeout": 30000
  }
}