{
    "enabled":  true,
    "confidenceThreshold":  60,
    "maxParallelAgents":  3,
    "fallbackStrategy":  "clarify-ba",
    "loggingEnabled":  true,
    "metricsEnabled":  true,
    "features":  {
                     "keywordExtraction":  true,
                     "decisionTree":  true,
                     "confidenceScoring":  true,
                     "autoRetry":  false,
                     "autoEscalation":  true
                 },
    "thresholds":  {
                       "highConfidence":  80,
                       "mediumConfidence":  60,
                       "lowConfidence":  40
                   },
    "agentCodeToSkill":  {
                             "BA":           "sdd-lifecycle",
                             "GOV":          "judgment-day",
                             "SAD":          "sdd-design",
                             "DEV":          "sdd-apply",
                             "QA":           "sdd-verify",
                             "OPS":          "docker-devops-skill",
                             "DOC":          "documentation-governance",
                             "SCRIPT-GOV":   "script-governance-skill",
                             "REPORT":       "reporting-skill",
                             "PR-REVIEW":    "code-review-orchestrator",
                             "RELEASE":      "release-management-skill",
                             "SESSION-CLOSE": "project-orchestrator-skill",
                             "GITFLOW-BRANCH": "gitflow-orchestrator-skill",
                             "GITFLOW-PR":   "branch-pr",
                             "GITFLOW-HOOKS": "gitflow-orchestrator-skill",
                             "GITFLOW-MERGE": "gitflow-orchestrator-skill",
                             "GITFLOW-WORKFLOW": "git-workflow-skill",
                             "GITFLOW-COMMIT": "git-workflow-skill",
                             "GITFLOW-CONFLICT": "git-workflow-skill"
                         },
    "skillToAgentProfile":  {
                                "code-review-orchestrator":  "QA",
                                "release-management-skill":  "OPS",
                                "project-orchestrator-skill": "GOV",
                                "reporting-skill":           "DOC",
                                "judgment-day":              "GOV",
                                "gitflow-orchestrator-skill": "GOV",
                                "branch-pr":                 "QA",
                                "git-workflow-skill":        "DEV",
                                "script-governance-skill":   "DEV",
                                "sdd-design":                "SAD",
                                "sdd-apply":                 "DEV",
                                "sdd-verify":                "QA",
                                "sdd-lifecycle":             "BA",
                                "docker-devops-skill":       "OPS",
                                "documentation-governance":  "DOC"
                            },
    "clarifyBaStrategy":  {
                              "enabled":  true,
                              "triggerThreshold":  40,
                              "agent":  "BA",
                              "skill":  "sdd-lifecycle",
                              "phase":  "EXPLORE",
                              "action":  "PLAN_MODE_REQUIRED",
                              "instructions":  "Activate AGENT-BA to gather requirements before proceeding. Use sdd-lifecycle EXPLORE phase: understand user needs, constraints, and acceptance criteria. Do NOT implement until BA exploration is complete.",
                              "questions":  [
                                                "What problem are you trying to solve?",
                                                "What does success look like for you?",
                                                "Are there any constraints (time, tech, budget)?",
                                                "Who are the end users affected?",
                                                "What should NOT change?"
                                            ]
                          },
    "unmappedFlows":  {
                          "prReview":  {
                                           "triggers":  [ "pull request", "PR", "create PR", "open PR", "merge", "review PR" ],
                                           "gate":  {
                                                        "agent":  "QA",
                                                        "profile":  "$ref:agentProfiles.QA",
                                                        "requiredBeforeMerge":  [
                                                                                    "all automated checks pass (exit 0)",
                                                                                    "linked issue has status:approved label",
                                                                                    "branch name matches naming convention regex",
                                                                                    "no secrets detected in diff",
                                                                                    "at least 1 reviewer assigned"
                                                                                ],
                                                        "blockMergeIf":  [
                                                                             "any requiredBeforeMerge item fails",
                                                                             "hedging language in PR description (could/should/probably)",
                                                                             "no issue linkage (Closes/Fixes/Resolves #N)"
                                                                         ],
                                                        "escalateOnFailure":  "orchestrator"
                                                    },
                                           "skill":  "code-review-orchestrator",
                                           "dimensions":  [ "Security", "Quality", "Architecture", "Testing", "Docs", "API", "GitFlow" ]
                                       },
                          "releaseManagement":  {
                                                    "triggers":  [ "release", "changelog", "version bump", "ship", "cut release", "release notes", "hotfix", "semver" ],
                                                    "gate":  {
                                                                 "agent":  "OPS",
                                                                 "profile":  "$ref:agentProfiles.OPS",
                                                                 "requiredBeforeRelease":  [
                                                                                               "CHANGELOG.md updated with user-visible changes",
                                                                                               "version bump validated against actual impact (semver)",
                                                                                               "rollback plan documented",
                                                                                               "all QA gates passed",
                                                                                               "no hedging in release notes (verified, not speculative)"
                                                                                           ],
                                                                 "blockReleaseIf":  [
                                                                                        "CHANGELOG.md not updated",
                                                                                        "rollback plan missing",
                                                                                        "QA gate not passed",
                                                                                        "version bump unjustified"
                                                                                    ],
                                                                 "escalateOnFailure":  "orchestrator"
                                                             },
                                                    "skill":  "release-management-skill",
                                                    "govCoReview":  true,
                                                    "govProfile":  "$ref:agentProfiles.GOV"
                                                },
                          "sessionClose":  {
                                               "triggers":  [ "cerrar sesion", "close session", "session end", "guardar sesion", "fin de sesion" ],
                                               "gate":  {
                                                            "agent":  "GOV",
                                                            "profile":  "$ref:agentProfiles.GOV",
                                                            "requiredBeforeClose":  [
                                                                                        "changes summarized (what changed, what is pending)",
                                                                                        "documentation updated if architecture/workflow changed",
                                                                                        "touched work validated (test/build/check)",
                                                                                        "session audit recorded (intended vs completed vs risks)",
                                                                                        "learnings persisted to memory if durable",
                                                                                        "repository state reviewed",
                                                                                        "blockers stated explicitly"
                                                                                    ],
                                                            "blockCloseIf":  [
                                                                                 "audit not recorded",
                                                                                 "open FIXME/TODO items not documented"
                                                                             ],
                                                            "escalateOnFailure":  "orchestrator"
                                                        },
                                               "skill":  "project-orchestrator-skill",
                                               "phase":  "SESSION_CLOSURE_PROTOCOL"
                                           },
                          "reporting":  {
                                            "triggers":  [ "informe", "report", "reporte", "metrics", "dashboard", "resumen ejecutivo", "tokens", "costos", "telemetry", "stats" ],
                                            "gate":  {
                                                         "agents":  [ "DOC", "GOV" ],
                                                         "profiles":  { "DOC":  "$ref:agentProfiles.DOC", "GOV":  "$ref:agentProfiles.GOV" },
                                                         "requiredBeforePublish":  [
                                                                                       "all referenced data paths exist",
                                                                                       "no fabricated metrics (each number has a source file cited)",
                                                                                       "GOV sign-off: no sensitive data exposed in report",
                                                                                       "report file written to disk before presenting"
                                                                                   ],
                                                         "blockPublishIf":  [
                                                                                "any metric has no source citation",
                                                                                "sensitive paths/tokens present in output",
                                                                                "report file missing from disk"
                                                                            ],
                                                         "escalateOnFailure":  "orchestrator"
                                                     },
                                            "skill":  "reporting-skill"
                                        }
                      },
