{
  "name": "windsurf-adapter",
  "version": "1.0.0",
  "description": "Converts Foundation skills to Windsurf plugin format",
  "main": "adapter.js",
  "scripts": {
    "convert-skill": "node adapter.js convert-skill",
    "generate-config": "node adapter.js generate-config"
  },
  "keywords": [
    "foundation",
    "windsurf",
    "plugin",
    "adapter"
  ],
  "dependencies": {
    "fs": "built-in",
    "path": "built-in"
  },
  "foundation": {
    "adapterType": "format-adapter",
    "targetTool": "windsurf",
    "targetFormat": "plugin",
    "compatibility": [
      "Windsurf IDE"
    ]
  }
}
