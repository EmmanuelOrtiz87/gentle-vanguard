{
  "version": "1.0.0",
  "name": "security-expert-rules",
  "description": "Security rules configuration for Workspace Foundation",

  "severity": {
    "critical": {
      "action": "block",
      "exitCode": 1,
      "message": "Critical security issue detected. Commit blocked."
    },
    "high": {
      "action": "warn",
      "exitCode": 0,
      "message": "High severity issue found. Review recommended."
    },
    "medium": {
      "action": "info",
      "exitCode": 0,
      "message": "Medium priority issue. Consider fixing."
    },
    "low": {
      "action": "info",
      "exitCode": 0,
      "message": "Low priority issue. Best practice violation."
    }
  },

  "exclusions": {
    "paths": [
      "**/node_modules/**",
      "**/dist/**",
      "**/build/**",
      "**/coverage/**",
      "**/.git/**",
      "**/vendor/**",
      "**/__pycache__/**",
      "**/venv/**",
      "**/.venv/**",
      "**/test*/**",
      "**/*.test.*",
      "**/*.spec.*",
      "**/examples/**",
      "**/mocks/**"
    ],
    "patterns": ["\\.min\\.(js|css)$", "\\.bundle\\.js$", "\\.compiled\\.ts$"],
    "allowInTest": {
      "password": ["test123", "password123", "Password123!", "Test@123"],
      "api_key": ["test-api-key", "sk_test_1234567890"]
    }
  },

  "secretPatterns": [
    {
      "id": "aws-access-key",
      "pattern": "AKIA[0-9A-Z]{16}",
      "severity": "critical",
      "description": "AWS Access Key ID"
    },
    {
      "id": "aws-secret-key",
      "pattern": "(?i)aws_secret_access_key[\\s]*[=:]?[\\s]*[\\\"\\'][A-Za-z0-9/+=]{40}[\\\"\\']",
      "severity": "critical",
      "description": "AWS Secret Access Key"
    },
    {
      "id": "github-token",
      "pattern": "ghp_[A-Za-z0-9]{36}",
      "severity": "critical",
      "description": "GitHub Personal Access Token"
    },
    {
      "id": "private-key",
      "pattern": "-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----",
      "severity": "critical",
      "description": "Private Key"
    },
    {
      "id": "generic-api-key",
      "pattern": "(?i)(api[_-]?key|apikey)[\\s]*[=:][\\s]*[\\\"\\'][A-Za-z0-9]{20,}[\\\"\\']",
      "severity": "high",
      "description": "Generic API Key"
    },
    {
      "id": "jwt-token",
      "pattern": "eyJ[A-Za-z0-9-_]+\\.[A-Za-z0-9-_]+\\.[A-Za-z0-9-_]+",
      "severity": "high",
      "description": "JWT Token"
    },
    {
      "id": "database-url",
      "pattern": "(?i)(mysql|postgres|postgresql|mongodb)://[^:\\s]+:[^@\\s]+@",
      "severity": "high",
      "description": "Database Connection String with credentials"
    },
    {
      "id": "slack-token",
      "pattern": "xox[baprs]-[0-9]{10,13}-[0-9]{10,13}-[A-Za-z0-9]+",
      "severity": "high",
      "description": "Slack Token"
    },
    {
      "id": "stripe-key",
      "pattern": "sk_live_[0-9a-zA-Z]{24,}",
      "severity": "critical",
      "description": "Stripe Secret Key"
    },
    {
      "id": "sendgrid-key",
      "pattern": "SG\\.[A-Za-z0-9_-]{22}\\.[A-Za-z0-9_-]{43}",
      "severity": "critical",
      "description": "SendGrid API Key"
    },
    {
      "id": "google-api-key",
      "pattern": "AIza[0-9A-Za-z_-]{35}",
      "severity": "high",
      "description": "Google API Key"
    }
  ],

  "vulnerabilityPatterns": [
    {
      "id": "eval-user-input",
      "pattern": "eval\\s*\\(\\s*.*(?:req\\.|request\\.|body\\.|params\\.|query\\.|input\\.)",
      "severity": "critical",
      "category": "Code Injection",
      "cwe": "CWE-95"
    },
    {
      "id": "innerhtml-user-input",
      "pattern": "(innerHTML|outerHTML|insertAdjacentHTML)\\s*\\(\\s*.*(?:req\\.|request\\.|body\\.|params\\.|query\\.)",
      "severity": "high",
      "category": "XSS",
      "cwe": "CWE-79"
    },
    {
      "id": "sql-injection",
      "pattern": "(?:execute|query|select|insert|update|delete).*\\+.*(?:req\\.|request\\.|body\\.|params\\.)",
      "severity": "critical",
      "category": "SQL Injection",
      "cwe": "CWE-89"
    },
    {
      "id": "command-injection",
      "pattern": "(?:exec|spawn|execSync|system|popen|os\\.system|subprocess)\\s*\\(\\s*.*(?:req\\.|request\\.|body\\.|params\\.|query\\.)",
      "severity": "critical",
      "category": "OS Command Injection",
      "cwe": "CWE-78"
    },
    {
      "id": "path-traversal",
      "pattern": "(?:readFile|readFileSync|open|readdir|stat).*\\.join\\(.*(?:req\\.|request\\.|params\\.)",
      "severity": "high",
      "category": "Path Traversal",
      "cwe": "CWE-22"
    },
    {
      "id": "weak-crypto-md5",
      "pattern": "(?:createHash|md5)\\s*\\(",
      "severity": "high",
      "category": "Weak Cryptography",
      "cwe": "CWE-327"
    },
    {
      "id": "cors-allow-all",
      "pattern": "(?:Access-Control-Allow-Origin|CORS)\\s*\\*",
      "severity": "high",
      "category": "CORS Misconfiguration",
      "cwe": "CWE-942"
    },
    {
      "id": "no-rate-limit",
      "pattern": "(?i)(rateLimit|express-rate-limit).*disabled",
      "severity": "high",
      "category": "Missing Rate Limiting",
      "cwe": "CWE-307"
    },
    {
      "id": "yaml-unsafe-load",
      "pattern": "yaml\\.load\\s*\\(",
      "severity": "high",
      "category": "Deserialization",
      "cwe": "CWE-502"
    },
    {
      "id": "pickle-unsafe",
      "pattern": "(?:pickle\\.load|pickle\\.loads)\\s*\\(",
      "severity": "critical",
      "category": "Deserialization",
      "cwe": "CWE-502"
    }
  ],

  "reporting": {
    "format": "markdown",
    "outputPath": "docs/security-review.md",
    "includeCodeSnippets": true,
    "maxSnippets": 5,
    "includeRemediation": true,
    "includeCWE": true
  },

  "interactive": {
    "enabled": true,
    "showDescriptions": true,
    "showRecommendations": true,
    "allowSkip": true,
    "requireJustification": true
  }
}
