{
    "adaptiveRules": {
        "enabled": true,
        "compressionRatio": 0.90,
        "preCompactHook": "tools/pre-compact-hook.ps1",
        "handoffCompress": true,
        "tiers": {
            "hot": {
                "retention": "session",
                "compression": "none"
            },
            "warm": {
                "retention": "1day",
                "compression": "0.90"
            },
            "cold": {
                "retention": "7days",
                "compression": "0.70"
            }
        },
        "prefixAnchors": [
            "FIXME",
            "TODO",
            "BUG",
            "DECISION",
            "RESULT",
            "STATUS:OK",
            "STATUS:ERROR"
        ]
    }
}
