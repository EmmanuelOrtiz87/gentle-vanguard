{
  "workspaceName": "workspace-foundation-portable",
  "dataRoot": "{workspaceRoot}/.engram-data",
  "toolsRoot": "{workspaceRoot}/tools",
  "projectsRoot": "{workspaceRoot}/projects",
  "mcpIntegrations": {},
  "projectTemplate": "{workspaceRoot}/templates/project-root",
  "projectDefaults": {
    "repositoryMode": "template",
    "kind": "service",
    "preset": "default",
    "architecture": "layered",
    "profile": "general",
    "aiModelMode": "none",
    "aiModelProvider": "",
    "aiModelName": "",
    "aiModelEndpoint": "",
    "aiModelNotes": "",
    "repoUrl": "",
    "cloneDir": "",
    "buildCommand": "go build ./...",
    "testCommand": "go test ./...",
    "postInstallCommand": ""
  },
  "projectKinds": ["service", "cli", "library"],
  "tools": [
    {
      "name": "engram",
      "checkCommand": "engram",
      "requires": ["go"],
      "install": {
        "windows": "go install github.com/Gentleman-Programming/engram/cmd/engram@latest",
        "linux": "go install github.com/Gentleman-Programming/engram/cmd/engram@latest",
        "macos": "go install github.com/Gentleman-Programming/engram/cmd/engram@latest"
      }
    },
  ]
}
