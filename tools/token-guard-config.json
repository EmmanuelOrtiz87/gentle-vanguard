{
  "enabled": true,
  "description": "Token Guard - Proteccin automtica contra overflow de tokens",
  "tokenBudget": 128000,
  "alertThreshold": 0.80,
  "pauseThreshold": 0.95,
  "maxRounds": 5,
  "roundTokenBudget": 25600,
  "logPath": "./.session/token-guard.log",
  "enableFragmentation": true,
  "enableAutoDispatchPause": true,
  "enableAlerts": true,
  "monitoring": {
    "checkInterval": 5000,
    "enableRealTimeTracking": true,
    "enableDetailedLogging": true
  },
  "alerting": {
    "alertAt80Percent": true,
    "alertAt90Percent": true,
    "alertAt95Percent": true,
    "pauseAt95Percent": true,
    "notificationMethod": "console"
  },
  "fragmentation": {
    "enabled": true,
    "strategy": "round-robin",
    "maxRoundsPerSession": 5,
    "tokensPerRound": 25600,
    "autoRestartOnCompletion": true
  },
  "dispatch": {
    "autoResume": true,
    "resumeThreshold": 0.70,
    "pauseOnAlert": false,
    "pauseOnCritical": true
  },
  "reporting": {
    "generateReportOnAlert": true,
    "generateReportOnCompletion": true,
    "reportPath": "./.session/token-guard-reports",
    "archiveOldReports": true,
    "archiveAfterDays": 7
  },
  "integration": {
    "integrateWithOrchestrator": true,
    "integrateWithSession": true,
    "updateSessionStateFile": true,
    "exportMetrics": true
  }
}
