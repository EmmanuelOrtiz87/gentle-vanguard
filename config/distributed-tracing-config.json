{
  "distributedTracing": {
    "enabled": true,
    "version": "1.0",
    "telemetryDirectory": ".telemetry",
    "correlationIdFormat": "session-YYYY-MM-DD-XX-XXXXXXXX",
    "spanHierarchy": {
      "enabled": true,
      "maxDepth": 10,
      "parentChildTracking": true
    },
    "metrics": {
      "enabled": true,
      "collectInterval": 5000,
      "exportInterval": 60000,
      "retentionDays": 30
    },
    "reporting": {
      "enabled": true,
      "generateDaily": true,
      "generateOnSessionEnd": true,
      "reportTypes": [
        "daily-summary",
        "performance-analysis",
        "error-analysis",
        "dispatch-metrics"
      ],
      "outputPath": ".telemetry/reports"
    },
    "spans": {
      "types": [
        "session",
        "dispatch",
        "orchestration",
        "automation",
        "operation",
        "task",
        "phase"
      ],
      "exportFormat": "jsonl",
      "compressionEnabled": false
    },
    "performance": {
      "trackLatency": true,
      "trackThroughput": true,
      "trackErrorRate": true,
      "trackResourceUsage": true,
      "samplingRate": 1.0
    },
    "integration": {
      "autoStart": true,
      "autoFinalize": true,
      "propagateCorrelationId": true,
      "captureAttributes": true,
      "captureEvents": true
    },
    "export": {
      "formats": ["json", "jsonl", "markdown"],
      "destinations": [
        ".telemetry/traces",
        ".telemetry/metrics",
        ".telemetry/reports"
      ]
    },
    "alerts": {
      "enabled": true,
      "errorRateThreshold": 0.05,
      "latencyThreshold": 5000,
      "throughputThreshold": 10
    }
  }
}