{
  "observability": {
    "enabled": true,
    "environment": "production",
    "version": "1.0.0",
    "lastUpdated": "2026-05-12T19:55:00Z",

    "logging": {
      "level": "INFO",
      "format": "json",
      "output": ["stdout", "file:logs/gentle-vanguard.jsonl"],
      "retention_days": 30,
      "sampling": {
        "enabled": false,
        "rate": 1.0
      },
      "fields": {
        "required": [
          "timestamp",
          "level",
          "service",
          "traceId",
          "spanId",
          "message",
          "component",
          "operation"
        ]
      }
    },

    "tracing": {
      "enabled": true,
      "version": "1.0.0",
      "protocol": "opentelemetry",
      "exporters": [
        {
          "type": "console",
          "enabled": true,
          "description": "Console exporter for development"
        },
        {
          "type": "jaeger",
          "enabled": false,
          "endpoint": "http://localhost:14268/api/traces",
          "sample_rate": 0.1,
          "description": "Jaeger (optional, for local development)"
        },
        {
          "type": "datadog",
          "enabled": false,
          "api_key": "${DATADOG_API_KEY}",
          "site": "datadoghq.com",
          "sample_rate": 1.0,
          "description": "Datadog (optional, for production)"
        }
      ],
      "max_trace_size_bytes": 65536,
      "attributes": {
        "service.name": "gentle-vanguard-orchestrator",
        "service.version": "2.9.0",
        "deployment.environment": "production"
      },
      "span_limits": {
        "max_attributes": 128,
        "max_events": 32,
        "max_links": 32
      }
    },

    "metrics": {
      "enabled": true,
      "version": "1.0.0",
      "format": "prometheus",
      "interval_seconds": 60,
      "exporters": [
        {
          "type": "prometheus-pushgateway",
          "enabled": false,
          "endpoint": "http://localhost:9091",
          "description": "Prometheus Pushgateway (optional)"
        }
      ],
      "collectors": [
        "agent_dispatch_latency",
        "skill_execution_time",
        "token_usage",
        "cache_performance",
        "error_rates",
        "user_satisfaction"
      ]
    },

    "alerts": {
      "enabled": true,
      "rules": [
        {
          "id": "agent_dispatch_slow",
          "name": "Agent Dispatch Slow",
          "metric": "agent_dispatch_seconds",
          "threshold": 1.0,
          "severity": "WARN",
          "window_minutes": 5,
          "action": "log_and_notify"
        },
        {
          "id": "skill_failure_rate_high",
          "name": "Skill Failure Rate High",
          "metric": "skill_failure_rate",
          "threshold": 0.05,
          "severity": "CRITICAL",
          "window_minutes": 5,
          "action": "page_oncall"
        },
        {
          "id": "token_budget_exceeded",
          "name": "Token Budget Exceeded",
          "metric": "token_usage_ratio",
          "threshold": 0.9,
          "severity": "HIGH",
          "window_minutes": 1440,
          "action": "notify_admin"
        }
      ]
    },

    "privacy": {
      "pii_masking": {
        "enabled": true,
        "patterns": {
          "email": "\\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Z|a-z]{2,}\\b",
          "ssn": "\\b\\d{3}-\\d{2}-\\d{4}\\b",
          "credit_card": "\\b\\d{4}[\\s-]?\\d{4}[\\s-]?\\d{4}[\\s-]?\\d{4}\\b",
          "phone": "\\b\\d{3}[-.]?\\d{3}[-.]?\\d{4}\\b"
        },
        "replacement": "[REDACTED]"
      },
      "retention": {
        "logs_days": 30,
        "traces_days": 14,
        "metrics_days": 30,
        "audit_logs_days": 730
      }
    },

    "siem": {
      "enabled": false,
      "comment": "Set enabled=true and configure provider+endpoint to activate cloud SIEM forwarding. Local structured log is always active.",
      "provider": "elk",
      "endpoint": "",
      "apiKey": "",
      "localOutputLog": "logs/siem-forwarded.jsonl",
      "alertLog": "logs/siem-alerts.jsonl",
      "bridgeScript": "scripts/security/siem-audit-bridge.ps1",
      "schedule": {
        "enabled": false,
        "cron": "*/15 * * * *",
        "description": "Run SIEM bridge every 15 minutes (configure via Task Scheduler or cron)"
      },
      "alertThresholds": {
        "massAccessCount": 10,
        "massAccessWindowMinutes": 5,
        "failureCount": 3,
        "failureWindowMinutes": 10
      },
      "auditSources": ["logs/secret-audit.jsonl"],
      "compliance": {
        "soc2Control": "CC7.2",
        "gdprArticle": "Art.33",
        "retentionYears": 2
      }
    }
  }
}
