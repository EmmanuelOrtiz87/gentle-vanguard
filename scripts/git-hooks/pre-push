#!/usr/bin/env bash
# pre-push hook - Runs before every push
# Install: ln -s ../../scripts/git-hooks/pre-push .git/hooks/

set -e

echo "[pre-push] Running checks..."

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Get current branch
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "detached")

echo "[pre-push] Branch: $BRANCH"

# Check if pushing to main/master
PROTECTED_BRANCHES="^(main|master|develop|release/.*)$"
if [[ "$BRANCH" =~ $PROTECTED_BRANCHES ]]; then
    echo -e "${YELLOW}[WARN] Pushing to protected branch: $BRANCH${NC}"
    
    # Check if there are commits ahead
    BEHIND=$(git rev-list --count --left-right "@{upstream}...HEAD" 2>/dev/null | cut -f1)
    if [[ -n "$BEHIND" ]] && [[ $BEHIND -gt 0 ]]; then
        echo -e "${RED}[ERROR] Branch is behind remote. Pull first.${NC}"
        exit 1
    fi
fi

# Run tests before push
echo "[pre-push] Running tests..."
if [[ -f "package.json" ]]; then
    if command -v npm &> /dev/null; then
        npm test -- --passWithNoTests 2>/dev/null || {
            echo -e "${RED}[ERROR] Tests failed${NC}"
            exit 1
        }
    fi
fi

if [[ -f "go.mod" ]]; then
    if command -v go &> /dev/null; then
        go test ./... 2>/dev/null || {
            echo -e "${RED}[ERROR] Go tests failed${NC}"
            exit 1
        }
    fi
fi

# Check commit message format (if commit-msg hook is available)
COMMIT_MSG_FILE=$(git rev-parse --git-dir)/COMMIT_EDITMSG
if [[ -f "$COMMIT_MSG_FILE" ]]; then
    COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")
    if [[ ! "$COMMIT_MSG" =~ ^(feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert)(\(.+\))?:[[:space:]].{1,50} ]]; then
        echo -e "${YELLOW}[WARN] Commit message should follow conventional commits format${NC}"
    fi
fi

# Check for uncommitted changes
if [[ -n "$(git status --porcelain)" ]]; then
    echo -e "${YELLOW}[WARN] You have uncommitted changes${NC}"
fi

echo -e "${GREEN}[pre-push] All checks passed!${NC}"
exit 0
