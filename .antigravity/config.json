{
  "name": "Antigravity - Gentle-Vanguard Workspace",
  "version": "2.0.0",
  "description": "Enhanced local-first policy with skill emulation and engram memory for Antigravity mission control",
  "workspace": {
    "projectRoot": ".",
    "configFiles": ["opencode.json", "AGENTS.md", "CLAUDE.md", ".cursorrules", ".antigravity/config.json"],
    "skillPaths": ["skills/", "~/.config/opencode/skills/"],
    "skillRegistry": ".atl/skill-registry.md"
  },
  "aiSettings": {
    "temperature": 0.3,
    "maxTokens": 4500,
    "localFirst": true,
    "planFirstForComplex": true
  },
  "toolPermissions": {
    "websearch": "deny",
    "webfetch": "deny",
    "codesearch": "deny",
    "externalTools": "ask"
  },
  "skillEmulation": {
    "enabled": true,
    "note": "Antigravity no tiene skill tool nativo — los skills se cargan manualmente",
    "criticalSkills": {
      "documentation": "skills/documentation-governance/SKILL.md",
      "sddLifecycle": "skills/sdd-lifecycle/SKILL.md",
      "codeReview": "skills/code-review-orchestrator-skill/SKILL.md",
      "sessionWorkflow": "skills/session-workflow-skill/SKILL.md",
      "testing": ["skills/playwright-skill/SKILL.md", "skills/pytest-skill/SKILL.md"]
    }
  },
  "contextManagement": {
    "useEngramMemory": true,
    "engramPaths": [".engram-data/", "scripts/.session/", "logs/"],
    "useLocalSkills": true,
    "useProjectDocs": true,
    "memoryTiering": {
      "hot": "active session",
      "warm": "1 day",
      "cold": "7 days"
    }
  },
  "preProcessing": {
    "enabled": true,
    "mandatory": true,
    "script": "scripts/utilities/pre-process-input.ps1",
    "scriptArgs": { "UserInput": "USER_INPUT_HERE", "WorkspaceRoot": "." },
    "fallbackBehavior": "continue"
  },
  "sessionManagement": {
    "autostart": {
      "enabled": true,
      "script": "scripts/utilities/session-autostart.cmd",
      "platform": "windows",
      "alternatives": {
        "linux": "bash ./scripts/utilities/session-autostart.sh",
        "macos": "bash ./scripts/utilities/session-autostart.sh"
      }
    },
    "tracking": {
      "project": "gentle-vanguard",
      "directory": ".",
      "sessionIdPattern": "session-YYYY-MM-DD-XX"
    }
  },
  "adaptiveOptimization": {
    "enabled": true,
    "controller": "scripts/utilities/adaptive-antigravity-profile.ps1",
    "mode": "temporary",
    "autoRestore": true
  },
  "language": { "default": "es", "technicalTerms": "en" },
  "missionParameters": {
    "project": "gentle-vanguard",
    "governanceLayers": ["GOV", "DEV", "QA", "OPS", "DOC", "SESSION"]
  }
}
