{
  "name": "example-hello-world",
  "version": "1.0.0",
  "description": "Example plugin that adds a simple 'hello' command to gv.ps1",
  "author": "Gentle-Vanguard Team",
  "main": "hello-world.ps1",
  "minGentle-VanguardVersion": "2.6.0",
  "provides": ["example", "greeting"],
  "hooks": [],
  "commands": [
    {
      "name": "hello",
      "description": "Prints a hello message",
      "script": "hello-world.ps1"
    }
  ],
  "dependencies": {
    "PowerShell": ">=7.0"
  }
}
