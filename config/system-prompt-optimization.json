{
  "$schema": "./opencode.schema.json#/definitions/promptOptimization",
  "version": "1.0.0",
  "description": "Configuración centralizada de optimización de system prompts",
  "_warning": "NO agregar esta config en opencode.json — OpenCode rechaza props no estándar",
  "enabled": true,
  "targetTokens": 2000,
  "maxTokens": 5000,
  "compression": "semantic",
  "abbreviations": {
    "implementation": "impl",
    "function": "fn",
    "configuration": "cfg",
    "required": "req",
    "optional": "opt",
    "reference": "ref",
    "standard": "std",
    "performance": "perf",
    "security": "sec",
    "development": "dev",
    "production": "prod",
    "environment": "env",
    "database": "db",
    "application": "app",
    "service": "svc",
    "repository": "repo"
  },
  "cache": {
    "enabled": true,
    "directory": ".session/prompt-cache",
    "ttl": 3600
  },
  "security": {
    "scanOnLoad": true,
    "blockSecrets": true,
    "blockXss": true
  },
  "versioning": {
    "enabled": true,
    "directory": ".session/prompt-versions"
  },
  "monitoring": {
    "trackTokens": true,
    "alertThreshold": 3000,
    "criticalThreshold": 5000
  }
}
