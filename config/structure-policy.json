{
  "_comment": "structureMode: enforce-canonical (greenfield/new repos) | adopt-existing (legacy/production repos  advisory only, no auto-refactor)",
  "structureMode": "enforce-canonical",
  "allowedScriptDirs": [
    "scripts/utilities",
    "scripts/diagnostics",
    "scripts/validation",
    "scripts/foundation",
    "scripts/project",
    "scripts/git-hooks",
    "skills",
    "tests"
  ],
  "allowedRootFiles": ["README.md", "config/mcp-servers.json"],
  "allowedRootMarkdownFiles": [
    "README.md",
    "AGENTS.md",
    "ANTIGRAVITY.md",
    "AI-MANDATORY-BEHAVIOR.md",
    "CHANGELOG.md",
    "CLAUDE.md",
    "CODEX.md",
    "CONTRIBUTING.md",
    "NEXT_SESSION_GUIDE.md",
    "TOKEN-REPORTING-PROCESS.md"
  ],
  "allowedRootJsonFiles": [
    "opencode.json",
    "engram-export.json"
  ],
  "deprecatedPathPatterns": [
    ".\\scripts\\update-all.ps1",
    "scripts/update-all.ps1"
  ]
}
