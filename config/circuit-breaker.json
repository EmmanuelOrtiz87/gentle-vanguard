{
  "version": "1.0.0",
  "description": "Circuit breaker configuration for agent harness resilience",
  "_comment": "Auto-healing: if failures exceed threshold within window, circuit opens to prevent cascade",
  "global": {
    "enabled": true,
    "defaultThreshold": 5,
    "defaultWindowSeconds": 60,
    "cooldownSeconds": 30,
    "halfOpenMaxRetries": 3
  },
  "perAgent": {
    "SESSION": { "threshold": 3, "windowSeconds": 30, "cooldownSeconds": 15 },
    "BA": { "threshold": 5, "windowSeconds": 60, "cooldownSeconds": 30 },
    "SAD": { "threshold": 5, "windowSeconds": 60, "cooldownSeconds": 30 },
    "DEV": { "threshold": "inherit", "cooldownSeconds": 20 },
    "QA": { "threshold": 3, "windowSeconds": 30, "cooldownSeconds": 15 },
    "OPS": { "threshold": 2, "windowSeconds": 30, "cooldownSeconds": 60 },
    "GOV": { "threshold": 3, "windowSeconds": 30, "cooldownSeconds": 30 },
    "DOC": { "threshold": 5, "windowSeconds": 60, "cooldownSeconds": 30 },
    "MKT": { "threshold": "inherit" },
    "PREMORTEM": { "threshold": "inherit" }
  },
  "errorCategories": {
    "CRITICAL": { "weight": 3, "autoOpen": true },
    "HIGH": { "weight": 2, "autoOpen": true },
    "MEDIUM": { "weight": 1, "autoOpen": false },
    "LOW": { "weight": 0, "autoOpen": false }
  },
  "stateFile": ".runtime/circuit-breaker-state.json"
}
