{
  "tool": "cline",
  "displayName": "Cline",
  "version": "latest",
  "preProcess": {
    "loadSkills": true,
    "skillTool": "skill",
    "autoLoad": true
  },
  "capabilities": ["mcp", "skills", "code_completion", "terminal"],
  "configFiles": [
    ".clinerules",
    ".clinerules.optimized",
    ".clineignore",
    ".cline/config.json",
    ".claude/settings.json"
  ],
  "hooks": {
    "preToolCall": "scripts/utilities/pre-process-input.ps1",
    "sessionStart": "scripts/utilities/session-autostart.cmd",
    "adaptiveProfile": "scripts/utilities/adaptive-claude-cline-profile.ps1",
    "sessionStartPlatform": {
      "windows": "scripts/utilities/session-autostart.cmd",
      "linux": "bash ./scripts/utilities/session-autostart.sh",
      "macos": "bash ./scripts/utilities/session-autostart.sh"
    }
  }
}
