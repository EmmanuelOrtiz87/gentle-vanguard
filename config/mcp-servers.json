{
  "version": "1.1.0",
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "--include-workspace-root",
        "--workspace",
        "%USERPROFILE%\\mcp-workspace",
        "--no",
        "--offline",
        "@modelcontextprotocol/server-filesystem",
        "."
      ],
      "description": "File system access for gentle-vanguard — offline hardened (npx supply-chain protection)",
      "security": {
        "hardened": true,
        "mode": "offline",
        "workspace": "%USERPROFILE%\\mcp-workspace",
        "pinnedVersion": "2026.1.14",
        "updateProcedure": "cd %USERPROFILE%\\mcp-workspace && npm update @modelcontextprotocol/server-filesystem && review package-lock.json changes before next use"
      }
    },
    "engram-kb": {
      "command": "tools\\engram.exe",
      "args": [
        "mcp",
        "--tools=agent"
      ],
      "description": "Engram Knowledge Base via native MCP stdio server",
      "security": {
        "hardened": true,
        "mode": "local",
        "storage": "%USERPROFILE%\\.engram",
        "transport": "stdio",
        "accessControl": "workspace-only"
      },
      "persistence": {
        "enabled": true,
        "syncCommand": "tools\\engram.exe sync --project gentle-vanguard",
        "exportFormat": "json"
      }
    }
  },
  "autoStart": true
}
