{
  "version": "1.0.0",
  "description": "Foundation Project - 28 Quality Gates Configuration",
  "gates": [
    {
      "id": "pre-commit-format",
      "name": "Code Formatting",
      "stage": "pre-commit",
      "tool": "prettier",
      "required": true,
      "description": "Validate code formatting standards",
      "command": "prettier --check .",
      "failureAction": "block"
    },
    {
      "id": "pre-commit-lint",
      "name": "Linting",
      "stage": "pre-commit",
      "tool": "eslint",
      "required": true,
      "description": "Check for code quality issues",
      "command": "eslint . --max-warnings 0",
      "failureAction": "block"
    },
    {
      "id": "pre-commit-type-check",
      "name": "Type Checking",
      "stage": "pre-commit",
      "tool": "typescript",
      "required": true,
      "description": "Validate TypeScript types",
      "command": "tsc --noEmit",
      "failureAction": "block"
    },
    {
      "id": "pre-commit-secrets",
      "name": "Secret Scanning",
      "stage": "pre-commit",
      "tool": "secretlint",
      "required": true,
      "description": "Scan for exposed secrets",
      "command": "secretlint '**/*'",
      "failureAction": "block"
    },
    {
      "id": "pre-commit-deps",
      "name": "Dependency Audit",
      "stage": "pre-commit",
      "tool": "npm-audit",
      "required": true,
      "description": "Check for vulnerable dependencies",
      "command": "npm audit --audit-level=moderate",
      "failureAction": "warn"
    },
    {
      "id": "build-compile",
      "name": "Compilation",
      "stage": "build",
      "tool": "typescript",
      "required": true,
      "description": "Compile TypeScript to JavaScript",
      "command": "tsc",
      "failureAction": "block"
    },
    {
      "id": "build-artifacts",
      "name": "Build Artifacts",
      "stage": "build",
      "tool": "webpack",
      "required": true,
      "description": "Generate build artifacts",
      "command": "webpack --mode production",
      "failureAction": "block"
    },
    {
      "id": "build-performance",
      "name": "Build Performance",
      "stage": "build",
      "tool": "custom",
      "required": true,
      "description": "Check build time performance",
      "threshold": 300,
      "unit": "seconds",
      "failureAction": "warn"
    },
    {
      "id": "build-size",
      "name": "Artifact Size",
      "stage": "build",
      "tool": "custom",
      "required": true,
      "description": "Validate artifact size",
      "threshold": 5,
      "unit": "MB",
      "failureAction": "warn"
    },
    {
      "id": "build-reproducibility",
      "name": "Build Reproducibility",
      "stage": "build",
      "tool": "custom",
      "required": true,
      "description": "Ensure reproducible builds",
      "failureAction": "block"
    },
    {
      "id": "build-deps",
      "name": "Dependency Resolution",
      "stage": "build",
      "tool": "npm",
      "required": true,
      "description": "Verify all dependencies resolved",
      "command": "npm ci",
      "failureAction": "block"
    },
    {
      "id": "test-unit",
      "name": "Unit Tests",
      "stage": "test",
      "tool": "jest",
      "required": true,
      "description": "Execute unit tests",
      "command": "jest --coverage",
      "failureAction": "block"
    },
    {
      "id": "test-integration",
      "name": "Integration Tests",
      "stage": "test",
      "tool": "jest",
      "required": true,
      "description": "Execute integration tests",
      "command": "jest --testPathPattern=integration",
      "failureAction": "block"
    },
    {
      "id": "test-e2e",
      "name": "E2E Tests",
      "stage": "test",
      "tool": "cypress",
      "required": true,
      "description": "Execute end-to-end tests",
      "command": "cypress run",
      "failureAction": "block"
    },
    {
      "id": "test-coverage",
      "name": "Test Coverage",
      "stage": "test",
      "tool": "jest",
      "required": true,
      "description": "Verify test coverage threshold",
      "threshold": 85,
      "unit": "%",
      "failureAction": "block"
    },
    {
      "id": "test-performance",
      "name": "Performance Tests",
      "stage": "test",
      "tool": "custom",
      "required": true,
      "description": "Run performance benchmarks",
      "command": "npm run test:performance",
      "failureAction": "warn"
    },
    {
      "id": "test-security",
      "name": "Security Tests",
      "stage": "test",
      "tool": "custom",
      "required": true,
      "description": "Run security tests",
      "command": "npm run test:security",
      "failureAction": "block"
    },
    {
      "id": "test-accessibility",
      "name": "Accessibility Tests",
      "stage": "test",
      "tool": "axe",
      "required": true,
      "description": "Check accessibility compliance",
      "command": "npm run test:a11y",
      "failureAction": "warn"
    },
    {
      "id": "test-compatibility",
      "name": "Compatibility Tests",
      "stage": "test",
      "tool": "custom",
      "required": true,
      "description": "Test cross-browser compatibility",
      "command": "npm run test:compat",
      "failureAction": "warn"
    },
    {
      "id": "quality-complexity",
      "name": "Code Complexity",
      "stage": "quality",
      "tool": "sonarqube",
      "required": true,
      "description": "Analyze code complexity",
      "threshold": 15,
      "unit": "cognitive complexity",
      "failureAction": "warn"
    },
    {
      "id": "quality-duplication",
      "name": "Duplication Detection",
      "stage": "quality",
      "tool": "sonarqube",
      "required": true,
      "description": "Detect code duplication",
      "threshold": 3,
      "unit": "%",
      "failureAction": "warn"
    },
    {
      "id": "quality-deadcode",
      "name": "Dead Code",
      "stage": "quality",
      "tool": "custom",
      "required": true,
      "description": "Remove dead code",
      "failureAction": "warn"
    },
    {
      "id": "quality-docs",
      "name": "Documentation Coverage",
      "stage": "quality",
      "tool": "typedoc",
      "required": true,
      "description": "Verify documentation coverage",
      "threshold": 90,
      "unit": "%",
      "failureAction": "warn"
    },
    {
      "id": "quality-architecture",
      "name": "Architecture Compliance",
      "stage": "quality",
      "tool": "custom",
      "required": true,
      "description": "Verify architecture rules",
      "failureAction": "block"
    },
    {
      "id": "security-scan",
      "name": "Vulnerability Scanning",
      "stage": "security",
      "tool": "snyk",
      "required": true,
      "description": "Scan for vulnerabilities",
      "command": "snyk test",
      "failureAction": "block"
    },
    {
      "id": "security-sast",
      "name": "SAST Analysis",
      "stage": "security",
      "tool": "sonarqube",
      "required": true,
      "description": "Static application security testing",
      "failureAction": "block"
    },
    {
      "id": "security-deps",
      "name": "Dependency Vulnerabilities",
      "stage": "security",
      "tool": "npm-audit",
      "required": true,
      "description": "Check dependency vulnerabilities",
      "command": "npm audit",
      "failureAction": "block"
    },
    {
      "id": "deploy-readiness",
      "name": "Production Readiness",
      "stage": "deploy",
      "tool": "custom",
      "required": true,
      "description": "Verify production readiness",
      "failureAction": "block"
    }
  ],
  "stages": {
    "pre-commit": {
      "description": "Checks run before commit",
      "order": 1,
      "required": true
    },
    "build": {
      "description": "Checks during build",
      "order": 2,
      "required": true
    },
    "test": {
      "description": "Checks during testing",
      "order": 3,
      "required": true
    },
    "quality": {
      "description": "Code quality checks",
      "order": 4,
      "required": true
    },
    "security": {
      "description": "Security checks",
      "order": 5,
      "required": true
    },
    "deploy": {
      "description": "Deployment readiness checks",
      "order": 6,
      "required": true
    }
  },
  "failureActions": {
    "block": "Prevent progression to next stage",
    "warn": "Log warning but allow progression",
    "info": "Log info message"
  },
  "reporting": {
    "generateReport": true,
    "reportFormat": "json",
    "reportPath": "reports/quality-gates-report.json",
    "dashboardUrl": "http://localhost:3000/dashboard"
  }
}