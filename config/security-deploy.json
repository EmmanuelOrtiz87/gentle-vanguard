{
  "version": "1.0.0",
  "name": "security-deploy-config",
  "description": "Security deployment configuration - local vs production handling",

  "environments": {
    "local": {
      "requireApiKey": false,
      "autoAuth": true,
      "description": "Local development environment"
    },
    "repo": {
      "requireApiKey": true,
      "autoAuth": false,
      "description": "Downloaded/cloned repository - requires initial setup"
    }
  },

  "files": {
    "neverCommit": [
      ".workspace/config/owner-auth.json",
      ".workspace/config/session-auth.json",
      ".workspace/config/dev-credentials.json",
      ".env",
      ".env.local",
      ".runtime/security-state.json",
      ".runtime/*-audit.log"
    ],
    "encryptBeforeCommit": [
      ".workspace/config/owner-auth.json"
    ],
    "templateFiles": [
      ".workspace/config/owner-auth.example.json",
      ".workspace/config/owner-auth.encrypted"
    ]
  },

  "setup": {
    "autoOnFirstRun": true,
    "requireUserApiKey": true,
    "generateNewApiKey": true,
    "encryptionEnabled": true
  },

  "developerFlow": {
    "description": "What developers see when they clone the repo",
    "steps": [
      "1. Run .\scripts\security\setup-secure.ps1",
      "2. Script generates new API key for developer",
      "3. Developer stores their key locally (not committed)",
      "4. Security enforced for restricted operations"
    ]
  }
}