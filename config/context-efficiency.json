    "applyChatLevel": "chat-compact",
    "stateFile": ".session/token-autopilot-state.json",
    "manualAliases": {
      "economy": [
        "ahorro",
        "modo-ahorro",
        "ahorro-on",
        "economy",
        "token-save"
      ],
      "balanced": [
        "normal",
        "balanceado",
        "modo-normal",
        "ahorro-off"
      ],
      "detailed": [
        "detallado",
        "detalle",
        "full",
        "verbose"
      ]
